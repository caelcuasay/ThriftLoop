@{
    ViewData["Title"] = "Check Your Email";
}

<div class="mobile-auth-screen">
    <div class="mobile-auth-header">
        <h1 class="mobile-auth-title">Email sent</h1>
        <p class="mobile-auth-subtitle">
            If an account with that email exists, we've sent a password reset link.
            Check your inbox — the link expires in <strong>1 hour</strong>.
        </p>
    </div>

    <div class="mobile-auth-body">
        <div class="mobile-confirm-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="2" opacity=".15" />
                <path d="M8 18l16 10 16-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <rect x="8" y="14" width="32" height="22" rx="3" stroke="currentColor" stroke-width="2" />
                <path d="M18 28l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>

        <p class="mobile-hint-text">
            Didn't get it? Check your spam folder, or
            <a asp-action="ForgotPassword" asp-controller="Auth" class="mobile-link">try again</a>.
        </p>
    </div>

    <div class="mobile-auth-footer">
        <p>
            <a asp-action="Login" asp-controller="Auth" class="mobile-link">Back to sign in</a>
        </p>
    </div>
</div>