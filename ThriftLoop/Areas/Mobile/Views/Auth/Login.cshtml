@model ThriftLoop.DTOs.Auth.LoginDTO
@{
    ViewData["Title"] = "Sign In";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="mobile-auth-screen">
    <div class="mobile-auth-header">
        <div class="mobile-auth-logo">
            <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill="currentColor" d="M382,136c-40.87,0-73.46,20.53-93.6,37.76l-.71.61-11.47,12.47,25.32,41.61,18.74-18.79C339.89,193.1,361.78,184,382,184c40.8,0,74,32.3,74,72s-33.2,72-74,72c-62,0-104.14-81.95-104.56-82.78h0C275,240.29,221.56,136,130,136,62.73,136,8,189.83,8,256S62.73,376,130,376c32.95,0,65.38-13.11,93.79-37.92l.61-.54,11.38-12.38-25.33-41.61-18.83,18.88C172,319.4,151.26,328,130,328c-40.8,0-74-32.3-74-72s33.2-72,74-72c62,0,104.14,81.95,104.56,82.78h0C237,271.71,290.44,376,382,376c67.27,0,122-53.83,122-120S449.27,136,382,136Z" />
            </svg>
        </div>
        <h1 class="mobile-auth-title">Welcome back</h1>
        <p class="mobile-auth-subtitle">Sign in to your account</p>
    </div>

    <div class="mobile-auth-body">
        @* Google error *@
        @if (TempData["ExternalAuthError"] is string extError)
        {
            <div class="mobile-alert mobile-alert--error" role="alert">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-.75-4.75a.75.75 0 001.5 0v-4.5a.75.75 0 00-1.5 0v4.5zm.75-7a.75.75 0 110 1.5.75.75 0 010-1.5z" clip-rule="evenodd" /></svg>
                <span>@extError</span>
            </div>
        }

        @* Reset success *@
        @if (TempData["ResetSuccess"] is string resetMsg)
        {
            <div class="mobile-alert mobile-alert--success" role="alert">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>@resetMsg</span>
            </div>
        }

        @* Reset error *@
        @if (TempData["ResetError"] is string resetErr)
        {
            <div class="mobile-alert mobile-alert--error" role="alert">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-.75-4.75a.75.75 0 001.5 0v-4.5a.75.75 0 00-1.5 0v4.5zm.75-7a.75.75 0 110 1.5.75.75 0 010-1.5z" clip-rule="evenodd" /></svg>
                <span>@resetErr</span>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mobile-alert mobile-alert--error" role="alert">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-.75-4.75a.75.75 0 001.5 0v-4.5a.75.75 0 00-1.5 0v4.5zm.75-7a.75.75 0 110 1.5.75.75 0 010-1.5z" clip-rule="evenodd" /></svg>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        @* Google sign-in *@
        <a asp-action="GoogleLogin" asp-controller="Auth"
               asp-route-returnUrl="@returnUrl"
               class="mobile-btn mobile-btn--google">
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" />
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
            </svg>
            Continue with Google
        </a>

        <div class="mobile-divider">
            <span>or sign in with email</span>
        </div>

        <form asp-action="Login" asp-controller="Auth"
              asp-route-returnUrl="@returnUrl"
              method="post" novalidate class="mobile-form">
            @Html.AntiForgeryToken()

            <div class="mobile-field">
                <label asp-for="Email" class="mobile-field__label">Email</label>
                <input asp-for="Email"
                       class="mobile-field__input"
                       type="email"
                       autocomplete="email"
                       placeholder="you@example.com"
                       spellcheck="false" />
                <span asp-validation-for="Email" class="mobile-field__error"></span>
            </div>

            <div class="mobile-field">
                <div class="mobile-field__label-row">
                    <label asp-for="Password" class="mobile-field__label">Password</label>
                    <a asp-action="ForgotPassword" asp-controller="Auth" class="mobile-field__link">Forgot?</a>
                </div>
                <div class="mobile-field__input-wrap">
                    <input asp-for="Password"
                           id="passwordInput"
                           class="mobile-field__input"
                           type="password"
                           autocomplete="current-password"
                           placeholder="••••••••" />
                    <button type="button" class="mobile-toggle-password" aria-label="Toggle password visibility"
                            onclick="togglePassword()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="mobile-field__error"></span>
            </div>

            <div class="mobile-field mobile-field--checkbox">
                <label class="mobile-checkbox">
                    <input asp-for="RememberMe" type="checkbox" class="mobile-checkbox__input" />
                    <span class="mobile-checkbox__custom"></span>
                    <span class="mobile-checkbox__text">Keep me signed in</span>
                </label>
            </div>

            <button type="submit" class="mobile-btn mobile-btn--primary">
                Sign In
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
            </button>
        </form>
    </div>

    <div class="mobile-auth-footer">
        <p>
            Don't have an account?
            <a asp-action="Register" asp-controller="Auth" asp-area="Mobile" class="mobile-link">Create one free</a>
        </p>
        <p class="mobile-auth-footer__rider">
            <a asp-action="RiderRegister" asp-controller="Auth" asp-area="Mobile" class="mobile-link">Apply as a Rider →</a>
        </p>
    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>