@model ThriftLoop.DTOs.Auth.ForgotPasswordDTO
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="mobile-auth-screen">
    <div class="mobile-auth-header">
        <div class="mobile-auth-back">
            <a asp-action="Login" asp-controller="Auth" class="mobile-back-btn" aria-label="Back to sign in">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M19 12H5m7-7l-7 7 7 7" /></svg>
            </a>
        </div>
        <h1 class="mobile-auth-title">Forgot your password?</h1>
        <p class="mobile-auth-subtitle">Enter your email and we'll send you a reset link.</p>
    </div>

    <div class="mobile-auth-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mobile-alert mobile-alert--error" role="alert">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-.75-4.75a.75.75 0 001.5 0v-4.5a.75.75 0 00-1.5 0v4.5zm.75-7a.75.75 0 110 1.5.75.75 0 010-1.5z" clip-rule="evenodd" /></svg>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="ForgotPassword" asp-controller="Auth"
              method="post" novalidate class="mobile-form">
            @Html.AntiForgeryToken()

            <div class="mobile-field">
                <label asp-for="Email" class="mobile-field__label">Email</label>
                <input asp-for="Email"
                       class="mobile-field__input"
                       type="email"
                       autocomplete="email"
                       placeholder="you@example.com"
                       spellcheck="false"
                       autofocus />
                <span asp-validation-for="Email" class="mobile-field__error"></span>
            </div>

            <button type="submit" class="mobile-btn mobile-btn--primary">
                Send Reset Link
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18"><path d="M3.105 2.289a.75.75 0 00-.826.95l1.414 4.925A1.5 1.5 0 005.135 9.25h6.115a.75.75 0 010 1.5H5.135a1.5 1.5 0 00-1.442 1.086l-1.414 4.926a.75.75 0 00.826.95 28.896 28.896 0 0015.293-7.154.75.75 0 000-1.115A28.897 28.897 0 003.105 2.289z" /></svg>
            </button>
        </form>
    </div>

    <div class="mobile-auth-footer">
        <p>
            Remembered it?
            <a asp-action="Login" asp-controller="Auth" class="mobile-link">Back to sign in</a>
        </p>
    </div>
</div>