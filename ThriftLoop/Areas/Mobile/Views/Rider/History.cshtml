@model IReadOnlyList<ThriftLoop.Models.Delivery>
@{
    ViewData["Title"] = "Delivery History";
    Layout = "~/Areas/Mobile/Views/Shared/_MobileLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/mobile-rider.css" asp-append-version="true" />
}

<div class="mobile-rider-screen">
    <!-- Header -->
    <div class="mobile-rider-header">
        <div>
            <h1 class="mobile-rider-header__title">Delivery History</h1>
            <p class="mobile-rider-header__subtitle">@Model.Count delivery@(Model.Count != 1 ? "ies" : "y") recorded</p>
        </div>
    </div>

    <a asp-action="Index" class="mobile-rider-back">
        <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" /></svg>
        Back to Dashboard
    </a>

    @if (!Model.Any())
    {
        <div class="mobile-rider-empty">
            <div class="mobile-rider-empty__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M9 12h.01M15 12h.01M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2s10 4.477 10 10z" /></svg>
            </div>
            <h3 class="mobile-rider-empty__title">No delivery history</h3>
            <p class="mobile-rider-empty__text">You haven't completed any deliveries yet.</p>
            <a asp-action="Index" class="mobile-rider-btn mobile-rider-btn--primary">Browse Available Jobs</a>
        </div>
    }
    else
    {
        <div class="mobile-rider-history-list">
            @foreach (var delivery in Model)
            {
                var order = delivery.Order;
                var item = order?.Item;
                DateTime? completionTime = delivery.ConfirmedByBuyerAt ?? delivery.DeliveredAt ?? delivery.PickedUpAt;
                var isCompleted = delivery.Status == ThriftLoop.Enums.DeliveryStatus.Completed;
                
                string statusClass = delivery.Status switch
                {
                    ThriftLoop.Enums.DeliveryStatus.Completed => "completed",
                    ThriftLoop.Enums.DeliveryStatus.Delivered => "delivered",
                    ThriftLoop.Enums.DeliveryStatus.PickedUp => "pickedup",
                    ThriftLoop.Enums.DeliveryStatus.Accepted => "accepted",
                    _ => "default"
                };

                <div class="mobile-rider-history-card">
                    <div class="mobile-rider-history-card__main">
                        <div class="mobile-rider-history-card__image">
                            @if (!string.IsNullOrEmpty(item?.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Title" loading="lazy" />
                            }
                            else
                            {
                                <div style="font-size:1.5rem;">📦</div>
                            }
                        </div>
                        <div class="mobile-rider-history-card__info">
                            <h3 class="mobile-rider-history-card__title">@(item?.Title ?? $"Item #{order?.ItemId}")</h3>
                            <div class="mobile-rider-history-card__meta">
                                <span class="mobile-rider-status mobile-rider-status--@statusClass">
                                    @delivery.Status
                                </span>
                                <span class="mobile-rider-history-card__date">
                                    @(delivery.AcceptedAt?.ToString("MMM d, yyyy") ?? "N/A")
                                </span>
                            </div>
                            @if (completionTime.HasValue)
                            {
                                <div class="mobile-rider-history-card__completed">
                                    @if (isCompleted)
                                    {
                                        <span>✅ Completed @completionTime.Value.ToString("MMM d, yyyy")</span>
                                    }
                                    else
                                    {
                                        <span>📅 Last update: @completionTime.Value.ToString("MMM d, yyyy")</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="mobile-rider-history-card__footer">
                        <div class="mobile-rider-history-card__detail">
                            <span class="mobile-rider-history-card__detail-label">Earnings</span>
                            <span class="mobile-rider-history-card__detail-value">₱@((order?.DeliveryFee ?? 0m).ToString("N2"))</span>
                        </div>
                        <div class="mobile-rider-history-card__detail">
                            <span class="mobile-rider-history-card__detail-label">Order Total</span>
                            <span class="mobile-rider-history-card__detail-value">₱@((order?.FinalPrice ?? 0m).ToString("N2"))</span>
                        </div>
                        <div class="mobile-rider-history-card__detail">
                            <span class="mobile-rider-history-card__detail-label">Payment</span>
                            <span class="mobile-rider-history-card__detail-value">@(order?.PaymentMethod.ToString() ?? "N/A")</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Summary Footer -->
        <div class="mobile-rider-summary">
            <div class="mobile-rider-summary__row">
                <span>Total Deliveries</span>
                <span class="mobile-rider-summary__value">@Model.Count</span>
            </div>
            <div class="mobile-rider-summary__row">
                <span>Completed</span>
                <span class="mobile-rider-summary__value mobile-rider-summary__value--success">
                    @Model.Count(d => d.Status == ThriftLoop.Enums.DeliveryStatus.Completed)
                </span>
            </div>
            <div class="mobile-rider-summary__row">
                <span>Total Earnings</span>
                <span class="mobile-rider-summary__value mobile-rider-summary__value--highlight">
                    ₱@Model.Sum(d => d.Order?.DeliveryFee ?? 0m).ToString("N2")
                </span>
            </div>
        </div>
    }

    <a asp-action="Index" class="mobile-rider-btn mobile-rider-btn--outline mobile-rider-btn--full" style="margin: 0 20px;">
        <svg class="mobile-rider-btn__icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" /></svg>
        Back to Dashboard
    </a>
</div>