@model ThriftLoop.Models.Delivery
@using ThriftLoop.Models
@using ThriftLoop.Enums
@{
    ViewData["Title"] = "Active Delivery";
    var riderName = ViewBag.RiderName as string ?? "Rider";
    var riderLat = ViewBag.RiderLatitude as decimal?;
    var riderLng = ViewBag.RiderLongitude as decimal?;
    Layout = "~/Areas/Mobile/Views/Shared/_MobileLayout.cshtml";

    var order = Model?.Order;
    var item = order?.Item;
    var buyer = order?.Buyer;
    
    string sellerName;
    string sellerAddress;
    string sellerContact;
    decimal? sellerLat = null;
    decimal? sellerLng = null;
    
    if (item?.ShopId != null && item?.Shop != null)
    {
        sellerName = item.Shop.ShopName;
        sellerAddress = item.Shop.StoreAddress ?? "Store address not provided";
        sellerContact = item.Shop.User?.Email?.Split('@')[0] ?? "Seller";
        sellerLat = item.Shop.Latitude;
        sellerLng = item.Shop.Longitude;
    }
    else if (order?.Seller != null)
    {
        sellerName = order.Seller.Email?.Split('@')[0] ?? "Seller";
        sellerAddress = order.Seller.Address ?? "Address not provided";
        sellerContact = order.Seller.PhoneNumber ?? order.Seller.Email ?? "No contact";
        sellerLat = order.Seller.Latitude;
        sellerLng = order.Seller.Longitude;
    }
    else
    {
        sellerName = "Unknown Seller";
        sellerAddress = "Address not available";
        sellerContact = "No contact info";
    }
    
    var buyerName = buyer?.Email?.Split('@')[0] ?? "Buyer";
    var buyerAddress = buyer?.Address ?? "Address not provided";
    var buyerContact = buyer?.PhoneNumber ?? buyer?.Email ?? "No contact";
    var buyerLat = buyer?.Latitude;
    var buyerLng = buyer?.Longitude;
    
    var itemPrice = (order?.FinalPrice ?? 0m) - (order?.DeliveryFee ?? 0m);
    var deliveryFee = order?.DeliveryFee ?? 50m;
    
    string GetStatusClass()
    {
        return Model?.Status switch
        {
            DeliveryStatus.Accepted => "mobile-rider-status--accepted",
            DeliveryStatus.PickedUp => "mobile-rider-status--pickedup",
            DeliveryStatus.Delivered => "mobile-rider-status--delivered",
            DeliveryStatus.Completed => "mobile-rider-status--completed",
            _ => "mobile-rider-status--default"
        };
    }
    
    string GetStatusText()
    {
        return Model?.Status switch
        {
            DeliveryStatus.Accepted => "Accepted - En Route to Seller",
            DeliveryStatus.PickedUp => "Picked Up - En Route to Buyer",
            DeliveryStatus.Delivered => "Delivered - Awaiting Confirmation",
            DeliveryStatus.Completed => "Completed",
            _ => Model?.Status.ToString() ?? "Unknown"
        };
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/mobile-rider.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@if (Model == null)
{
    <!-- Empty State -->
    <div class="mobile-rider-screen">
        <div class="mobile-rider-empty">
            <div class="mobile-rider-empty__icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M3 7h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z" />
                    <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                    <circle cx="8" cy="13" r="1" />
                    <circle cx="16" cy="13" r="1" />
                </svg>
            </div>
            <h3 class="mobile-rider-empty__title">No active delivery</h3>
            <p class="mobile-rider-empty__text">You don't have an active delivery at the moment.</p>
            <a href="@Url.Action("Index")" class="mobile-rider-btn mobile-rider-btn--primary">Browse available jobs</a>
        </div>
    </div>
}
else
{
    <!-- Toast Messages -->
    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div class="mobile-rider-toast mobile-rider-toast--success" style="position: fixed; top: 16px; left: 16px; right: 16px; z-index: 1000;">
            <svg class="mobile-rider-toast__icon" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span>@successMsg</span>
        </div>
    }
    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="mobile-rider-toast mobile-rider-toast--error" style="position: fixed; top: 16px; left: 16px; right: 16px; z-index: 1000;">
            <svg class="mobile-rider-toast__icon" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
            </svg>
            <span>@errMsg</span>
        </div>
    }

    <!-- Full-screen Map Background Layout -->
    <div class="mobile-rider-map-bg">
        <!-- Full-screen Map -->
        <div id="deliveryMap" class="mobile-rider-map-bg__container"></div>

        <!-- Floating Back Button -->
        <a asp-action="Index" class="mobile-rider-map-bg__back">
            <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20">
                <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
            </svg>
        </a>

        <!-- Status Badge -->
        <div style="position: absolute; top: 16px; right: 16px; z-index: 100;">
            <span class="mobile-rider-status @GetStatusClass()" style="font-size: 0.75rem; padding: 6px 12px;">@GetStatusText()</span>
        </div>

        <!-- Floating Item Card -->
        <div class="mobile-rider-float-card" style="top: 70px;">
            <div class="mobile-rider-float-card__image">
                @if (!string.IsNullOrEmpty(item?.ImageUrl))
                {
                    <img src="@item.ImageUrl" alt="@item.Title" />
                }
                else
                {
                    <div class="mobile-rider-float-card__placeholder">📦</div>
                }
            </div>
            <div class="mobile-rider-float-card__content">
                <h1 class="mobile-rider-float-card__title">@(item?.Title ?? $"Item #{order?.ItemId}")</h1>
                <div class="mobile-rider-float-card__meta">
                    <span>@(item?.Category ?? "General")</span>
                    <span>•</span>
                    <span>@(item?.Condition ?? "N/A")</span>
                </div>
                <span class="mobile-rider-float-card__badge mobile-rider-float-card__badge--@(order?.PaymentMethod == PaymentMethod.Wallet ? "wallet" : "cod")">
                    @(order?.PaymentMethod == PaymentMethod.Wallet ? "Wallet" : "COD")
                </span>
            </div>
        </div>

        <!-- Bottom Sheet -->
        <div class="mobile-rider-bottom-sheet">
            <!-- Distance Summary -->
            <div class="mobile-rider-bottom-sheet__distances">
                <div class="mobile-rider-distance-pill" id="currentLegBlock">
                    <span class="mobile-rider-distance-pill__label" id="currentLegLabel">Current Leg</span>
                    <span class="mobile-rider-distance-pill__value" id="currentLegDistance">--</span>
                    <span class="mobile-rider-distance-pill__note" id="currentLegNote"></span>
                </div>
                <div class="mobile-rider-distance-pill">
                    <span class="mobile-rider-distance-pill__label">Total Route</span>
                    <span class="mobile-rider-distance-pill__value" id="totalRouteDistance">--</span>
                    <span class="mobile-rider-distance-pill__note" id="totalRouteNote"></span>
                </div>
            </div>

            <!-- Locations -->
            <div class="mobile-rider-bottom-sheet__locations">
                <div class="mobile-rider-route-stop">
                    <div class="mobile-rider-route-stop__dot mobile-rider-route-stop__dot--pickup"></div>
                    <div class="mobile-rider-route-stop__content">
                        <div class="mobile-rider-route-stop__label">Pickup from Seller</div>
                        <div class="mobile-rider-route-stop__address">@sellerAddress</div>
                        <div class="mobile-rider-route-stop__contact">@sellerName • @sellerContact</div>
                    </div>
                </div>
                <div class="mobile-rider-route-line"></div>
                <div class="mobile-rider-route-stop">
                    <div class="mobile-rider-route-stop__dot mobile-rider-route-stop__dot--dropoff"></div>
                    <div class="mobile-rider-route-stop__content">
                        <div class="mobile-rider-route-stop__label">Deliver to Buyer</div>
                        <div class="mobile-rider-route-stop__address">@buyerAddress</div>
                        <div class="mobile-rider-route-stop__contact">@buyerName • @buyerContact</div>
                    </div>
                </div>
            </div>

            <!-- Earnings & Actions -->
            <div class="mobile-rider-bottom-sheet__actions">
                <div class="mobile-rider-earnings-compact">
                    <div class="mobile-rider-earnings-compact__row">
                        <span>Your Delivery Fee</span>
                        <span class="mobile-rider-earnings-compact__highlight">₱@deliveryFee.ToString("N2")</span>
                    </div>
                </div>

                @if (Model.Status == DeliveryStatus.Accepted)
                {
                    <form asp-action="MarkPickedUp" method="post" id="pickupForm" onsubmit="return confirmFormSubmit('Confirm you have picked up the item from the seller?', this)">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="deliveryId" value="@Model.Id" />
                        <button type="submit" class="mobile-rider-btn mobile-rider-btn--primary mobile-rider-btn--full">
                            <svg class="mobile-rider-btn__icon" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                            </svg>
                            Mark as Picked Up
                        </button>
                    </form>
                }
                else if (Model.Status == DeliveryStatus.PickedUp)
                {
                    <form asp-action="MarkDelivered" method="post" id="deliverForm" onsubmit="return confirmFormSubmit('Confirm you have delivered the item to the buyer?', this)">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="deliveryId" value="@Model.Id" />
                        <button type="submit" class="mobile-rider-btn mobile-rider-btn--primary mobile-rider-btn--full" style="background: linear-gradient(135deg, #059669, #10b981);">
                            <svg class="mobile-rider-btn__icon" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                            </svg>
                            Mark as Delivered
                        </button>
                    </form>
                }
                else if (Model.Status == DeliveryStatus.Delivered)
                {
                    <div class="mobile-rider-toast mobile-rider-toast--warning">
                        <span>⏳ Awaiting buyer confirmation...</span>
                    </div>
                }
                else if (Model.Status == DeliveryStatus.Completed)
                {
                    <div class="mobile-rider-toast mobile-rider-toast--success">
                        <span>🎉 Delivery completed successfully!</span>
                    </div>
                }

                <a asp-action="Index" class="mobile-rider-btn mobile-rider-btn--ghost mobile-rider-btn--full">Back to Jobs</a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        (function() {
            var sellerLat = @(sellerLat?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
            var sellerLng = @(sellerLng?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
            var buyerLat = @(buyerLat?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
            var buyerLng = @(buyerLng?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
            var riderLat = @(riderLat?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
            var riderLng = @(riderLng?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
            var status = '@Model?.Status';
        
            var map = L.map('deliveryMap', { zoomControl: false }).setView([14.5995, 120.9842], 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OSM'
            }).addTo(map);
            
            L.control.zoom({ position: 'bottomright' }).addTo(map);
        
            var markers = [];
            var bounds = L.latLngBounds();
        
            if (sellerLat && sellerLng) {
                var m = L.marker([sellerLat, sellerLng]).bindPopup('📦 Pickup: Seller').addTo(map);
                markers.push(m);
                bounds.extend([sellerLat, sellerLng]);
            }
            if (buyerLat && buyerLng) {
                var m = L.marker([buyerLat, buyerLng]).bindPopup('🏠 Dropoff: Buyer').addTo(map);
                markers.push(m);
                bounds.extend([buyerLat, buyerLng]);
            }
            if (riderLat && riderLng) {
                var m = L.marker([riderLat, riderLng], {
                    icon: L.divIcon({
                        className: '',
                        html: '<div style="background:#2d1b69;color:white;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;white-space:nowrap;">🚴 You</div>',
                        iconSize: [60, 28]
                    })
                }).bindPopup('📍 Your Location').addTo(map);
                markers.push(m);
                bounds.extend([riderLat, riderLng]);
            }
        
            if (bounds.isValid()) {
                map.fitBounds(bounds, { padding: [30, 30] });
            }
        
            function calcDist(lat1, lon1, lat2, lon2) {
                if (!lat1 || !lon1 || !lat2 || !lon2) return null;
                var R = 6371, dLat = (lat2-lat1)*Math.PI/180, dLon = (lon2-lon1)*Math.PI/180;
                var a = Math.sin(dLat/2)*Math.sin(dLat/2) + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)*Math.sin(dLon/2);
                return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            }
        
            function fmtDist(km) {
                if (km === null) return '--';
                return km < 1 ? (km*1000).toFixed(0)+' m' : km.toFixed(1)+' km';
            }
        
            var straightSellerToBuyer = calcDist(sellerLat, sellerLng, buyerLat, buyerLng);
            var straightRiderToSeller = calcDist(riderLat, riderLng, sellerLat, sellerLng);
            var straightRiderToBuyer = calcDist(riderLat, riderLng, buyerLat, buyerLng);
        
            var currentLegDistance = document.getElementById('currentLegDistance');
            var currentLegNote = document.getElementById('currentLegNote');
            var currentLegLabel = document.getElementById('currentLegLabel');
            var totalRouteDistance = document.getElementById('totalRouteDistance');
            var totalRouteNote = document.getElementById('totalRouteNote');
        
            function updateDisplay(currentDist, currentIsRoad, totalDist, totalIsRoad) {
                if (currentDist !== null) {
                    currentLegDistance.textContent = fmtDist(currentDist);
                    currentLegNote.textContent = currentIsRoad ? '🚗 Driving distance' : '📏 Straight-line';
                } else {
                    currentLegDistance.textContent = '--';
                    currentLegNote.textContent = '';
                }
                if (totalDist !== null) {
                    totalRouteDistance.textContent = fmtDist(totalDist);
                    totalRouteNote.textContent = totalIsRoad ? '🚗 Driving distance' : '📏 Straight-line';
                } else {
                    totalRouteDistance.textContent = '--';
                    totalRouteNote.textContent = '';
                }
            }
        
            if (status === 'Accepted') {
                currentLegLabel.textContent = 'To Pickup (Seller)';
                updateDisplay(straightRiderToSeller, false, straightSellerToBuyer, false);
            } else if (status === 'PickedUp') {
                currentLegLabel.textContent = 'To Dropoff (Buyer)';
                updateDisplay(straightRiderToBuyer, false, straightSellerToBuyer, false);
            } else {
                currentLegLabel.textContent = 'Current Leg';
                updateDisplay(null, false, straightSellerToBuyer, false);
            }
        
            var straightLayer = null;
            if (sellerLat && sellerLng && buyerLat && buyerLng) {
                straightLayer = L.polyline([[sellerLat, sellerLng], [buyerLat, buyerLng]], {
                    color: '#a39e98', weight: 2, dashArray: '5, 5', opacity: 0.6
                }).addTo(map).bindPopup('Straight-line');
            }
            
            // OSRM Road Routes
            var routeLayer = null, riderLayer = null;
            
            async function fetchRoute(sl, sn, el, en) {
                if (!sl || !sn || !el || !en) return null;
                try {
                    var r = await fetch('https://router.project-osrm.org/route/v1/driving/'+sn+','+sl+';'+en+','+el+'?overview=full&geometries=geojson');
                    if (!r.ok) return null;
                    var d = await r.json();
                    return d.routes && d.routes[0] ? d.routes[0] : null;
                } catch(e) { return null; }
            }
            
            function drawRoute(data, color, weight, dash, text) {
                if (!data || !data.geometry) return null;
                var coords = data.geometry.coordinates.map(function(c) { return [c[1], c[0]]; });
                return L.polyline(coords, { color: color, weight: weight, opacity: 0.8, dashArray: dash })
                    .bindPopup(text + ': ' + fmtDist(data.distance/1000));
            }
            
            async function loadRoadRoutes() {
                var roadSellerBuyer = null, roadRiderSeller = null, roadRiderBuyer = null;
                
                if (sellerLat && sellerLng && buyerLat && buyerLng) {
                    var r = await fetchRoute(sellerLat, sellerLng, buyerLat, buyerLng);
                    if (r) roadSellerBuyer = { distance: r.distance/1000, geometry: r.geometry };
                }
                if (riderLat && riderLng && sellerLat && sellerLng) {
                    var r = await fetchRoute(riderLat, riderLng, sellerLat, sellerLng);
                    if (r) roadRiderSeller = { distance: r.distance/1000, geometry: r.geometry };
                }
                if (riderLat && riderLng && buyerLat && buyerLng) {
                    var r = await fetchRoute(riderLat, riderLng, buyerLat, buyerLng);
                    if (r) roadRiderBuyer = { distance: r.distance/1000, geometry: r.geometry };
                }
                
                if (routeLayer) map.removeLayer(routeLayer);
                if (riderLayer) map.removeLayer(riderLayer);
                
                if (roadSellerBuyer) {
                    routeLayer = drawRoute(roadSellerBuyer, '#2d1b69', 4, null, '🚗 Delivery route');
                    if (routeLayer) routeLayer.addTo(map);
                }
                
                var currentRoadDist = null;
                if (status === 'Accepted' && roadRiderSeller) {
                    riderLayer = drawRoute(roadRiderSeller, '#b45309', 3, '8, 6', '📍 Route to pickup');
                    currentRoadDist = roadRiderSeller.distance;
                } else if (status === 'PickedUp' && roadRiderBuyer) {
                    riderLayer = drawRoute(roadRiderBuyer, '#b45309', 3, '8, 6', '📍 Route to dropoff');
                    currentRoadDist = roadRiderBuyer.distance;
                }
                if (riderLayer) riderLayer.addTo(map);
                
                updateDisplay(
                    currentRoadDist,
                    !!riderLayer,
                    roadSellerBuyer ? roadSellerBuyer.distance : straightSellerToBuyer,
                    !!roadSellerBuyer
                );
            }
            
            // Auto-load road routes
            if (sellerLat && sellerLng && buyerLat && buyerLng) {
                loadRoadRoutes();
                if (straightLayer) map.removeLayer(straightLayer);
            }
        })();
    </script>
}