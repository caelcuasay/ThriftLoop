@model ThriftLoop.DTOs.Auth.RiderEditDTO
@{
    ViewData["Title"] = "Edit Application";
    Layout = "~/Areas/Mobile/Views/Shared/_MobileLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/mobile-rider.css" asp-append-version="true" />
}

<div class="mobile-rider-screen">
    <!-- Header -->
    <div class="mobile-rider-header">
        <div>
            <h1 class="mobile-rider-header__title">Edit Application</h1>
            <p class="mobile-rider-header__subtitle">Resubmit for review</p>
        </div>
    </div>

    <a asp-action="RiderApproval" asp-controller="Auth" class="mobile-rider-back">
        <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" /></svg>
        Back to status
    </a>

    @if (!string.IsNullOrEmpty(ViewBag.RejectionReason as string))
    {
        <div class="mobile-rider-rejection">
            <div class="mobile-rider-rejection__icon">⚠️</div>
            <div class="mobile-rider-rejection__text">
                <strong>Reason for rejection:</strong>
                <p>@ViewBag.RejectionReason</p>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="mobile-rider-toast mobile-rider-toast--error">
            <svg class="mobile-rider-toast__icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
            <span>@errMsg</span>
        </div>
    }

    <form asp-action="EditApplication" asp-controller="Rider"
          method="post" enctype="multipart/form-data" novalidate class="mobile-rider-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ExistingLicenseUrl" />

        <!-- Personal Information -->
        <div class="mobile-rider-form__section">
            <h2 class="mobile-rider-form__title">
                <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path d="M10 8a3 3 0 100-6 3 3 0 000 6zM3.465 14.493a1.23 1.23 0 00.41 1.412A9.957 9.957 0 0010 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 00-13.074.003z" /></svg>
                Personal Information
            </h2>

            <div class="mobile-rider-field">
                <label asp-for="FullName" class="mobile-rider-field__label">Full Name</label>
                <input asp-for="FullName" class="mobile-rider-field__input" type="text" autocomplete="name" placeholder="Enter your full name" />
                <span asp-validation-for="FullName" class="mobile-rider-field__error"></span>
            </div>

            <div class="mobile-rider-field">
                <label asp-for="PhoneNumber" class="mobile-rider-field__label">Phone Number</label>
                <input asp-for="PhoneNumber" class="mobile-rider-field__input" type="tel" autocomplete="tel" placeholder="09123456789" />
                <span asp-validation-for="PhoneNumber" class="mobile-rider-field__error"></span>
            </div>

            <div class="mobile-rider-field">
                <label asp-for="Email" class="mobile-rider-field__label">Email Address</label>
                <input asp-for="Email" class="mobile-rider-field__input" type="email" autocomplete="email" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="mobile-rider-field__error"></span>
            </div>

            <div class="mobile-rider-field">
                <label asp-for="Address" class="mobile-rider-field__label">Address</label>
                <textarea asp-for="Address" class="mobile-rider-field__textarea" rows="3" placeholder="Enter your complete address"></textarea>
                <span asp-validation-for="Address" class="mobile-rider-field__error"></span>
            </div>
        </div>

        <!-- Vehicle & License Details -->
        <div class="mobile-rider-form__section">
            <h2 class="mobile-rider-form__title">
                <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path d="M6.5 3A1.5 1.5 0 005 4.5v.75a.75.75 0 01-.75.75H3a1 1 0 00-1 1v7a1 1 0 001 1h14a1 1 0 001-1V7a1 1 0 00-1-1h-1.25a.75.75 0 01-.75-.75V4.5A1.5 1.5 0 0013.5 3h-7zM10 13a2 2 0 100-4 2 2 0 000 4z" /></svg>
                Vehicle & License Details
            </h2>

            <!-- Current License Preview -->
            @if (!string.IsNullOrEmpty(Model.ExistingLicenseUrl))
            {
                <div style="margin-bottom: 20px;">
                    <img src="@Model.ExistingLicenseUrl" alt="Current license" style="max-width: 100%; border-radius: 12px; border: 1px solid var(--r-border);" />
                    <p class="mobile-rider-field__hint">Current license photo — upload new to replace</p>
                </div>
            }

            <!-- License Upload -->
            <div class="mobile-rider-field">
                <label asp-for="DriversLicense" class="mobile-rider-field__label">Driver's License</label>
                <div class="mobile-rider-upload" id="licenseUpload">
                    <input asp-for="DriversLicense"
                           type="file"
                           class="mobile-rider-upload__input"
                           accept="image/jpeg,image/png,image/webp"
                           onchange="previewLicense(this)" />
                    <div class="mobile-rider-upload__icon" id="licenseUploadBody">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="24" height="24">
                            <path fill-rule="evenodd" d="M1 5.25A2.25 2.25 0 013.25 3h13.5A2.25 2.25 0 0119 5.25v9.5A2.25 2.25 0 0116.75 17H3.25A2.25 2.25 0 011 14.75v-9.5zm1.5 5.81v3.69c0 .414.336.75.75.75h13.5a.75.75 0 00.75-.75v-2.69l-2.22-2.219a.75.75 0 00-1.06 0l-1.91 1.909-1.47-1.47a.75.75 0 00-1.06 0L2.5 11.06zm9.5-6.56a1 1 0 100 2 1 1 0 000-2z" clip-rule="evenodd" />
                        </svg>
                        <div class="mobile-rider-upload__text">
                            <strong>Click to upload new license</strong>
                            <small>JPG, PNG or WEBP — max 5 MB (optional)</small>
                        </div>
                    </div>
                    <img id="licensePreview" class="mobile-rider-upload__preview" src="#" alt="New license preview" />
                </div>
                <span asp-validation-for="DriversLicense" class="mobile-rider-field__error"></span>
            </div>

            <!-- Vehicle Type -->
            <div class="mobile-rider-field">
                <label asp-for="VehicleType" class="mobile-rider-field__label">Vehicle Type</label>
                <select asp-for="VehicleType" class="mobile-rider-field__select">
                    <option value="" disabled>Select vehicle type...</option>
                    <option value="Motorcycle">Motorcycle</option>
                    <option value="E-Bike">E-Bike</option>
                    <option value="E-Scooter">E-Scooter</option>
                    <option value="Bicycle">Bicycle</option>
                    <option value="Car">Car</option>
                    <option value="Van">Van</option>
                </select>
                <span asp-validation-for="VehicleType" class="mobile-rider-field__error"></span>
            </div>

            <!-- Vehicle Color -->
            <div class="mobile-rider-field">
                <label asp-for="VehicleColor" class="mobile-rider-field__label">Vehicle Color</label>
                <input asp-for="VehicleColor" class="mobile-rider-field__input" type="text" placeholder="e.g. Red, Black, White" />
                <span asp-validation-for="VehicleColor" class="mobile-rider-field__error"></span>
            </div>

            <!-- License Plate -->
            <div class="mobile-rider-field">
                <label asp-for="LicensePlate" class="mobile-rider-field__label">License Plate Number</label>
                <input asp-for="LicensePlate" class="mobile-rider-field__input" type="text" placeholder="ABC-1234" style="text-transform:uppercase;" />
                <span asp-validation-for="LicensePlate" class="mobile-rider-field__error"></span>
            </div>
        </div>

        <!-- Change Password (Optional) -->
        <div class="mobile-rider-form__section">
            <h2 class="mobile-rider-form__title">
                <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" /></svg>
                Change Password (Optional)
            </h2>

            <div class="mobile-rider-field">
                <label asp-for="NewPassword" class="mobile-rider-field__label">New Password</label>
                <input asp-for="NewPassword" id="passwordInput" class="mobile-rider-field__input" type="password" autocomplete="new-password" placeholder="Leave blank to keep current" />
                <span asp-validation-for="NewPassword" class="mobile-rider-field__error"></span>
            </div>

            <div class="mobile-rider-field">
                <label asp-for="ConfirmNewPassword" class="mobile-rider-field__label">Confirm New Password</label>
                <input asp-for="ConfirmNewPassword" id="confirmPasswordInput" class="mobile-rider-field__input" type="password" autocomplete="new-password" placeholder="Confirm your new password" />
                <span asp-validation-for="ConfirmNewPassword" class="mobile-rider-field__error"></span>
            </div>
        </div>

        <!-- Actions -->
        <div style="padding: 0 20px 24px;">
            <button type="submit" class="mobile-rider-btn mobile-rider-btn--primary mobile-rider-btn--full">
                <svg class="mobile-rider-btn__icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                Resubmit Application
            </button>
            <a asp-action="RiderApproval" asp-controller="Auth" class="mobile-rider-btn mobile-rider-btn--outline mobile-rider-btn--full" style="margin-top: 12px;">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePassword(inputId) {
        var input = document.getElementById(inputId);
        input.type = input.type === 'password' ? 'text' : 'password';
        }

        function previewLicense(input) {
        var preview = document.getElementById('licensePreview');
        var body = document.getElementById('licenseUploadBody');
        if (input.files && input.files[0]) {
        if (input.files[0].size > 5 * 1024 * 1024) {
        alert('File exceeds 5 MB. Please choose a smaller image.');
        input.value = '';
        return;
        }
        var reader = new FileReader();
        reader.onload = function(e) {
        preview.src = e.target.result;
        preview.style.display = 'block';
        body.style.display = 'none';
        };
        reader.readAsDataURL(input.files[0]);
        } else {
        preview.style.display = 'none';
        body.style.display = 'flex';
        }
        }

        // Auto uppercase license plate
        document.querySelector('[name="LicensePlate"]')
        ?.addEventListener('blur', function() { this.value = this.value.toUpperCase(); });
    </script>
}