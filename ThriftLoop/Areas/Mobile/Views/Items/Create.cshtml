@using ThriftLoop.ViewModels
@model ItemCreateViewModel
@{
    ViewData["Title"] = "Create Listing";
}

<div class="mobile-create-screen">
    @* ── Header ──────────────────────────────────────────────────────────── *@
    <div class="mobile-create-header">
        <h1 class="mobile-create-header__title">New Listing</h1>
        <p class="mobile-create-header__sub">Fill in each field to unlock the next</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" id="createItemForm">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mobile-toast mobile-toast--error" role="alert">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                </svg>
                <span>Please fix the errors below before publishing.</span>
            </div>
        }

        @* ── Photos Section ───────────────────────────────────────────────── *@
        <div class="mobile-create-section">
            <div class="mobile-create-section__header">
                <h2 class="mobile-create-section__title">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                        <rect x="2.5" y="4.5" width="15" height="11" rx="1.5" />
                        <circle cx="7" cy="8.5" r="1.5" />
                        <path d="M2.5 13.5L7 9L10.5 12.5L13.5 10L17.5 14" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Photos
                </h2>
                <span class="mobile-create-section__counter" id="photoCounter">0 / 5</span>
            </div>

            <div class="mobile-photo-upload" id="photoUploadArea" tabindex="0">
                <input type="file"
                       name="Images"
                       id="photoInput"
                       multiple
                       accept="image/jpeg,image/png,image/webp"
                       class="mobile-photo-upload__input" />

                <div class="mobile-photo-upload__empty" id="photoEmpty">
                    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" width="40" height="40">
                        <rect x="4" y="8" width="40" height="32" rx="4" />
                        <circle cx="17" cy="20" r="4" />
                        <path d="M4 36l12-10 8 8 6-5 14 11" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span class="mobile-photo-upload__headline">Add photos</span>
                    <span class="mobile-photo-upload__sub">Tap to browse or drag & drop</span>
                    <span class="mobile-photo-upload__limit">JPEG · PNG · WebP · Max 5 MB each</span>
                </div>

                <div class="mobile-photo-upload__preview" id="photoPreview" style="display:none">
                    <img id="photoMainImg" alt="Cover photo" />
                    <span class="mobile-photo-upload__cover-badge">Cover</span>
                </div>
            </div>

            <div class="mobile-photo-strip" id="photoStrip"></div>
            <span asp-validation-for="Images" class="mobile-field-error"></span>
        </div>

        @* ── Title ────────────────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionTitle">
            <div class="mobile-create-section__header">
                <h2 class="mobile-create-section__title">Title</h2>
                <span class="mobile-create-section__counter" id="titleCounter">0/100</span>
            </div>
            <input asp-for="Title"
                   class="mobile-create-input"
                   id="titleInput"
                   placeholder="e.g., Vintage Levi's 501 Jeans"
                   maxlength="100"
                   autocomplete="off" />
            <span asp-validation-for="Title" class="mobile-field-error"></span>
        </div>

        @* ── Price ────────────────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionPrice">
            <h2 class="mobile-create-section__title">Price</h2>
            <div class="mobile-price-wrap">
                <span class="mobile-price-symbol">₱</span>
                <input asp-for="Price"
                       class="mobile-create-input mobile-create-input--price"
                       id="priceInput"
                       type="number"
                       step="0.01"
                       min="0.01"
                       max="99999.99"
                       placeholder="0.00"
                       value="" />
            </div>
            <span asp-validation-for="Price" class="mobile-field-error"></span>
        </div>

        @* ── Category ─────────────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionCategory">
            <h2 class="mobile-create-section__title">Category</h2>
            <input type="hidden" asp-for="Category" id="categoryHidden" />
            <div class="mobile-chip-grid" id="categoryChips">
                @foreach (var cat in ItemCreateViewModel.Categories)
                {
                    <button type="button" class="mobile-chip" data-value="@cat">@cat</button>
                }
            </div>
            <span asp-validation-for="Category" class="mobile-field-error"></span>
        </div>

        @* ── Condition ────────────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionCondition">
            <h2 class="mobile-create-section__title">Condition</h2>
            <input type="hidden" asp-for="Condition" id="conditionHidden" />
            <div class="mobile-chip-grid" id="conditionChips">
                @foreach (var cond in ItemCreateViewModel.Conditions)
                {
                    <button type="button" class="mobile-chip" data-value="@cond">@cond</button>
                }
            </div>
            <span asp-validation-for="Condition" class="mobile-field-error"></span>
        </div>

        @* ── Size (Optional) ──────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionSize">
            <h2 class="mobile-create-section__title">Size <span class="mobile-create-optional">(Optional)</span></h2>
            <div class="mobile-select-wrap">
                <select asp-for="Size" class="mobile-create-select" id="sizeSelect">
                    <option value="">Select size</option>
                    @foreach (var size in ItemCreateViewModel.Sizes)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
                <svg class="mobile-select-chevron" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
                </svg>
            </div>
        </div>

        @* ── Description ──────────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionDescription">
            <div class="mobile-create-section__header">
                <h2 class="mobile-create-section__title">Description</h2>
                <span class="mobile-create-section__counter" id="descCounter">0/1000</span>
            </div>
            <textarea asp-for="Description"
                      class="mobile-create-textarea"
                      id="descInput"
                      rows="4"
                      placeholder="Describe your item — condition, brand, measurements, any flaws..."
                      maxlength="1000"></textarea>
            <span asp-validation-for="Description" class="mobile-field-error"></span>
        </div>

        @* ── Delivery Options ─────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionDelivery">
            <h2 class="mobile-create-section__title">Delivery Options</h2>
            <p class="mobile-create-hint">Choose at least one</p>

            <label class="mobile-delivery-option">
                <input type="checkbox" name="AllowDelivery" value="true" checked class="mobile-delivery-checkbox" />
                <span class="mobile-delivery-option__icon">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                        <rect x="2.5" y="9.5" width="15" height="7" rx="1" />
                        <circle cx="6" cy="16.5" r="1.5" />
                        <circle cx="14" cy="16.5" r="1.5" />
                    </svg>
                </span>
                <div class="mobile-delivery-option__info">
                    <span class="mobile-delivery-option__title">Delivery</span>
                    <span class="mobile-delivery-option__desc">Ship directly to buyer</span>
                </div>
                <span class="mobile-delivery-option__check"></span>
            </label>

            <label class="mobile-delivery-option">
                <input type="checkbox" name="AllowHalfway" value="true" class="mobile-delivery-checkbox" />
                <span class="mobile-delivery-option__icon">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                        <circle cx="10" cy="10" r="7.5" />
                        <path d="M10 5v5l3 3" stroke-linecap="round" />
                    </svg>
                </span>
                <div class="mobile-delivery-option__info">
                    <span class="mobile-delivery-option__title">Halfway Meetup</span>
                    <span class="mobile-delivery-option__desc">Meet at agreed location</span>
                </div>
                <span class="mobile-delivery-option__check"></span>
            </label>

            <label class="mobile-delivery-option">
                <input type="checkbox" name="AllowPickup" value="true" class="mobile-delivery-checkbox" />
                <span class="mobile-delivery-option__icon">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                        <path d="M3 9.5L10 3.5L17 9.5V16.5H3V9.5Z" stroke-linecap="round" stroke-linejoin="round" />
                        <rect x="8" y="11" width="4" height="5.5" />
                    </svg>
                </span>
                <div class="mobile-delivery-option__info">
                    <span class="mobile-delivery-option__title">Pickup</span>
                    <span class="mobile-delivery-option__desc">Buyer comes to you</span>
                </div>
                <span class="mobile-delivery-option__check"></span>
            </label>
            <span class="mobile-field-error" id="deliveryError"></span>
        </div>

        @* ── Stealable ────────────────────────────────────────────────────── *@
        <div class="mobile-create-section" id="sectionStealable">
            <h2 class="mobile-create-section__title">Listing Type</h2>

            <label class="mobile-stealable-toggle">
                <div class="mobile-stealable-toggle__info">
                    <span class="mobile-stealable-toggle__title">Make it Stealable</span>
                    <span class="mobile-stealable-toggle__desc">Buyers can claim and compete for this item</span>
                </div>
                <div class="mobile-toggle-switch">
                    <input type="checkbox" name="IsStealable" value="true" id="stealableToggle" />
                    <span class="mobile-toggle-switch__track"></span>
                </div>
            </label>

            <div class="mobile-steal-duration" id="stealDurationPanel">
                <label class="mobile-create-label" for="stealDurationSelect">Steal window duration</label>
                <div class="mobile-select-wrap">
                    <select name="StealDurationHours" class="mobile-create-select" id="stealDurationSelect">
                        <option value="">Select duration</option>
                        @foreach (var dur in ItemCreateViewModel.StealDurations)
                        {
                            <option value="@dur">@dur hours</option>
                        }
                    </select>
                    <svg class="mobile-select-chevron" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                        <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
                    </svg>
                </div>
            </div>
        </div>

        @* ── Submit ───────────────────────────────────────────────────────── *@
        <div class="mobile-create-submit">
            <a asp-action="Index" class="mobile-btn mobile-btn--ghost">Cancel</a>
            <button type="submit" class="mobile-btn mobile-btn--primary" id="submitBtn">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path d="M3.5 2.75a.75.75 0 00-1.5 0v14.5a.75.75 0 001.5 0v-4.392l1.657-.348a6.449 6.449 0 014.271.572 8.973 8.973 0 003.965.972 6.7 6.7 0 002.341-.428 2.25 2.25 0 001.266-2.117V3.75a.75.75 0 00-1.125-.649 5.2 5.2 0 01-2.482.66c-1.788 0-3.318-.506-4.507-1.2a6.407 6.407 0 00-3.686-.956L3.5 2.75z" />
                </svg>
                Publish Listing
            </button>
        </div>
    </form>
</div>

<script>
    (function() {
        'use strict';

        // =========================================================
        // PHOTO UPLOAD (FIXED)
        // =========================================================

        var photoUploadArea = document.getElementById('photoUploadArea');
        var photoInput = document.getElementById('photoInput');
        var photoEmpty = document.getElementById('photoEmpty');
        var photoPreview = document.getElementById('photoPreview');
        var photoMainImg = document.getElementById('photoMainImg');
        var photoStrip = document.getElementById('photoStrip');
        var photoCounter = document.getElementById('photoCounter');

        var selectedFiles = [];
        var objectUrls = [];

        function revokeAll() {
            objectUrls.forEach(function(url) { URL.revokeObjectURL(url); });
            objectUrls = [];
        }

        function createUrl(file) {
            var url = URL.createObjectURL(file);
            objectUrls.push(url);
            return url;
        }

        function replaceFileInput() {
            var oldInput = photoInput;
            var newInput = document.createElement('input');
            newInput.type = 'file';
            newInput.id = 'photoInput';
            newInput.name = 'Images';
            newInput.multiple = true;
            newInput.accept = 'image/jpeg,image/png,image/webp';
            newInput.className = 'mobile-photo-upload__input';

            var dt = new DataTransfer();
            selectedFiles.forEach(function(f) { dt.items.add(f); });
            newInput.files = dt.files;

            newInput.addEventListener('change', function() {
                if (this.files.length) addFiles(this.files);
                this.value = '';
            });

            if (oldInput && oldInput.parentNode) {
                oldInput.parentNode.replaceChild(newInput, oldInput);
            }
            photoInput = newInput;
        }

        function renderPreviews() {
            revokeAll();

            if (selectedFiles.length > 0) {
                photoMainImg.src = createUrl(selectedFiles[0]);
                photoPreview.style.display = 'block';
                photoEmpty.style.display = 'none';
                photoUploadArea.classList.add('has-photo');
            } else {
                photoPreview.style.display = 'none';
                photoEmpty.style.display = '';
                photoUploadArea.classList.remove('has-photo');
                photoMainImg.src = '';
            }

            photoStrip.innerHTML = '';

            selectedFiles.forEach(function(file, index) {
                var thumb = document.createElement('div');
                thumb.className = 'mobile-photo-strip__thumb' + (index === 0 ? ' mobile-photo-strip__thumb--cover' : '');

                var img = document.createElement('img');
                img.src = createUrl(file);
                img.alt = 'Photo ' + (index + 1);

                var removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'mobile-photo-strip__remove';
                removeBtn.setAttribute('aria-label', 'Remove photo ' + (index + 1));
                removeBtn.textContent = '\u00D7';

                // FIXED: IIFE captures the correct index for each button
                (function(idx) {
                    removeBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        selectedFiles.splice(idx, 1);
                        renderPreviews();
                        replaceFileInput();
                    });
                })(index);

                thumb.appendChild(img);
                thumb.appendChild(removeBtn);
                photoStrip.appendChild(thumb);
            });

            if (selectedFiles.length < 5) {
                var addSlot = document.createElement('div');
                addSlot.className = 'mobile-photo-strip__add';
                addSlot.textContent = '+';
                addSlot.addEventListener('click', function(e) {
                    e.stopPropagation();
                    photoInput.click();
                });
                photoStrip.appendChild(addSlot);
            }

            replaceFileInput();
            photoCounter.textContent = selectedFiles.length + ' / 5';
        }

        function addFiles(files) {
            var remaining = 5 - selectedFiles.length;
            var toAdd = Array.from(files).slice(0, remaining);

            toAdd.forEach(function(file) {
                if (!file.type.match(/^image\/(jpeg|png|webp)$/)) {
                    showToast(file.name + ' is not a supported format.', 'error');
                    return;
                }
                if (file.size > 5 * 1024 * 1024) {
                    showToast(file.name + ' exceeds 5 MB.', 'error');
                    return;
                }
                selectedFiles.push(file);
            });

            renderPreviews();
        }

        photoUploadArea.addEventListener('click', function() { photoInput.click(); });
        photoUploadArea.addEventListener('dragover', function(e) { e.preventDefault(); photoUploadArea.classList.add('is-dragging'); });
        photoUploadArea.addEventListener('dragleave', function() { photoUploadArea.classList.remove('is-dragging'); });
        photoUploadArea.addEventListener('drop', function(e) {
            e.preventDefault();
            photoUploadArea.classList.remove('is-dragging');
            if (e.dataTransfer.files.length) addFiles(e.dataTransfer.files);
        });

        photoInput.addEventListener('change', function() {
            if (this.files.length) addFiles(this.files);
            this.value = '';
        });

        renderPreviews();

        // =========================================================
        // CHARACTER COUNTERS
        // =========================================================

        function bindCounter(inputId, counterId, max) {
            var input = document.getElementById(inputId);
            var counter = document.getElementById(counterId);
            if (!input || !counter) return;
            input.addEventListener('input', function() {
                var len = input.value.length;
                counter.textContent = len + '/' + max;
                if (len > max * 0.9) counter.classList.add('mobile-create-section__counter--warn');
                else counter.classList.remove('mobile-create-section__counter--warn');
            });
        }

        bindCounter('titleInput', 'titleCounter', 100);
        bindCounter('descInput', 'descCounter', 1000);

        // =========================================================
        // CATEGORY CHIPS
        // =========================================================

        var categoryChips = document.getElementById('categoryChips');
        var categoryHidden = document.getElementById('categoryHidden');

        if (categoryChips && categoryHidden) {
            categoryChips.querySelectorAll('.mobile-chip').forEach(function(chip) {
                chip.addEventListener('click', function() {
                    categoryChips.querySelectorAll('.mobile-chip').forEach(function(c) { c.classList.remove('mobile-chip--active'); });
                    chip.classList.add('mobile-chip--active');
                    categoryHidden.value = chip.dataset.value;
                });
            });
        }

        // =========================================================
        // CONDITION CHIPS
        // =========================================================

        var conditionChips = document.getElementById('conditionChips');
        var conditionHidden = document.getElementById('conditionHidden');

        if (conditionChips && conditionHidden) {
            conditionChips.querySelectorAll('.mobile-chip').forEach(function(chip) {
                chip.addEventListener('click', function() {
                    conditionChips.querySelectorAll('.mobile-chip').forEach(function(c) { c.classList.remove('mobile-chip--active'); });
                    chip.classList.add('mobile-chip--active');
                    conditionHidden.value = chip.dataset.value;
                });
            });
        }

        // =========================================================
        // DELIVERY CHECKBOXES
        // =========================================================

        document.querySelectorAll('.mobile-delivery-checkbox').forEach(function(cb) {
            cb.addEventListener('change', function() {
                var option = this.closest('.mobile-delivery-option');
                if (this.checked) option.classList.add('mobile-delivery-option--checked');
                else option.classList.remove('mobile-delivery-option--checked');
            });
        });

        // =========================================================
        // STEALABLE TOGGLE
        // =========================================================

        var stealableToggle = document.getElementById('stealableToggle');
        var stealDurationPanel = document.getElementById('stealDurationPanel');

        if (stealableToggle && stealDurationPanel) {
            stealableToggle.addEventListener('change', function() {
                if (this.checked) stealDurationPanel.classList.add('is-visible');
                else {
                    stealDurationPanel.classList.remove('is-visible');
                    document.getElementById('stealDurationSelect').value = '';
                }
            });
        }

        // =========================================================
        // FORM SUBMIT
        // =========================================================

        var form = document.getElementById('createItemForm');
        var submitBtn = document.getElementById('submitBtn');

        if (form) {
            form.addEventListener('submit', function(e) {
                var hasError = false;
                var title = document.getElementById('titleInput').value.trim();
                var price = document.getElementById('priceInput').value;
                var category = document.getElementById('categoryHidden').value;
                var condition = document.getElementById('conditionHidden').value;
                var description = document.getElementById('descInput').value.trim();
                var delivery = document.querySelector('[name="AllowDelivery"]').checked;
                var halfway = document.querySelector('[name="AllowHalfway"]').checked;
                var pickup = document.querySelector('[name="AllowPickup"]').checked;

                if (!title) { showToast('Please enter a title.', 'error'); hasError = true; }
                else if (!price || parseFloat(price) <= 0) { showToast('Please enter a valid price.', 'error'); hasError = true; }
                else if (!category) { showToast('Please select a category.', 'error'); hasError = true; }
                else if (!condition) { showToast('Please select the condition.', 'error'); hasError = true; }
                else if (!description) { showToast('Please enter a description.', 'error'); hasError = true; }
                else if (!delivery && !halfway && !pickup) { showToast('Please select at least one delivery option.', 'error'); hasError = true; }

                if (hasError) {
                    e.preventDefault();
                    return false;
                }

                if (stealableToggle && stealableToggle.checked && !document.getElementById('stealDurationSelect').value) {
                    e.preventDefault();
                    showToast('Please select a steal window duration.', 'error');
                    return false;
                }

                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Publishing...';
                }
            });
        }

        function showToast(message, type) {
            type = type || 'info';
            var toast = document.createElement('div');
            toast.className = 'app-toast app-toast--' + type;
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(function() { toast.remove(); }, 3200);
        }
    })();
</script>