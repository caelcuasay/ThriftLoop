@model ThriftLoop.Models.Item
@using ThriftLoop.Models
@using ThriftLoop.Enums
@{
    ViewData["Title"] = Model.Title;

    bool isOwner = (bool)(ViewBag.IsOwner ?? false);
    bool isAnonymous = (bool)(ViewBag.IsAnonymous ?? true);
    bool isCurrentWinner = (bool)(ViewBag.IsCurrentWinner ?? false);
    bool isOriginalGetter = (bool)(ViewBag.IsOriginalGetter ?? false);

    bool isStealable = Model.ListingType == ListingType.Stealable;
    bool stealWindowOpen = isStealable
                           && Model.Status == ItemStatus.Reserved
                           && Model.StealEndsAt.HasValue
                           && DateTime.UtcNow <= Model.StealEndsAt.Value;

    string sellerDisplay = Model.User is not null
        ? Model.User.Email.Split('@')[0]
        : "Unknown seller";

    string priceLabel = isStealable ? "Starting price" : "Fixed price";
    if (isStealable && Model.Status == ItemStatus.Reserved)
        priceLabel = "Current price";
    if (isStealable && Model.Status == ItemStatus.StolenPendingCheckout)
        priceLabel = "Stolen price";

    bool hasImages = Model.ImageUrls.Count > 0;

    // Default fulfillment method
    string defaultFulfillmentMethod = Model.AllowDelivery ? "Delivery"
        : Model.AllowHalfway ? "Halfway"
        : Model.AllowPickup ? "Pickup"
        : "Delivery";
}

<div class="mobile-detail-screen">
    @* ── Image Gallery ──────────────────────────────────────────────────── *@
    <div class="mobile-detail-gallery">
        @if (hasImages)
        {
            <div class="mobile-detail-gallery__main" id="galleryMain">
                <img src="@Model.ImageUrls[0]" alt="@Model.Title" class="mobile-detail-gallery__img" id="mainGalleryImg" />

                @if (Model.ImageUrls.Count > 1)
                {
                    <button type="button" class="mobile-gallery-arrow mobile-gallery-arrow--prev" id="galleryPrev" aria-label="Previous photo">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                            <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <button type="button" class="mobile-gallery-arrow mobile-gallery-arrow--next" id="galleryNext" aria-label="Next photo">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                            <path d="M7.5 5L12.5 10L7.5 15" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <span class="mobile-gallery-counter" id="galleryCounter">1 / @Model.ImageUrls.Count</span>
                }
            </div>

            @if (Model.ImageUrls.Count > 1)
            {
                <div class="mobile-detail-gallery__thumbs" id="galleryThumbs">
                    @for (int t = 0; t < Model.ImageUrls.Count; t++)
                    {
                        <button type="button"
                                class="mobile-gallery-thumb @(t == 0 ? "mobile-gallery-thumb--active" : "")"
                                data-index="@t"
                                data-src="@Model.ImageUrls[t]"
                                aria-label="Photo @(t + 1)">
                            <img src="@Model.ImageUrls[t]" alt="Thumbnail @(t + 1)" loading="lazy" />
                        </button>
                    }
                </div>
            }
        }
        else
        {
            <div class="mobile-detail-gallery__placeholder">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4" width="48" height="48">
                    <rect x="6" y="10" width="52" height="44" rx="6" />
                    <circle cx="22" cy="26" r="6" />
                    <path d="M6 46l16-14 10 10 8-7 18 15" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>No photo</span>
            </div>
        }

        @* Badges *@
        <div class="mobile-detail-badges">
            @if (isStealable)
            {
                <span class="mobile-detail-badge mobile-detail-badge--stealable">Stealable</span>
            }
            @if (Model.Status == ItemStatus.Reserved)
            {
                <span class="mobile-detail-badge mobile-detail-badge--reserved">Reserved</span>
            }
            @if (Model.Status == ItemStatus.Sold)
            {
                <span class="mobile-detail-badge mobile-detail-badge--sold">Sold</span>
            }
        </div>
    </div>

    @* ── Content ─────────────────────────────────────────────────────────── *@
    <div class="mobile-detail-content">
        @* Meta row *@
        <div class="mobile-detail-meta">
            <span class="mobile-detail-category">@Model.Category</span>
            <span class="mobile-detail-condition">@Model.Condition</span>
            @if (!string.IsNullOrEmpty(Model.Size))
            {
                <span class="mobile-detail-size">@Model.Size</span>
            }
        </div>

        @* Title *@
        <h1 class="mobile-detail-title">@Model.Title</h1>

        @* Price *@
        <div class="mobile-detail-price-block">
            <span class="mobile-detail-price">₱@Model.Price.ToString("N2")</span>
            <span class="mobile-detail-price-label">@priceLabel</span>
        </div>

        @* Fulfillment badges *@
        <div class="mobile-detail-fulfillment">
            @if (Model.AllowDelivery)
            {
                <span class="mobile-fulfillment-tag">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"><path d="M2.5 3A1.5 1.5 0 001 4.5v7A1.5 1.5 0 002.5 13h11a1.5 1.5 0 001.5-1.5v-7A1.5 1.5 0 0013.5 3h-11z" /><circle cx="4.5" cy="9.5" r="1.5" /><circle cx="11.5" cy="9.5" r="1.5" /></svg>
                    Delivery
                </span>
            }
            @if (Model.AllowHalfway)
            {
                <span class="mobile-fulfillment-tag">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"><path d="M8 1a5 5 0 00-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 00-5-5z" /><circle cx="8" cy="6" r="2" /></svg>
                    Halfway
                </span>
            }
            @if (Model.AllowPickup)
            {
                <span class="mobile-fulfillment-tag">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"><path d="M2 6l6-4.5L14 6v7.5a.5.5 0 01-.5.5h-11a.5.5 0 01-.5-.5V6z" /><path d="M6 14V9h4v5" /></svg>
                    Pickup
                </span>
            }
        </div>

        @* Timer for stealable items *@
        @if (isStealable && Model.Status == ItemStatus.Reserved && Model.StealEndsAt.HasValue)
        {
            if (stealWindowOpen)
            {
                <div class="mobile-timer-card mobile-timer-card--active">
                    <div class="mobile-timer-card__icon">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="mobile-timer-card__body">
                        <span class="mobile-timer-card__label">Steal window closes in</span>
                        <span class="mobile-timer-card__timer"
                              id="stealTimer"
                              data-ends-at="@(DateTime.SpecifyKind(Model.StealEndsAt.Value, DateTimeKind.Utc).ToString("O"))">
                            --:--:--
                        </span>
                    </div>
                </div>
            }
        }

        @* Sold notice *@
        @if (Model.Status == ItemStatus.Sold)
        {
            <div class="mobile-detail-notice mobile-detail-notice--sold">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
                This item has been sold.
            </div>
        }

        @* Description *@
        <div class="mobile-detail-section">
            <h2 class="mobile-detail-section__title">Description</h2>
            <p class="mobile-detail-description">@Model.Description</p>
        </div>

        @* Facts *@
        <div class="mobile-detail-section">
            <h2 class="mobile-detail-section__title">Details</h2>
            <div class="mobile-detail-facts">
                <div class="mobile-detail-fact">
                    <span class="mobile-detail-fact__label">Listed</span>
                    <span class="mobile-detail-fact__value">@Model.CreatedAt.ToString("MMM d, yyyy")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Size))
                {
                    <div class="mobile-detail-fact">
                        <span class="mobile-detail-fact__label">Size</span>
                        <span class="mobile-detail-fact__value">@Model.Size</span>
                    </div>
                }
                @if (isStealable)
                {
                    <div class="mobile-detail-fact">
                        <span class="mobile-detail-fact__label">Steal Window</span>
                        <span class="mobile-detail-fact__value">@Model.StealDurationHours hr</span>
                    </div>
                }
                <div class="mobile-detail-fact">
                    <span class="mobile-detail-fact__label">Item ID</span>
                    <span class="mobile-detail-fact__value">#@Model.Id</span>
                </div>
            </div>
        </div>

        @* Seller info *@
        <div class="mobile-detail-section">
            <h2 class="mobile-detail-section__title">Seller</h2>
            <div class="mobile-seller-card">
                <div class="mobile-seller-card__avatar">@sellerDisplay.Substring(0, 1).ToUpper()</div>
                <div class="mobile-seller-card__info">
                    <span class="mobile-seller-card__name">@sellerDisplay</span>
                    <span class="mobile-seller-card__since">Member since @(Model.User?.CreatedAt.ToString("MMMM yyyy") ?? "—")</span>
                </div>
            </div>
        </div>

        @* Owner actions *@
        @if (isOwner)
        {
            <div class="mobile-detail-actions">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="mobile-btn mobile-btn--outline">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                        <path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z" />
                    </svg>
                    Edit Listing
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="mobile-btn mobile-btn--danger-outline">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                        <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5z" clip-rule="evenodd" />
                    </svg>
                    Delete Listing
                </a>
            </div>
        }
        @* Anonymous user *@
        else if (isAnonymous)
        {
            <div class="mobile-detail-actions">
                <a asp-action="Login" asp-controller="Auth" asp-area="Mobile"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="mobile-btn mobile-btn--primary">
                    Sign in to Buy
                </a>
            </div>
            <p class="mobile-detail-login-hint">
                <a asp-action="Login" asp-controller="Auth" asp-area="Mobile">Sign in</a> or
                <a asp-action="Register" asp-controller="Auth" asp-area="Mobile">create an account</a>
                to purchase this item.
            </p>
        }
        @* Authenticated buyer — standard listing *@
        else if (!isStealable)
        {
            @if (Model.Status != ItemStatus.Sold)
            {
                @* Fulfillment options *@
                <div class="mobile-detail-section">
                    <h2 class="mobile-detail-section__title">How to receive?</h2>
                    <div class="mobile-fulfillment-options">
                        @if (Model.AllowDelivery)
                        {
                            <label class="mobile-fulfillment-option @(defaultFulfillmentMethod == "Delivery" ? "mobile-fulfillment-option--selected" : "")" data-method="Delivery">
                                <input type="radio" name="fulfillmentMethod" value="Delivery" class="mobile-fulfillment-radio"
                                @(defaultFulfillmentMethod == "Delivery" ? "checked" : "") />
                                <span class="mobile-fulfillment-option__radio"></span>
                                <span class="mobile-fulfillment-option__text">Delivery · ₱50 fee</span>
                            </label>
                        }
                        @if (Model.AllowHalfway)
                        {
                            <label class="mobile-fulfillment-option @(defaultFulfillmentMethod == "Halfway" ? "mobile-fulfillment-option--selected" : "")" data-method="Halfway">
                                <input type="radio" name="fulfillmentMethod" value="Halfway" class="mobile-fulfillment-radio"
                                @(defaultFulfillmentMethod == "Halfway" ? "checked" : "") />
                                <span class="mobile-fulfillment-option__radio"></span>
                                <span class="mobile-fulfillment-option__text">Halfway Meetup · Free</span>
                            </label>
                        }
                        @if (Model.AllowPickup)
                        {
                            <label class="mobile-fulfillment-option @(defaultFulfillmentMethod == "Pickup" ? "mobile-fulfillment-option--selected" : "")" data-method="Pickup">
                                <input type="radio" name="fulfillmentMethod" value="Pickup" class="mobile-fulfillment-radio"
                                @(defaultFulfillmentMethod == "Pickup" ? "checked" : "") />
                                <span class="mobile-fulfillment-option__radio"></span>
                                <span class="mobile-fulfillment-option__text">Self Pickup · Free</span>
                            </label>
                        }
                    </div>
                </div>

                @* Price breakdown *@
                <div class="mobile-price-breakdown" id="priceBreakdown">
                    <div class="mobile-price-breakdown__row">
                        <span>Item price</span>
                        <span>₱@Model.Price.ToString("N2")</span>
                    </div>
                    <div class="mobile-price-breakdown__row" id="deliveryFeeRow">
                        <span>Delivery fee</span>
                        <span id="deliveryFeeDisplay">₱50.00</span>
                    </div>
                    <div class="mobile-price-breakdown__row mobile-price-breakdown__row--total">
                        <span>Total</span>
                        <span id="totalPriceDisplay">₱@((Model.Price + 50).ToString("N2"))</span>
                    </div>
                </div>

                @* Action buttons *@
                <div class="mobile-detail-actions">
                    <form asp-action="BuyNow" method="get" id="buyNowForm" style="display:none;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="fulfillmentMethod" id="fulfillmentMethodInput" value="@defaultFulfillmentMethod" />
                        <button type="submit" class="mobile-btn mobile-btn--primary">
                            Buy Now
                        </button>
                    </form>
                    <form asp-action="ContactSeller" method="get" id="contactSellerForm" style="display:none;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="mobile-btn mobile-btn--outline">
                            Contact Seller
                        </button>
                    </form>
                </div>
            }
        }
        @* Authenticated buyer — stealable: available *@
        else if (Model.Status == ItemStatus.Available)
        {
            <div class="mobile-detail-actions">
                <form asp-action="GetItem" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="mobile-btn mobile-btn--primary">
                        Get this Item
                    </button>
                </form>
            </div>
            <p class="mobile-detail-steal-hint">
                Claim this item at the base price. Others can Steal it with +₱50 during the window.
            </p>
        }
        @* Authenticated buyer — stealable: reserved (current winner) *@
        else if (isCurrentWinner && Model.Status == ItemStatus.Reserved)
        {
            <div class="mobile-detail-notice mobile-detail-notice--winner">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
                You hold this item at ₱@Model.Price.ToString("N2").
            </div>
            <div class="mobile-detail-actions">
                <form asp-action="CancelGet" method="post" style="width:100%;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="mobile-btn mobile-btn--ghost">Cancel Reservation</button>
                </form>
            </div>
        }
        @* Authenticated buyer — stealable: reserved (not winner, can steal) *@
        else if (stealWindowOpen)
        {
            <div class="mobile-detail-actions">
                <form asp-action="StealItem" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="mobile-btn mobile-btn--steal">
                        Steal this Item · +₱50
                    </button>
                </form>
            </div>
        }
        @* Authenticated buyer — stolen pending checkout (current winner) *@
        else if (isCurrentWinner && Model.Status == ItemStatus.StolenPendingCheckout)
        {
            <div class="mobile-detail-actions">
                <a asp-action="Checkout" asp-controller="Orders" asp-area="Mobile" asp-route-itemId="@Model.Id"
                       class="mobile-btn mobile-btn--primary">
                    Complete Purchase
                </a>
            </div>
        }
    </div>
</div>

<script>
    (function() {
        // =========================================================
        // GALLERY NAVIGATION
        // =========================================================
        var images = @Json.Serialize(Model.ImageUrls);
        var currentIndex = 0;

        var mainImg = document.getElementById('mainGalleryImg');
        var counter = document.getElementById('galleryCounter');
        var thumbs = document.querySelectorAll('.mobile-gallery-thumb');
        var prevBtn = document.getElementById('galleryPrev');
        var nextBtn = document.getElementById('galleryNext');

        function goTo(index) {
            if (index < 0 || index >= images.length) return;
            currentIndex = index;
            if (mainImg) mainImg.src = images[index];
            if (counter) counter.textContent = (index + 1) + ' / ' + images.length;

            thumbs.forEach(function(thumb, i) {
                thumb.classList.toggle('mobile-gallery-thumb--active', i === index);
            });
        }

        if (prevBtn) prevBtn.addEventListener('click', function() { goTo(currentIndex - 1); });
        if (nextBtn) nextBtn.addEventListener('click', function() { goTo(currentIndex + 1); });

        thumbs.forEach(function(thumb) {
            thumb.addEventListener('click', function() {
                var idx = parseInt(this.dataset.index);
                if (!isNaN(idx)) goTo(idx);
            });
        });

        // =========================================================
        // FULFILLMENT METHOD SWITCHING
        // =========================================================
        var fulfillmentRadios = document.querySelectorAll('.mobile-fulfillment-radio');
        var fulfillmentInput = document.getElementById('fulfillmentMethodInput');
        var deliveryFeeRow = document.getElementById('deliveryFeeRow');
        var totalPriceDisplay = document.getElementById('totalPriceDisplay');
        var buyNowForm = document.getElementById('buyNowForm');
        var contactSellerForm = document.getElementById('contactSellerForm');

        var itemPrice = @Model.Price;
        var deliveryFee = 50.00;

        function updateFulfillmentUI(method) {
            document.querySelectorAll('.mobile-fulfillment-option').forEach(function(opt) {
                opt.classList.remove('mobile-fulfillment-option--selected');
            });
            var selected = document.querySelector('.mobile-fulfillment-option[data-method="' + method + '"]');
            if (selected) selected.classList.add('mobile-fulfillment-option--selected');

            var isDelivery = method === 'Delivery';
            if (deliveryFeeRow) deliveryFeeRow.style.display = isDelivery ? 'flex' : 'none';

            var total = isDelivery ? itemPrice + deliveryFee : itemPrice;
            if (totalPriceDisplay) totalPriceDisplay.textContent = '₱' + total.toFixed(2);

            if (fulfillmentInput) fulfillmentInput.value = method;

            if (buyNowForm && contactSellerForm) {
                buyNowForm.style.display = isDelivery ? 'block' : 'none';
                contactSellerForm.style.display = isDelivery ? 'none' : 'block';
            }
        }

        fulfillmentRadios.forEach(function(radio) {
            radio.addEventListener('change', function() {
                updateFulfillmentUI(radio.value);
            });
        });

        document.querySelectorAll('.mobile-fulfillment-option').forEach(function(opt) {
            opt.addEventListener('click', function() {
                var radio = this.querySelector('.mobile-fulfillment-radio');
                if (radio) {
                    radio.checked = true;
                    updateFulfillmentUI(radio.value);
                }
            });
        });

        var checkedRadio = document.querySelector('.mobile-fulfillment-radio:checked');
        if (checkedRadio) updateFulfillmentUI(checkedRadio.value);

        // =========================================================
        // STEAL TIMER
        // =========================================================
        var stealTimerEl = document.getElementById('stealTimer');
        if (stealTimerEl) {
            var endsAt = new Date(stealTimerEl.dataset.endsAt).getTime();

            function updateTimer() {
                var now = Date.now();
                var diff = endsAt - now;

                if (diff <= 0) {
                    stealTimerEl.textContent = '00:00:00';
                    return;
                }

                var hours = Math.floor(diff / (1000 * 60 * 60));
                var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((diff % (1000 * 60)) / 1000);

                stealTimerEl.textContent =
                    String(hours).padStart(2, '0') + ':' +
                    String(minutes).padStart(2, '0') + ':' +
                    String(seconds).padStart(2, '0');
            }

            updateTimer();
            setInterval(updateTimer, 1000);
        }
    })();
</script>