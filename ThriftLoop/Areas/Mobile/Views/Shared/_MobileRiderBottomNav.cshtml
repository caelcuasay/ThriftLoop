@using System.Security.Claims
@{
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var isRider = User.HasClaim(c => c.Type == "IsRider" && c.Value == "true");
}

@* Only show rider bottom nav for authenticated riders *@
@if (isRider && User.Identity?.IsAuthenticated == true)
{
    <nav class="mobile-rider-bottom-nav">
        <div class="mobile-rider-bottom-nav__container">
            <a asp-controller="Rider" asp-action="Index" asp-area="Mobile"
               class="mobile-rider-bottom-nav__link @(currentPath == "/mobile/rider" || currentPath.StartsWith("/mobile/rider/index", StringComparison.OrdinalIgnoreCase) ? "mobile-rider-bottom-nav__link--active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                <span class="mobile-rider-bottom-nav__label">Find Jobs</span>
            </a>

            <a asp-controller="Rider" asp-action="History" asp-area="Mobile"
               class="mobile-rider-bottom-nav__link @(currentPath.StartsWith("/mobile/rider/history", StringComparison.OrdinalIgnoreCase) ? "mobile-rider-bottom-nav__link--active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
                </svg>
                <span class="mobile-rider-bottom-nav__label">History</span>
            </a>

            <a asp-controller="Wallet" asp-action="Index" asp-area="Mobile"
               class="mobile-rider-bottom-nav__link @(currentPath.StartsWith("/mobile/wallet", StringComparison.OrdinalIgnoreCase) ? "mobile-rider-bottom-nav__link--active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4" />
                    <path d="M20 12v4H6a2 2 0 0 0-2 2c0 1.1.9 2 2 2h12v-4" />
                    <circle cx="12" cy="12" r="2" />
                </svg>
                <span class="mobile-rider-bottom-nav__label">Wallet</span>
            </a>

            <div class="mobile-rider-bottom-nav__menu">
                <button type="button" class="mobile-rider-bottom-nav__trigger" id="riderMenuBtn" aria-expanded="false" aria-label="Menu">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3" />
                        <path d="M12 1v6m0 6v6m4.22-10.22l4.24-4.24M6.34 17.66l-4.24 4.24M23 12h-6m-6 0H1m20.07 4.93l-4.24-4.24M6.34 6.34L2.1 2.1" />
                    </svg>
                    <span class="mobile-rider-bottom-nav__label">More</span>
                </button>

                <div class="mobile-rider-bottom-nav__dropdown" id="riderMenuDropdown">
                    <form asp-action="Logout" asp-controller="Auth" asp-area="Mobile" method="post" class="mobile-rider-bottom-nav__dropdown-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="mobile-rider-bottom-nav__dropdown-item mobile-rider-bottom-nav__dropdown-item--signout">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <polyline points="16 17 21 12 16 7" />
                                <line x1="21" y1="12" x2="9" y2="12" />
                            </svg>
                            Sign out
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <script>
        (function() {
            var menuBtn = document.getElementById('riderMenuBtn');
            var dropdown = document.getElementById('riderMenuDropdown');

            if (menuBtn && dropdown) {
                menuBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var isExpanded = this.getAttribute('aria-expanded') === 'true';
                    this.setAttribute('aria-expanded', !isExpanded);
                    dropdown.classList.toggle('mobile-rider-bottom-nav__dropdown--visible');
                });

                document.addEventListener('click', function(e) {
                    if (!menuBtn.contains(e.target) && !dropdown.contains(e.target)) {
                        menuBtn.setAttribute('aria-expanded', 'false');
                        dropdown.classList.remove('mobile-rider-bottom-nav__dropdown--visible');
                    }
                });
            }
        })();
    </script>
}
