@using System.Security.Claims
@{
    var userEmail = User.FindFirst(ClaimTypes.Email)?.Value
                        ?? User.Identity?.Name
                        ?? string.Empty;
    var displayName = userEmail.Contains('@') ? userEmail.Split('@')[0] : userEmail;
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var isAuthPage = currentPath.StartsWith("/mobile/auth", StringComparison.OrdinalIgnoreCase);
    var isRider = User.HasClaim(c => c.Type == "IsRider" && c.Value == "true");
}

<header class="mobile-topbar">
    @* Back button for auth sub-pages *@
    @if (isAuthPage && !currentPath.EndsWith("/login", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-action="Login" asp-controller="Auth" asp-area="Mobile" class="mobile-topbar__back" aria-label="Back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <path d="M19 12H5m7-7l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
    }

    @* Brand (logo only) *@
    <a asp-controller="Home" asp-action="Index" asp-area="Mobile" class="mobile-topbar__brand" aria-label="ThriftLoop Home">
        <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path fill="currentColor" d="M382,136c-40.87,0-73.46,20.53-93.6,37.76l-.71.61-11.47,12.47,25.32,41.61,18.74-18.79C339.89,193.1,361.78,184,382,184c40.8,0,74,32.3,74,72s-33.2,72-74,72c-62,0-104.14-81.95-104.56-82.78h0C275,240.29,221.56,136,130,136,62.73,136,8,189.83,8,256S62.73,376,130,376c32.95,0,65.38-13.11,93.79-37.92l.61-.54,11.38-12.38-25.33-41.61-18.83,18.88C172,319.4,151.26,328,130,328c-40.8,0-74-32.3-74-72s33.2-72,74-72c62,0,104.14,81.95,104.56,82.78h0C237,271.71,290.44,376,382,376c67.27,0,122-53.83,122-120S449.27,136,382,136Z" />
        </svg>
    </a>

    @* Center nav: For You + Sellers (only on non-auth, non-rider pages) *@
    @if (!isAuthPage && !isRider && User.Identity?.IsAuthenticated == true)
    {
        <nav class="mobile-topbar__nav">
            <a asp-controller="Home" asp-action="Index" asp-area="Mobile"
                   class="mobile-topbar__nav-link @(currentPath == "/mobile" || currentPath.StartsWith("/mobile/home", StringComparison.OrdinalIgnoreCase) ? "mobile-topbar__nav-link--active" : "")">
                For You
            </a>
            <a asp-controller="Sellers" asp-action="Index" asp-area="Mobile"
                   class="mobile-topbar__nav-link @(currentPath.StartsWith("/mobile/sellers", StringComparison.OrdinalIgnoreCase) ? "mobile-topbar__nav-link--active" : "")">
                Sellers
            </a>
        </nav>
    }

    @* Right: Profile avatar with dropdown *@
    <div class="mobile-topbar__actions">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mobile-topbar__avatar-wrap" id="mobileAvatarWrap">
                <button class="mobile-topbar__avatar-btn" id="mobileAvatarBtn" aria-expanded="false" aria-label="User menu">
                    <span class="mobile-topbar__avatar">@char.ToUpper(displayName[0])</span>
                </button>

                <div class="mobile-topbar__dropdown" id="mobileAvatarDropdown">
                    @* User info *@
                    <div class="mobile-topbar__dropdown-header">
                        <span class="mobile-topbar__dropdown-name">@displayName</span>
                        <span class="mobile-topbar__dropdown-email">@userEmail</span>
                    </div>

                    <div class="mobile-topbar__dropdown-divider"></div>

                    @* Menu items *@
                    <a asp-controller="User" asp-action="Index" asp-area="Mobile"
                           class="mobile-topbar__dropdown-item @(currentPath.StartsWith("/mobile/user", StringComparison.OrdinalIgnoreCase) ? "mobile-topbar__dropdown-item--active" : "")">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path d="M8 8a3 3 0 100-6 3 3 0 000 6zm-4.5 5.5a5 5 0 019 0h-9z" />
                        </svg>
                        My Profile
                    </a>

                    <a asp-controller="Orders" asp-action="MyPurchases" asp-area="Mobile"
                           class="mobile-topbar__dropdown-item @(currentPath.StartsWith("/mobile/orders", StringComparison.OrdinalIgnoreCase) ? "mobile-topbar__dropdown-item--active" : "")">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path d="M1 2.5A1.5 1.5 0 012.5 1h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 01.44 1.061V13.5A1.5 1.5 0 018.5 15h-6A1.5 1.5 0 011 13.5v-11z" />
                            <path d="M9 4.5V1a1 1 0 011-1h3.5a1.5 1.5 0 011.5 1.5v11a1.5 1.5 0 01-1.5 1.5h-4.5A1.5 1.5 0 019 13.5v-9z" />
                        </svg>
                        My Purchases
                    </a>

                    <a asp-controller="Wallet" asp-action="Index" asp-area="Mobile"
                           class="mobile-topbar__dropdown-item @(currentPath.StartsWith("/mobile/wallet", StringComparison.OrdinalIgnoreCase) ? "mobile-topbar__dropdown-item--active" : "")">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path fill-rule="evenodd" d="M1 3A1.5 1.5 0 012.5 1.5h11A1.5 1.5 0 0115 3v10a1.5 1.5 0 01-1.5 1.5h-11A1.5 1.5 0 011 13V3zm10.5 5a.75.75 0 100 1.5.75.75 0 000-1.5z" clip-rule="evenodd" />
                        </svg>
                        Wallet
                    </a>

                    <a asp-controller="Likes" asp-action="Index" asp-area="Mobile"
                           class="mobile-topbar__dropdown-item @(currentPath.StartsWith("/mobile/likes", StringComparison.OrdinalIgnoreCase) ? "mobile-topbar__dropdown-item--active" : "")">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path d="M8 1.314C2.824-2.16-2.824 8.686 8 16c10.824-7.314 5.176-18.16 0-14.686z" />
                        </svg>
                        Liked Items
                    </a>

                    @if (User.IsInRole("Seller"))
                    {
                        <a asp-controller="Shop" asp-action="Mine" asp-area="Mobile"
                               class="mobile-topbar__dropdown-item @(currentPath.StartsWith("/mobile/shop", StringComparison.OrdinalIgnoreCase) ? "mobile-topbar__dropdown-item--active" : "")">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 1a2.5 2.5 0 00-2.5 2.5H3.5A1.5 1.5 0 002 5v8.5A1.5 1.5 0 003.5 15h9a1.5 1.5 0 001.5-1.5V5a1.5 1.5 0 00-1.5-1.5h-2A2.5 2.5 0 008 1zm0 1.5A1 1 0 019 3.5v0H7v0A1 1 0 018 2.5zm-2.5 2H4a.5.5 0 00-.5.5v8a.5.5 0 00.5.5h8a.5.5 0 00.5-.5V5a.5.5 0 00-.5-.5h-1.5v.75a.75.75 0 01-1.5 0V4.5h-2v.75a.75.75 0 01-1.5 0V4.5z" clip-rule="evenodd" />
                            </svg>
                            My Shop
                        </a>
                    }

                    <div class="mobile-topbar__dropdown-divider"></div>

                    <form asp-action="Logout" asp-controller="Auth" asp-area="Mobile" method="post" class="mobile-topbar__dropdown-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="mobile-topbar__dropdown-item mobile-topbar__dropdown-item--signout">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true">
                                <path fill-rule="evenodd" d="M2 2.75A2.75 2.75 0 014.75 0h5.5A2.75 2.75 0 0113 2.75v10.5A2.75 2.75 0 0110.25 16h-5.5A2.75 2.75 0 012 13.25v-10.5zM8.5 5a.75.75 0 00-1.5 0v3.5a.75.75 0 001.5 0V5z" clip-rule="evenodd" />
                            </svg>
                            Sign out
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            @if (!isAuthPage)
            {
                <a asp-action="Login" asp-controller="Auth" asp-area="Mobile" class="mobile-topbar__text-btn">Sign In</a>
            }
        }
    </div>
</header>

<script>
    (function() {
        var avatarBtn = document.getElementById('mobileAvatarBtn');
        var dropdown = document.getElementById('mobileAvatarDropdown');
        var avatarWrap = document.getElementById('mobileAvatarWrap');

        if (avatarBtn && dropdown) {
            avatarBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var isExpanded = this.getAttribute('aria-expanded') === 'true';
                this.setAttribute('aria-expanded', !isExpanded);
                dropdown.classList.toggle('mobile-topbar__dropdown--visible');
            });

            document.addEventListener('click', function(e) {
                if (avatarWrap && !avatarWrap.contains(e.target)) {
                    avatarBtn.setAttribute('aria-expanded', 'false');
                    dropdown.classList.remove('mobile-topbar__dropdown--visible');
                }
            });
        }
    })();
</script>