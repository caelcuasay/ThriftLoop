@using System.Security.Claims
@{
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var isAuthPage = currentPath.StartsWith("/mobile/auth", StringComparison.OrdinalIgnoreCase);
    var isRider = User.HasClaim(c => c.Type == "IsRider" && c.Value == "true");
    var isSeller = User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value == "Seller");
}

@* Only show bottom nav on non-auth, non-rider pages when authenticated *@
@{
    var isConversationPage = currentPath.StartsWith("/mobile/chat/conversation", StringComparison.OrdinalIgnoreCase);
}
@if (!isAuthPage && !isRider && !isConversationPage && User.Identity?.IsAuthenticated == true)
{
    <nav class="mobile-bottom-nav">
        <a asp-controller="Home" asp-action="Index" asp-area="Mobile"
               class="mobile-bottom-nav__item @(currentPath == "/mobile" || currentPath.StartsWith("/mobile/home", StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith("/mobile/sellers", StringComparison.OrdinalIgnoreCase) ? "mobile-bottom-nav__item--active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
            </svg>
            <span>Home</span>
        </a>

        <a asp-controller="Chat" asp-action="Index" asp-area="Mobile"
               class="mobile-bottom-nav__item @(currentPath.StartsWith("/mobile/chat", StringComparison.OrdinalIgnoreCase) ? "mobile-bottom-nav__item--active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            <span>Chat</span>
        </a>

        <div class="mobile-fab-menu">
            <div class="mobile-fab-menu__backdrop" onclick="toggleFabMenu()"></div>
            <div class="mobile-fab-menu__items">
                <a asp-controller="Items" asp-action="Create" asp-area="Mobile" class="mobile-fab-menu__item">
                    <div class="mobile-fab-menu__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                            <path d="M12 5v14m-7-7h14" stroke-linecap="round" />
                        </svg>
                    </div>
                    <span class="mobile-fab-menu__label">Add Listing</span>
                </a>
                <a asp-controller="Items" asp-action="Index" asp-area="Mobile" class="mobile-fab-menu__item">
                    <div class="mobile-fab-menu__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                    </div>
                    <span class="mobile-fab-menu__label">View Listings</span>
                </a>
                @if (isSeller)
                {
                    <a asp-controller="Shop" asp-action="Create" asp-area="Mobile" class="mobile-fab-menu__item">
                        <div class="mobile-fab-menu__icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                                <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" />
                                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                                <line x1="12" y1="22.08" x2="12" y2="12" />
                            </svg>
                        </div>
                        <span class="mobile-fab-menu__label">Add Shop Item</span>
                    </a>
                }
            </div>
            <button type="button" class="mobile-bottom-nav__create" onclick="toggleFabMenu()" aria-label="Add new">
                <svg class="mobile-bottom-nav__create-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="26" height="26">
                    <path d="M12 5v14m-7-7h14" stroke-linecap="round" />
                </svg>
            </button>
        </div>

        <script>
                function toggleFabMenu() {
                    var menu = document.querySelector('.mobile-fab-menu');
                    if (menu) menu.classList.toggle('is-open');
                }

                // Close FAB menu when clicking backdrop
                document.addEventListener('click', function(e) {
                    if (e.target.closest('.mobile-fab-menu__backdrop')) {
                        var menu = document.querySelector('.mobile-fab-menu');
                        if (menu) menu.classList.remove('is-open');
                    }
                });
        </script>

        <a asp-controller="Cart" asp-action="Index" asp-area="Mobile"
               class="mobile-bottom-nav__item @(currentPath.StartsWith("/mobile/cart", StringComparison.OrdinalIgnoreCase) ? "mobile-bottom-nav__item--active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
            </svg>
            <span>Cart</span>
        </a>

        <a asp-controller="Likes" asp-action="Index" asp-area="Mobile"
               class="mobile-bottom-nav__item @(currentPath.StartsWith("/mobile/likes", StringComparison.OrdinalIgnoreCase) ? "mobile-bottom-nav__item--active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
            </svg>
            <span>Likes</span>
        </a>
    </nav>
}