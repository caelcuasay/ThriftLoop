@model ThriftLoop.DTOs.User.UpdateProfileDTO
@using ThriftLoop.DTOs.User

@{
    ViewData["Title"] = "My Profile";
    Layout = null;

    var profile = ViewBag.Profile as UserProfileDTO;
    var initials = !string.IsNullOrWhiteSpace(profile?.FullName)
        ? string.Concat(profile.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => char.ToUpper(w[0])))
        : char.ToUpper(profile?.Email?.FirstOrDefault() ?? 'U').ToString();
    var memberSince = profile?.CreatedAt.ToString("MMMM yyyy") ?? "—";

    bool profileIncomplete = string.IsNullOrWhiteSpace(profile?.PhoneNumber)
                          || string.IsNullOrWhiteSpace(profile?.Address);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThriftLoop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User.css" asp-append-version="true" />
</head>
<body>

    <a class="sr-only" href="#main-content">Skip to main content</a>

    @await Html.PartialAsync("_Navbar")

    <div class="up-container">
        <div class="up-shell">

            @* Left: profile sidebar *@
            <aside class="up-sidebar" aria-label="Profile information" role="complementary">
                <div class="up-sidebar__header">
                    <span class="up-sidebar__title">Profile</span>
                </div>

                <div class="up-profile-card">
                    <div class="up-avatar up-avatar--large" aria-hidden="true">@initials</div>

                    <h2 class="up-profile-name">
                        @(string.IsNullOrWhiteSpace(profile?.FullName) ? profile?.Email : profile.FullName)
                    </h2>

                    <div class="up-profile-badges" aria-hidden="true">
                        <span class="up-badge">@profile?.Role</span>
                        <span class="up-badge up-badge--light">Member since @memberSince</span>
                        @if (profile?.IsGoogleAccount == true)
                        {
                            <span class="up-badge up-badge--google" aria-hidden="true">
                                <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true" focusable="false">
                                    <circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5" />
                                    <path d="M8 4.5v7M4.5 8h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                                </svg>
                                Google account
                            </span>
                        }
                        @if (profileIncomplete)
                        {
                            <span class="up-badge up-badge--warning" title="Phone number and address are required to buy or sell">
                                ⚠ Profile incomplete
                            </span>
                        }
                    </div>
                </div>

                @* Account info section inside sidebar *@
                <div class="up-filter-group">
                    <p class="up-filter-group__label">Account Information</p>
                    <ul class="up-info-list">
                        <li class="up-info-item">
                            <span class="up-info-label">Email</span>
                            <span class="up-info-value" id="profile-email">@profile?.Email</span>
                        </li>
                        <li class="up-info-item">
                            <span class="up-info-label">Full Name</span>
                            <span class="up-info-value @(string.IsNullOrWhiteSpace(profile?.FullName) ? "up-info-value--empty" : "")">
                                @(string.IsNullOrWhiteSpace(profile?.FullName) ? "Not set" : profile.FullName)
                            </span>
                        </li>
                        <li class="up-info-item">
                            <span class="up-info-label">
                                Phone Number
                                @if (string.IsNullOrWhiteSpace(profile?.PhoneNumber))
                                {
                                    <span class="up-required-dot" title="Required to buy or sell" aria-label="Required">●</span>
                                }
                            </span>
                            <span class="up-info-value @(string.IsNullOrWhiteSpace(profile?.PhoneNumber) ? "up-info-value--empty" : "")">
                                @(string.IsNullOrWhiteSpace(profile?.PhoneNumber) ? "Not set" : profile.PhoneNumber)
                            </span>
                        </li>
                        <li class="up-info-item">
                            <span class="up-info-label">
                                Address
                                @if (string.IsNullOrWhiteSpace(profile?.Address))
                                {
                                    <span class="up-required-dot" title="Required to buy or sell" aria-label="Required">●</span>
                                }
                            </span>
                            <span class="up-info-value @(string.IsNullOrWhiteSpace(profile?.Address) ? "up-info-value--empty" : "")">
                                @(string.IsNullOrWhiteSpace(profile?.Address) ? "Not set" : profile.Address)
                            </span>
                        </li>
                    </ul>
                </div>
            </aside>

            @* Right: edit profile form *@
            <main class="up-main" id="main-content" role="main" aria-labelledby="profile-heading">
                <header class="up-feed-header">
                    <h1 class="up-feed-title" id="profile-heading">Edit Profile</h1>
                    <p class="up-feed-meta">Update your personal information</p>
                </header>

                @* Redirected here because profile is incomplete *@
                @if (TempData["ProfileIncomplete"] is string incompleteMsg)
                {
                    <div class="up-alert up-alert--warning" role="alert" aria-live="assertive">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true" focusable="false">
                            <path fill-rule="evenodd" d="M8 1a7 7 0 100 14A7 7 0 008 1zm-.75 4.25a.75.75 0 011.5 0v3.5a.75.75 0 01-1.5 0v-3.5zm.75 7a.75.75 0 110-1.5.75.75 0 010 1.5z" clip-rule="evenodd" />
                        </svg>
                        @incompleteMsg
                    </div>
                }

                @* Proactive nudge when phone or address is still missing *@
                @if (profileIncomplete && TempData["ProfileIncomplete"] is null)
                {
                    <div class="up-alert up-alert--info" role="note" aria-live="polite">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true" focusable="false">
                            <path fill-rule="evenodd" d="M8 1a7 7 0 100 14A7 7 0 008 1zm-.75 4.25a.75.75 0 011.5 0v3.5a.75.75 0 01-1.5 0v-3.5zm.75 7a.75.75 0 110-1.5.75.75 0 010 1.5z" clip-rule="evenodd" />
                        </svg>
                        Your <strong>phone number</strong> and <strong>address</strong> are required before you can list or purchase items.
                    </div>
                }

                @* Success / validation banners *@
                @if (TempData["ProfileSuccess"] is string successMsg)
                {
                    <div class="up-alert up-alert--success" role="status" aria-live="polite">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true" focusable="false">
                            <path fill-rule="evenodd" d="M8 1a7 7 0 100 14A7 7 0 008 1zm3.28 5.28a.75.75 0 00-1.06-1.06L7 8.44 5.78 7.22a.75.75 0 00-1.06 1.06l1.75 1.75a.75.75 0 001.06 0l3.75-3.75z" clip-rule="evenodd" />
                        </svg>
                        @successMsg
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="up-alert up-alert--error" role="alert" aria-live="assertive">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true" focusable="false">
                            <path fill-rule="evenodd" d="M8 1a7 7 0 100 14A7 7 0 008 1zm-.75 4.25a.75.75 0 011.5 0v3.5a.75.75 0 01-1.5 0v-3.5zm.75 7a.75.75 0 110-1.5.75.75 0 010 1.5z" clip-rule="evenodd" />
                        </svg>
                        Please fix the errors below before saving.
                    </div>
                }

                <div class="up-form-card" aria-labelledby="profile-heading">
                    <form asp-controller="User" asp-action="UpdateProfile" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="up-form-group">
                            <label asp-for="FullName" class="up-form-label">Full Name</label>
                            <input asp-for="FullName"
                                   class="up-form-input @(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "up-form-input--error" : "")"
                                   placeholder="e.g. Maria Santos"
                                   autocomplete="name"
                                   aria-invalid="@(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "true" : "false")"
                                   aria-describedby="FullName-error" />
                            <span asp-validation-for="FullName" class="up-form-error" id="FullName-error"></span>
                        </div>

                        <div class="up-form-group">
                            <label asp-for="PhoneNumber" class="up-form-label">
                                Phone Number
                                <span class="up-form-label__required" aria-label="Required to buy or sell">Required to buy or sell</span>
                            </label>
                            <input asp-for="PhoneNumber"
                                   class="up-form-input @(ViewData.ModelState["PhoneNumber"]?.Errors.Count > 0 ? "up-form-input--error" : "")"
                                   placeholder="e.g. +639171234567"
                                   autocomplete="tel"
                                   type="tel"
                                   aria-invalid="@(ViewData.ModelState["PhoneNumber"]?.Errors.Count > 0 ? "true" : "false")"
                                   aria-describedby="PhoneNumber-hint PhoneNumber-error" />
                            <span class="up-form-hint" id="PhoneNumber-hint">Needed to create listings and complete purchases.</span>
                            <span asp-validation-for="PhoneNumber" class="up-form-error" id="PhoneNumber-error"></span>
                        </div>

                        <div class="up-form-group">
                            <label asp-for="Address" class="up-form-label">
                                Address
                                <span class="up-form-label__required" aria-label="Required to buy or sell">Required to buy or sell</span>
                            </label>
                            <textarea asp-for="Address"
                                      class="up-form-input up-form-textarea @(ViewData.ModelState["Address"]?.Errors.Count > 0 ? "up-form-input--error" : "")"
                                      placeholder="Street, City, Province, ZIP"
                                      rows="3"
                                      autocomplete="street-address"
                                      aria-invalid="@(ViewData.ModelState["Address"]?.Errors.Count > 0 ? "true" : "false")"
                                      aria-describedby="Address-hint Address-error"></textarea>
                            <span class="up-form-hint" id="Address-hint">Used as your delivery address for orders.</span>
                            <span asp-validation-for="Address" class="up-form-error" id="Address-error"></span>
                        </div>

                        <div class="up-form-actions">
                            <button type="submit" class="up-btn up-btn--primary">Save Changes</button>
                            <a asp-controller="Home" asp-action="Index" class="up-btn up-btn--ghost">Cancel</a>
                        </div>
                    </form>
                </div>

                @* Security section (password change — hidden for Google accounts) *@
                @if (profile?.IsGoogleAccount == false)
                {
                    <div class="up-security-card" aria-labelledby="security-title">
                        <div class="up-security-header">
                            <h3 class="up-security-title" id="security-title">Security</h3>
                            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" width="18" height="18" aria-hidden="true" focusable="false">
                                <path d="M10 2.5L3.75 6.25V10.5C3.75 14.5 6.75 18 10 18.5C13.25 18 16.25 14.5 16.25 10.5V6.25L10 2.5Z" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M10 10.5V13M10 8H10.008" stroke-linecap="round" />
                            </svg>
                        </div>
                        <p class="up-security-desc">
                            Need to update your password? We'll send a secure reset link to your email address.
                        </p>
                        <a asp-controller="Auth" asp-action="ForgotPassword" class="up-btn up-btn--outline" role="button">
                            Reset Password via Email
                        </a>
                    </div>
                }

            </main>
        </div>
    </div>

</body>
</html>