@* Views/Chat/Index.cshtml *@
@model List<ThriftLoop.DTOs.Chat.ConversationDTO>
@{
    ViewData["Title"] = ViewBag.UnreadCount > 0 ? $"Messages ({ViewBag.UnreadCount})" : "Messages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
}

<div class="chat-container">
    @* Sidebar *@
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <h2>Messages</h2>
            <button type="button" class="btn-new-message" id="newMessageBtn" title="New message">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 9l5 5 5-5M12 14V2" />
                </svg>
            </button>
        </div>

        <div class="chat-sidebar-search">
            <input type="text" id="conversationSearch" placeholder="Search conversations..." autocomplete="off" />
        </div>

        <div class="chat-conversation-list" id="conversationList">
            @if (Model.Count == 0)
            {
                <div class="chat-empty-state">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                    </svg>
                    <h3>No messages yet</h3>
                    <p>Start a conversation with someone!</p>
                    <button type="button" class="btn btn-primary" id="startFirstChatBtn">Start a chat</button>
                </div>
            }
            else
            {
                @foreach (var conv in Model)
                {
                    <a href="@Url.Action("Conversation", new { id = conv.Id })"
                           class="conversation-item @(conv.UnreadCount > 0 ? "unread" : "")">
                        <div class="conversation-avatar">
                            @if (!string.IsNullOrEmpty(conv.OtherUserAvatarUrl))
                            {
                                <img src="@conv.OtherUserAvatarUrl" alt="@conv.OtherUserName" />
                            }
                            else
                            {
                                <div class="avatar-placeholder">
                                    @conv.OtherUserName.Substring(0, 1).ToUpper()
                                </div>
                            }
                        </div>
                        <div class="conversation-content">
                            <div class="conversation-header">
                                <span class="conversation-name">@conv.OtherUserName</span>
                                <span class="conversation-time">@GetRelativeTime(conv.LastMessageAt)</span>
                            </div>
                            <div class="conversation-preview">
                                @if (conv.LastMessageIsFromCurrentUser)
                                {
                                    <span class="you-prefix">You: </span>
                                }
                                <span class="last-message">@Truncate(conv.LastMessage, 35)</span>
                                @if (conv.UnreadCount > 0)
                                {
                                    <span class="unread-badge">@GetBadgeCount(conv.UnreadCount)</span>
                                }
                            </div>
                            @if (conv.LastMessageIsFromCurrentUser && !string.IsNullOrEmpty(conv.LastMessageStatus))
                            {
                                <div class="message-status">
                                    @GetStatusIcon(conv.LastMessageStatus)
                                </div>
                            }
                        </div>
                    </a>
                }
            }
        </div>

        @if (ViewBag.HasMoreConversations == true)
        {
            <div class="chat-sidebar-footer">
                <button type="button" class="btn-load-more" id="loadMoreConversations" data-page="@(ViewBag.CurrentPage + 1)">
                    Load more
                </button>
            </div>
        }
    </div>

    @* Main content area (empty state) *@
    <div class="chat-main">
        <div class="chat-empty-main">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            <h2>Your messages</h2>
            <p>Select a conversation or start a new one</p>
            <button type="button" class="btn btn-primary" id="newMessageEmptyBtn">New message</button>
        </div>
    </div>
</div>

@* New Message Modal *@
<div class="modal" id="newMessageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3>New message</h3>
                <button type="button" class="btn-close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="search-container">
                    <input type="text"
                           id="userSearchInput"
                           class="form-control"
                           placeholder="Search for a user..."
                           autocomplete="off" />
                    <div class="search-results" id="userSearchResults"></div>
                </div>
                <form id="newMessageForm" method="post" action="@Url.Action("Start")" class="hidden">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="selectedUserId" name="RecipientId" />
                    <div class="selected-user-display" id="selectedUserDisplay"></div>
                    <div class="form-group">
                        <label for="initialMessage">Message (optional)</label>
                        <textarea id="initialMessage"
                                  name="InitialMessage"
                                  class="form-control"
                                  rows="3"
                                  maxlength="2000"
                                  placeholder="Write a message..."></textarea>
                        <small class="char-count"><span id="charCount">0</span>/2000</small>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="startChatBtn" disabled>Start chat</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat-inbox.js" asp-append-version="true"></script>
}

@functions {
    private string GetRelativeTime(DateTime timestamp)
    {
        var now = DateTime.UtcNow;
        var diff = now - timestamp;

        if (diff.TotalMinutes < 1)
            return "just now";
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours}h";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays}d";
        
        return timestamp.ToLocalTime().ToString("MMM d");
    }

    private string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        return text.Substring(0, maxLength) + "...";
    }

    private string GetBadgeCount(int count)
    {
        return count > 99 ? "99+" : count.ToString();
    }

    private string GetStatusIcon(string status)
    {
        return status switch
        {
            "Read" => "✓✓",
            "Delivered" => "✓✓",
            "Sent" => "✓",
            _ => ""
        };
    }
}