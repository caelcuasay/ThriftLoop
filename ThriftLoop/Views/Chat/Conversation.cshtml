@* Views/Chat/Conversation.cshtml *@
@model ThriftLoop.DTOs.Chat.ConversationDetailDTO
@{
    ViewData["Title"] = Model.OtherUserName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
}

<div class="chat-container">
    @* Sidebar *@
    <div class="chat-sidebar" id="chatSidebar">
        <div class="chat-sidebar-header">
            <h2>Messages</h2>
            <button type="button" class="btn-new-message" id="newMessageBtn" title="New message">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 9l5 5 5-5M12 14V2" />
                </svg>
            </button>
        </div>

        <div class="chat-sidebar-search">
            <input type="text" id="conversationSearch" placeholder="Search conversations..." autocomplete="off" />
        </div>

        <div class="chat-conversation-list" id="conversationList">
            <div class="loading-placeholder">Loading conversations...</div>
        </div>
    </div>

    @* Main Chat Area *@
    <div class="chat-main">
        @* Chat Header *@
        <div class="chat-header">
            <button type="button" class="btn-back-sidebar" id="toggleSidebarBtn" title="Show conversations">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 18l-6-6 6-6" />
                </svg>
            </button>

            <div class="chat-header-info">
                <div class="chat-avatar">
                    @if (!string.IsNullOrEmpty(Model.OtherUserAvatarUrl))
                    {
                        <img src="@Model.OtherUserAvatarUrl" alt="@Model.OtherUserName" />
                    }
                    else
                    {
                        <div class="avatar-placeholder">
                            @Model.OtherUserName.Substring(0, 1).ToUpper()
                        </div>
                    }
                    <span class="online-indicator @(Model.IsOtherUserOnline ? "online" : "")"></span>
                </div>
                <div class="chat-user-info">
                    <h3>@Model.OtherUserName</h3>
                    <span class="user-status" id="userStatus">@Model.OtherUserActiveStatus</span>
                </div>
            </div>

            <div class="chat-header-actions">
                <button type="button" class="btn-icon" title="View profile">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </button>
            </div>
        </div>

        @* Context header if linked to item/order *@
        @if (Model.HasContext)
        {
            <div class="chat-context-header">
                <div class="chat-context-info">
                    @if (!string.IsNullOrEmpty(Model.LinkedItemImageUrl))
                    {
                        <img src="@Model.LinkedItemImageUrl" alt="@Model.LinkedItemTitle" class="chat-context-image" />
                    }
                    <div class="chat-context-details">
                        <span class="chat-context-title">@Model.ContextHeaderText</span>
                        @if (!string.IsNullOrEmpty(Model.ContextSubtitleText))
                        {
                            <span class="chat-context-subtitle">@Model.ContextSubtitleText</span>
                        }
                    </div>
                </div>
                @if (Model.IsItemInquiry && Model.CanCreateOrder)
                {
                    <a asp-action="Checkout" asp-controller="Orders" asp-route-itemId="@Model.ContextItemId" class="chat-context-action">
                        Create Order
                    </a>
                }
                @if (Model.IsOrderConversation && Model.CanConfirmReceipt)
                {
                    <form asp-action="MarkDelivered" asp-controller="Orders" asp-route-orderId="@Model.LinkedOrderId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="chat-context-action">Confirm Receipt</button>
                    </form>
                }
            </div>
        }

        @* Messages Area *@
        <div class="chat-messages" id="messageContainer">
            @if (Model.HasMoreMessages)
            {
                <div class="load-more-container">
                    <button type="button" class="btn-load-more-messages" id="loadOlderMessages" data-page="@(Model.Page + 1)" data-has-more="true">
                        Load older messages
                    </button>
                </div>
            }

            <div class="messages-list" id="messagesList">
                @foreach (var message in Model.Messages)
                {
                    <partial name="_MessageBubble" model="message" />
                }
            </div>

            <div id="typingIndicator" class="typing-indicator hidden">
                <span></span>
                <span></span>
                <span></span>
                <span class="typing-text">@Model.OtherUserName is typing...</span>
            </div>
        </div>

        @* Message Input Area *@
        <div class="chat-input-area">
            <form id="messageForm" class="message-form">
                @Html.AntiForgeryToken()
                <input type="hidden" id="conversationId" value="@Model.Id" />
                <input type="hidden" id="recipientId" value="@Model.OtherUserId" />
                
                <textarea id="messageInput"
                          class="message-input"
                          placeholder="Type a message..."
                          rows="1"
                          maxlength="2000"
                          autocomplete="off"></textarea>
                
                <button type="submit" class="btn-send" id="sendMessageBtn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
                    </svg>
                </button>
            </form>
            <small class="char-count"><span id="messageCharCount">0</span>/2000</small>
        </div>
    </div>
</div>

@* New Message Modal *@
<div class="modal" id="newMessageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3>New message</h3>
                <button type="button" class="btn-close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <partial name="_UserSearchModal" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
    <script>
        // Initialize chat with conversation data
        document.addEventListener('DOMContentLoaded', function() {
        window.chatConfig = {
        conversationId: @Model.Id,
        currentUserId: @(Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"),
        otherUserId: @Model.OtherUserId,
        otherUserName: '@Html.Raw(Model.OtherUserName)',
        prefillMessage: ''
        };
            
        if (typeof initializeChat === 'function') {
        initializeChat(window.chatConfig);
        }
        });

        // Auto-scroll to bottom on page load/refresh
        (function() {
        function scrollToBottomImmediate() {
        const messageContainer = document.getElementById('messageContainer');
        if (messageContainer) {
        messageContainer.scrollTop = messageContainer.scrollHeight;
        }
        }
            
        // Try immediate scroll
        scrollToBottomImmediate();
            
        // Also scroll after short delays to ensure images and dynamic content are loaded
        setTimeout(scrollToBottomImmediate, 100);
        setTimeout(scrollToBottomImmediate, 300);
        setTimeout(scrollToBottomImmediate, 500);
        setTimeout(scrollToBottomImmediate, 1000);
            
        // Use MutationObserver to detect when new messages are added
        const messagesList = document.getElementById('messagesList');
        if (messagesList) {
        const observer = new MutationObserver(function() {
        scrollToBottomImmediate();
        });
        observer.observe(messagesList, { childList: true, subtree: true });
        }
        })();
    </script>
}

<style>
    .chat-context-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    background: #f8f9fa;
    border-bottom: 1px solid #e9ecef;
    }
    
    .chat-context-info {
    display: flex;
    align-items: center;
    gap: 12px;
    }
    
    .chat-context-image {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    object-fit: cover;
    }
    
    .chat-context-details {
    display: flex;
    flex-direction: column;
    }
    
    .chat-context-title {
    font-weight: 600;
    font-size: 14px;
    color: #1a1814;
    }
    
    .chat-context-subtitle {
    font-size: 12px;
    color: #6b7280;
    }
    
    .chat-context-action {
    padding: 6px 16px;
    background: #2d5a27;
    color: white;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    }
    
    .chat-context-action:hover {
    background: #1f401b;
    }
    
    .chat-toast {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    }

    /* Ensure contextual cards are properly centered and spaced */
    .messages-list .contextual-card {
    margin: 16px auto;
    }

    /* System message spacing */
    .system-message {
    margin: 12px 0;
    }
</style>