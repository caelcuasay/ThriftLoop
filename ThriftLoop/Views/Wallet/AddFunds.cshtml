@{
    ViewData["Title"] = "Add Funds";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="addfunds-shell">

    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a asp-action="Index" asp-controller="Wallet" class="detail-breadcrumb__link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Back to Wallet
        </a>
    </nav>

    <div class="addfunds-card">

        <div class="addfunds-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
        </div>

        <h1 class="addfunds-card__title">Add Funds</h1>
        <p class="addfunds-card__subtitle">
            Top up your ThriftLoop wallet to pay for items instantly with escrow protection.
        </p>

        @* ── Demo top-up (real gateway placeholder) ──────────────────────── *@
        <div class="addfunds-demo-notice">
            <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
            </svg>
            <p>
                <strong>Demo mode:</strong> This is a placeholder. In production this page will
                integrate with GCash, Maya, or a bank transfer gateway. For now, entering an
                amount will directly credit your wallet.
            </p>
        </div>

        @if (TempData["ErrorMessage"] is string errMsg)
        {
            <div class="addfunds-alert" role="alert">@errMsg</div>
        }

        <form asp-action="AddFunds" method="post" class="addfunds-form" id="addFundsForm">
            @Html.AntiForgeryToken()

            <div class="addfunds-amount-wrap">
                <span class="addfunds-amount-wrap__sym">₱</span>
                <input type="number"
                       name="amount"
                       id="amountInput"
                       class="addfunds-amount-input"
                       placeholder="0.00"
                       step="0.01"
                       min="1"
                       max="50000"
                       required
                       autocomplete="off" />
            </div>

            @* Quick-select amounts *@
            <div class="addfunds-quick">
                @foreach (var preset in new[] { 500, 1000, 2000, 5000 })
                {
                    <button type="button"
                            class="addfunds-quick__btn"
                            data-amount="@preset">
                        ₱@preset.ToString("N0")
                    </button>
                }
            </div>

            <button type="submit" class="btn btn--primary addfunds-submit" id="addFundsBtn">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
                Add Funds to Wallet
            </button>
        </form>

        @* ── Future gateway placeholders ──────────────────────────────────── *@
        <div class="addfunds-methods">
            <p class="addfunds-methods__label">Payment methods coming soon</p>
            <div class="addfunds-methods__logos">
                <span class="addfunds-method-pill">GCash</span>
                <span class="addfunds-method-pill">Maya</span>
                <span class="addfunds-method-pill">Bank Transfer</span>
                <span class="addfunds-method-pill">Credit Card</span>
            </div>
        </div>

    </div>

</div>

@section Scripts {
    <style>
        .addfunds-shell {
            max-width: 480px;
            margin: 2rem auto 4rem;
        }

        .addfunds-card {
            background: var(--color-surface, #faf8f5);
            border: 1px solid var(--color-border, #e2ddd6);
            border-radius: 16px;
            padding: 2.5rem 2rem;
            text-align: center;
        }

        .addfunds-card__icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: color-mix(in srgb, var(--color-primary, #2d5a27) 10%, transparent);
            color: var(--color-primary, #2d5a27);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
        }

        .addfunds-card__title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.75rem;
            color: var(--color-text, #1a1814);
            margin: 0 0 0.5rem;
        }

        .addfunds-card__subtitle {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            color: var(--color-muted, #8a8278);
            margin: 0 0 1.5rem;
            line-height: 1.55;
        }

        .addfunds-demo-notice {
            display: flex;
            align-items: flex-start;
            gap: 0.625rem;
            background: color-mix(in srgb, #2563eb 8%, transparent);
            border: 1px solid color-mix(in srgb, #2563eb 20%, transparent);
            border-radius: 8px;
            padding: 0.875rem 1rem;
            text-align: left;
            margin-bottom: 1.5rem;
            color: #1d4ed8;
        }

            .addfunds-demo-notice svg {
                flex-shrink: 0;
                margin-top: 2px;
            }

            .addfunds-demo-notice p {
                font-family: 'DM Sans', sans-serif;
                font-size: 0.8125rem;
                margin: 0;
                line-height: 1.55;
                color: #1d4ed8;
            }

        .addfunds-alert {
            background: color-mix(in srgb, #dc2626 8%, transparent);
            border: 1px solid color-mix(in srgb, #dc2626 20%, transparent);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            color: #b91c1c;
            margin-bottom: 1rem;
        }

        .addfunds-form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .addfunds-amount-wrap {
            display: flex;
            align-items: center;
            border: 1.5px solid var(--color-border, #e2ddd6);
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
            transition: border-color 0.15s;
        }

            .addfunds-amount-wrap:focus-within {
                border-color: var(--color-primary, #2d5a27);
            }

        .addfunds-amount-wrap__sym {
            padding: 0 0.875rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 1.1rem;
            color: var(--color-muted, #8a8278);
            border-right: 1.5px solid var(--color-border, #e2ddd6);
        }

        .addfunds-amount-input {
            flex: 1;
            border: none;
            outline: none;
            padding: 0.875rem;
            font-family: 'DM Serif Display', serif;
            font-size: 1.5rem;
            color: var(--color-text, #1a1814);
            background: transparent;
            width: 100%;
        }

        .addfunds-quick {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .addfunds-quick__btn {
            padding: 0.4rem 0.875rem;
            border: 1.5px solid var(--color-border, #e2ddd6);
            border-radius: 6px;
            background: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--color-text, #1a1814);
            cursor: pointer;
            transition: border-color 0.15s, background 0.15s;
        }

            .addfunds-quick__btn:hover,
            .addfunds-quick__btn--active {
                border-color: var(--color-primary, #2d5a27);
                background: color-mix(in srgb, var(--color-primary, #2d5a27) 6%, transparent);
                color: var(--color-primary, #2d5a27);
            }

        .addfunds-submit {
            width: 100%;
            justify-content: center;
        }

        .addfunds-methods {
            margin-top: 2rem;
        }

        .addfunds-methods__label {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.78rem;
            color: var(--color-muted, #8a8278);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin: 0 0 0.625rem;
        }

        .addfunds-methods__logos {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .addfunds-method-pill {
            padding: 0.3rem 0.75rem;
            border: 1px solid var(--color-border, #e2ddd6);
            border-radius: 99px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.78rem;
            color: var(--color-muted, #8a8278);
            opacity: 0.65;
        }
    </style>

    <script>
        (function () {
            'use strict';

            var input   = document.getElementById('amountInput');
            var form    = document.getElementById('addFundsForm');
            var btn     = document.getElementById('addFundsBtn');
            var presets = document.querySelectorAll('.addfunds-quick__btn');

            presets.forEach(function (p) {
                p.addEventListener('click', function () {
                    if (!input) return;
                    input.value = p.dataset.amount;
                    presets.forEach(function (b) { b.classList.remove('addfunds-quick__btn--active'); });
                    p.classList.add('addfunds-quick__btn--active');
                });
            });

            if (input) {
                input.addEventListener('input', function () {
                    presets.forEach(function (b) { b.classList.remove('addfunds-quick__btn--active'); });
                    presets.forEach(function (b) {
                        if (b.dataset.amount === input.value) b.classList.add('addfunds-quick__btn--active');
                    });
                });
            }

            if (form && btn) {
                form.addEventListener('submit', function () {
                    btn.disabled = true;
                    btn.textContent = 'Processing…';
                });
            }
        }());
    </script>
}
