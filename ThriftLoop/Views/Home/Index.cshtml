@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "shopper";
}

@* The navbar (with the sign-out button) is rendered by _Layout / _Navbar.
   This view only contains the page body content. *@

<div class="home-shell">
    <div class="welcome-card">
        <span class="welcome-card__badge">✓ Authenticated</span>
        <h1 class="welcome-card__title">You're in, @userEmail.Split('@')[0]!</h1>
        <p class="welcome-card__body">
            Your ThriftLoop account is set up and ready.<br>
            Start browsing second-hand finds curated just for you.
        </p>
        <a href="#" class="btn btn--primary" style="display:inline-flex;width:auto;padding:.75rem 2rem;">
            Explore listings
            <svg viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
        </a>
    </div>
</div>
