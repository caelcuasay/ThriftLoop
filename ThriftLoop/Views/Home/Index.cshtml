@model ThriftLoop.ViewModels.HomeIndexViewModel
@using ThriftLoop.Models
@using ThriftLoop.ViewModels
@using System.Text.Json
@using ThriftLoop.Enums
@{
    ViewData["Title"] = "For You";
    Layout = null;

    var maxPrice = Model.Items.Any() ? (int)Math.Ceiling((double)Model.Items.Max(i => i.Price)) : 100000;
    ViewBag.MaxPrice = maxPrice;

    // Helper to get location preview - skip last 3 parts, if 4+ remain skip first part
    string GetLocationPreview(string? address)
    {
        if (string.IsNullOrWhiteSpace(address))
            return "Unknown";

        var parts = address.Split(',', StringSplitOptions.RemoveEmptyEntries)
                           .Select(p => p.Trim())
                           .Where(p => !string.IsNullOrWhiteSpace(p))
                           .ToList();

        if (parts.Count <= 3)
            return address.Trim(); // Too short, return as-is

        // Skip last 3 parts (country, region, province)
        var remaining = parts.Take(parts.Count - 3).ToList();

        // If 4+ parts remain, skip the first one (street address detail)
        if (remaining.Count >= 4)
            remaining = remaining.Skip(1).ToList();

        return string.Join(", ", remaining);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThriftLoop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Filter.css" asp-append-version="true" />
    <style>
            /* Discount display styles */
            .fy-card__price-section {
                margin-top: 4px;
            }

            .fy-card__original-price {
                font-size: 0.8rem;
                color: var(--color-muted, #9ca3af);
                text-decoration: line-through;
                line-height: 1.3;
            }

            .fy-card__current-price-row {
                display: flex;
                align-items: center;
                gap: 8px;
                flex-wrap: wrap;
            }

            .fy-card__current-price {
                font-size: 1.125rem;
                font-weight: 700;
                color: #1a1814;
                white-space: nowrap;
            }

            .fy-card__discount-badge {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: #fee2e2;
                color: #b91c1c;
                font-size: 0.7rem;
                font-weight: 600;
                padding: 3px 8px;
                border-radius: 20px;
                line-height: 1;
                white-space: nowrap;
                flex-shrink: 0;
            }

            .fy-card__discount-expiry {
                display: flex;
                align-items: center;
                gap: 4px;
                margin-top: 4px;
                font-size: 0.7rem;
                color: #b91c1c;
                font-weight: 500;
            }

                .fy-card__discount-expiry svg {
                    flex-shrink: 0;
                }

            /* Shop card specific - dynamic font scaling to fit on one line */
            .fy-card--shop .fy-card__price-section {
                overflow: hidden;
            }

            .fy-card--shop .fy-card__original-price {
                white-space: nowrap;
            }

            .fy-card--shop .fy-card__current-price-row {
                flex-wrap: nowrap;
                align-items: baseline;
            }

            .fy-card--shop .fy-card__current-price {
                white-space: nowrap;
                flex-shrink: 1;
                min-width: 0;
                /* Dynamic font scaling - shrinks text to fit container */
                font-size: clamp(0.8rem, 4vw, 1.125rem);
            }

                /* For price ranges that are long, scale down further */
                .fy-card--shop .fy-card__current-price[data-long-price="true"] {
                    font-size: clamp(0.7rem, 3.5vw, 1rem);
                }

            /* Sold items - muted discount display */
            .fy-card--sold .fy-card__current-price {
                color: var(--color-muted, #6b6560);
            }

            .fy-card--sold .fy-card__discount-badge {
                background: #e5e7eb;
                color: #6b7280;
            }

            .fy-card--sold .fy-card__discount-expiry {
                color: #9ca3af;
            }

            /* Location display */
            .fy-card__top {
                display: flex;
                align-items: center;
                gap: 8px;
                flex-wrap: wrap;
            }

            .fy-card__location-row {
                margin-top: 8px;
                display: flex;
                align-items: center;
            }

            .fy-card__location {
                font-size: 0.75rem;
                color: var(--color-muted, #6b6560);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                max-width: 100%;
            }

            .fy-card__category {
                font-size: 0.75rem;
                color: var(--color-primary, #6d4c3d);
                font-weight: 500;
            }

            .fy-card__date {
                font-size: 0.75rem;
                color: var(--color-muted, #9ca3af);
                margin-left: auto;
            }
    </style>
</head>
<body>
    @await Html.PartialAsync("_Navbar")
    @await Html.PartialAsync("_Filter")

    <div class="container">
        <main class="fy-main" id="fyMain">
            <header class="fy-feed-header">
                <h1 class="fy-feed-title">For You</h1>
                <p class="fy-feed-meta" id="feedMeta">
                    <span id="visibleCount">@Model.Items.Count</span>&nbsp;listings
                </p>
            </header>

            @if (!Model.Items.Any())
            {
                <div class="fy-empty" id="globalEmpty">
                    <div class="fy-empty__icon" aria-hidden="true">
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4">
                            <rect x="8" y="14" width="48" height="36" rx="6" />
                            <path d="M22 14v-4a6 6 0 0112 0v4" stroke-linecap="round" />
                            <path d="M24 33h16M32 25v16" stroke-linecap="round" />
                        </svg>
                    </div>
                    <h2 class="fy-empty__title">Nothing listed yet</h2>
                    <p class="fy-empty__body">Be the first to post an item.</p>
                    <a asp-action="Create" asp-controller="Items" class="btn btn--primary fy-empty__cta">
                        Post an item
                    </a>
                </div>
            }
            else
            {
                <div class="fy-empty fy-empty--hidden" id="filterEmpty" aria-live="polite">
                    <div class="fy-empty__icon" aria-hidden="true">
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4">
                            <circle cx="28" cy="28" r="18" />
                            <path d="M42 42l14 14" stroke-linecap="round" />
                            <path d="M22 28h12M28 22v16" stroke-linecap="round" />
                        </svg>
                    </div>
                    <h2 class="fy-empty__title">No matches</h2>
                    <p class="fy-empty__body">Try adjusting or clearing your filters.</p>
                    <button type="button" class="fy-empty__reset-btn" id="resetFilters2">
                        Clear filters
                    </button>
                </div>

                <div class="fy-grid" id="itemGrid">
                    @foreach (var item in Model.Items)
                    {
                        var isOwner = Model.CurrentUserId.HasValue && item.UserId == Model.CurrentUserId.Value;
                        var isStealable = item.ListingType == ListingType.Stealable;
                        var isReserved = item.Status == ItemStatus.Reserved;
                        var isSold = item.Status == ItemStatus.Sold;
                        var isShopItem = item.ShopId.HasValue;
                        var hasDiscount = item.HasActiveDiscount;
                        var imagesJson = JsonSerializer.Serialize(item.ImageUrls);

                        // Calculate expiry text
                        string? expiryText = null;
                        if (hasDiscount && item.DiscountExpiresAt.HasValue)
                        {
                            var timeLeft = item.DiscountExpiresAt.Value - DateTime.UtcNow;
                            if (timeLeft.TotalDays >= 1)
                            {
                                var days = (int)timeLeft.TotalDays;
                                expiryText = $"{days}d left";
                            }
                            else if (timeLeft.TotalHours >= 1)
                            {
                                var hours = (int)timeLeft.TotalHours;
                                expiryText = $"{hours}h left";
                            }
                            else if (timeLeft.TotalMinutes > 0)
                            {
                                var mins = (int)timeLeft.TotalMinutes;
                                expiryText = $"{mins}m left";
                            }
                        }

                        // Get price display string (without "From" prefix since we'll add it separately)
                        var priceDisplay = Model.ShopItemPriceDisplay.ContainsKey(item.Id)
                            ? Model.ShopItemPriceDisplay[item.Id]
                            : "₱" + item.Price.ToString("N2");
                        
                        // Check if price string is long (more than 15 chars)
                        var isLongPrice = priceDisplay.Length > 15;

                        <article class="fy-card @(isSold ? "fy-card--sold" : "") @(isShopItem ? "fy-card--shop" : "")"
                                 data-category="@item.Category"
                                 data-condition="@item.Condition"
                                 data-price="@item.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                 data-title="@item.Title.ToLower()"
                                 data-desc="@item.Description.ToLower()">

                            <div class="fy-card__img-wrap" data-images="@imagesJson">
                                @if (item.ImageUrls.Count > 0)
                                {
                                    <img src="@item.ImageUrls[0]" alt="@item.Title" class="fy-card__img" loading="lazy" />
                                    @if (item.ImageUrls.Count > 1)
                                    {
                                        <div class="fy-card__dots" aria-hidden="true">
                                            @for (int d = 0; d < item.ImageUrls.Count; d++)
                                            {
                                                <span class="fy-card__dot @(d == 0 ? "fy-card__dot--active" : "")"></span>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="fy-card__img fy-card__img--placeholder" aria-hidden="true">
                                        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4">
                                            <rect x="4" y="8" width="40" height="32" rx="4" />
                                            <circle cx="17" cy="20" r="4" />
                                            <path d="M4 36l12-10 8 8 6-5 14 11" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                    </div>
                                }

                                <span class="fy-card__condition-badge">@item.Condition</span>

                                @if (isStealable)
                                {
                                    <span class="fy-card__stealable-badge" aria-label="Stealable listing">
                                        @if (isReserved)
                                        {
                                            <span>Reserved</span>
                                        }
                                        else if (isSold)
                                        {
                                            <span>Sold</span>
                                        }
                                        else
                                        {
                                            <span>Stealable</span>
                                        }
                                    </span>
                                }

                                @if (isShopItem)
                                {
                                    <span class="fy-card__shop-badge" aria-label="Shop listing">Shop</span>
                                }
                            </div>

                            <div class="fy-card__body">
                                <div class="fy-card__top">
                                    <span class="fy-card__category">@item.Category</span>
                                    <span class="fy-card__date">@item.CreatedAt.ToString("MMM d")</span>
                                </div>

                                <div class="fy-card__title-row">
                                    <h2 class="fy-card__title">@item.Title</h2>
                                    @if (!isShopItem)
                                    {
                                        var isLiked = Model.LikedItemIds.Contains(item.Id);
                                        var likeCount = Model.LikeCounts.GetValueOrDefault(item.Id, 0);
                                        <button type="button" class="fy-like-btn @(isLiked ? "fy-like-btn--liked" : "")" data-item-id="@item.Id" data-like-count="@likeCount" aria-label="Like item">
                                            <svg class="fy-like-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
                                            </svg>
                                            @if (likeCount > 0)
                                            {
                                                <span class="fy-like-btn__count">@likeCount</span>
                                            }
                                        </button>
                                    }
                                </div>

                                @* ── PRICE DISPLAY SECTION ─────────────────────────────────────────── *@
                                <div class="fy-card__price-section">
                                    @if (isShopItem)
                                    {
                                        @* SHOP ITEM: Show "From" on original price only, current price shows just the range *@
                                        @if (hasDiscount)
                                        {
                                            <div class="fy-card__original-price">
                                                From ₱@(item.OriginalPrice?.ToString("N2"))
                                            </div>
                                            <div class="fy-card__current-price-row">
                                                <span class="fy-card__current-price" @(isLongPrice ? "data-long-price=true" : "")>
                                                    @priceDisplay
                                                </span>
                                                <span class="fy-card__discount-badge">
                                                    -@(item.DiscountPercentage?.ToString("F0"))%
                                                </span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(expiryText))
                                            {
                                                <div class="fy-card__discount-expiry">
                                                    <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11">
                                                        <path d="M8 15A7 7 0 108 1a7 7 0 000 14zm.75-10.25a.75.75 0 00-1.5 0v4a.75.75 0 001.5 0v-4zM8 13a1 1 0 100-2 1 1 0 000 2z" />
                                                    </svg>
                                                    @expiryText
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="fy-card__current-price-row">
                                                <span class="fy-card__current-price" @(isLongPrice ? "data-long-price=true" : "")>
                                                    @priceDisplay
                                                </span>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        @* P2P ITEM: Show original price strikethrough + discounted price *@
                                        @if (hasDiscount)
                                        {
                                            <div class="fy-card__original-price">
                                                ₱@(item.OriginalPrice?.ToString("N2"))
                                            </div>
                                            <div class="fy-card__current-price-row">
                                                <span class="fy-card__current-price">₱@item.Price.ToString("N2")</span>
                                                <span class="fy-card__discount-badge">-@(item.DiscountPercentage?.ToString("F0"))%</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(expiryText))
                                            {
                                                <div class="fy-card__discount-expiry">
                                                    <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11">
                                                        <path d="M8 15A7 7 0 108 1a7 7 0 000 14zm.75-10.25a.75.75 0 00-1.5 0v4a.75.75 0 001.5 0v-4zM8 13a1 1 0 100-2 1 1 0 000 2z" />
                                                    </svg>
                                                    @expiryText
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="fy-card__current-price-row">
                                                <span class="fy-card__current-price">₱@item.Price.ToString("N2")</span>
                                            </div>
                                        }
                                    }
                                </div>
                                @* ── LOCATION DISPLAY SECTION ───────────────────────────────────────── *@
                                @{
                                    var locationAddress = isShopItem
                                        ? item.Shop?.StoreAddress
                                        : item.User?.Address;
                                    var locationPreview = GetLocationPreview(locationAddress);
                                }
                                <div class="fy-card__location-row">
                                    <span class="fy-card__location" title="@(isShopItem ? item.Shop?.StoreAddress : item.User?.Address)">
                                        @locationPreview
                                    </span>
                                </div>
                            </div>

                            @if (isOwner)
                            {
                                <div class="fy-card__actions fy-card__actions--owner">
                                    @if (isShopItem)
                                    {
                                        <a asp-action="Edit" asp-controller="Shop" asp-route-id="@item.Id" class="fy-btn fy-btn--manage">
                                            Manage listing
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="Edit" asp-controller="Items" asp-route-id="@item.Id" class="fy-btn fy-btn--manage">
                                            Manage listing
                                        </a>
                                    }
                                </div>
                            }

                            @* Link to appropriate details page *@
                            @if (isShopItem)
                            {
                                <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.Id" class="fy-card__link" aria-label="View details for @item.Title"></a>
                            }
                            else
                            {
                                <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Id" class="fy-card__link" aria-label="View details for @item.Title"></a>
                            }
                        </article>
                    }
                </div>
            }
        </main>
    </div>

    <script>
            (function() {
                var grid = document.getElementById('itemGrid');
                var filterEmpty = document.getElementById('filterEmpty');
                var visibleCount = document.getElementById('visibleCount');

                if (!grid && !filterEmpty) return;

                if (grid) {
                    var cards = Array.prototype.slice.call(grid.querySelectorAll('.fy-card'));

                    // Multi-image hover cycling
                    cards.forEach(function(card) {
                        var wrap = card.querySelector('.fy-card__img-wrap');
                        var img = card.querySelector('.fy-card__img');
                        var dotsEl = card.querySelector('.fy-card__dots');

                        if (!wrap || !img) return;

                        var raw = wrap.getAttribute('data-images');
                        var images = [];
                        try { images = JSON.parse(raw); } catch (e) { }
                        if (images.length < 2) return;

                        var dots = dotsEl ? Array.prototype.slice.call(dotsEl.querySelectorAll('.fy-card__dot')) : [];
                        var current = 0;
                        var timer = null;

                        function goTo(idx) {
                            img.classList.add('fy-img--fading');
                            setTimeout(function() {
                                img.src = images[idx];
                                img.classList.remove('fy-img--fading');
                            }, 220);
                            dots.forEach(function(d, i) {
                                d.classList.toggle('fy-card__dot--active', i === idx);
                            });
                            current = idx;
                        }

                        card.addEventListener('mouseenter', function() {
                            if (timer) return;
                            timer = setInterval(function() { goTo((current + 1) % images.length); }, 900);
                        });
                        card.addEventListener('mouseleave', function() {
                            if (timer) { clearInterval(timer); timer = null; }
                            if (current !== 0) goTo(0);
                        });
                    });

                    // Filter callback
                    window.applyFiltersCallback = function(state) {
                        var query = state.search.toLowerCase();
                        var minVal = state.priceMin;
                        var maxVal = state.priceMax;
                        var activeCats = state.categories;
                        var activeConds = state.conditions;

                        var shown = 0;

                        cards.forEach(function(card) {
                            var cat = card.dataset.category;
                            var cond = card.dataset.condition;
                            var price = parseFloat(card.dataset.price);
                            var title = card.dataset.title || '';
                            var desc = card.dataset.desc || '';

                            var catOk = activeCats.length === 0 || activeCats.indexOf(cat) !== -1;
                            var condOk = activeConds.length === 0 || activeConds.indexOf(cond) !== -1;
                            var priceOk = price >= minVal && price <= maxVal;
                            var textOk = !query || title.indexOf(query) !== -1 || desc.indexOf(query) !== -1;

                            var visible = catOk && condOk && priceOk && textOk;
                            card.classList.toggle('fy-card--hidden', !visible);
                            if (visible) shown++;
                        });

                        if (visibleCount) visibleCount.textContent = shown;
                        if (filterEmpty) filterEmpty.classList.toggle('fy-empty--hidden', shown > 0);
                    };
                }

                // Reset button inside empty state
                var resetBtn2 = document.getElementById('resetFilters2');
                if (resetBtn2) {
                    resetBtn2.addEventListener('click', function() {
                        if (window.resetFiltersFromPartial) {
                            window.resetFiltersFromPartial();
                        }
                    });
                }

                // Like button click handler
                document.querySelectorAll('.fy-like-btn').forEach(function(btn) {
                    btn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();

                        var btn = this;
                        var itemId = btn.dataset.itemId;
                        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                        fetch('/Likes/Toggle', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({ itemId: parseInt(itemId) })
                        })
                        .then(function(res) { return res.json(); })
                        .then(function(data) {
                            if (data.success) {
                                btn.classList.toggle('fy-like-btn--liked', data.isLiked);
                                var countEl = btn.querySelector('.fy-like-btn__count');
                                if (data.likeCount > 0) {
                                    if (countEl) {
                                        countEl.textContent = data.likeCount;
                                    } else {
                                        var newCount = document.createElement('span');
                                        newCount.className = 'fy-like-btn__count';
                                        newCount.textContent = data.likeCount;
                                        btn.appendChild(newCount);
                                    }
                                } else if (countEl) {
                                    countEl.remove();
                                }
                            }
                        })
                        .catch(function(err) {
                            console.error('Like failed:', err);
                        });
                    });
                });
            }());
    </script>
</body>
</html>