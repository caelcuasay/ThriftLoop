@model ThriftLoop.Models.SiteSettings
@{
    ViewData["Title"] = "GCash QR & Account Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="admin-gcash-shell">
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a asp-action="Index" asp-controller="Admin" class="detail-breadcrumb__link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Back to Admin Dashboard
        </a>
    </nav>

    <h1 class="admin-gcash__title">GCash QR & Account Management</h1>
    <p class="admin-gcash__subtitle">
        Upload the GCash QR code and set the account number for receipt validation.
    </p>

    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div class="admin-alert admin-alert--success" role="alert">@successMsg</div>
    }
    @if (TempData["ErrorMessage"] is string errorMsg)
    {
        <div class="admin-alert admin-alert--error" role="alert">@errorMsg</div>
    }

    <div class="admin-gcash-card">
        <h2 class="admin-gcash-card__title">Current QR Code</h2>

        @if (Model?.GCashQRCodePath != null)
        {
            <div class="admin-gcash-current">
                <img src="@Model.GCashQRCodePath" alt="Current GCash QR Code" class="admin-gcash-qr" />
                <div class="admin-gcash-meta">
                    <p><strong>Uploaded:</strong> @(Model.QRCodeUpdatedAt?.ToString("MMM dd, yyyy HH:mm") ?? "Unknown")</p>
                    <form asp-action="RemoveGCashQR" method="post" class="admin-gcash-remove-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn--danger" onclick="return confirm('Remove this QR code? Users will not be able to top up until a new one is uploaded.');">
                            Remove QR Code
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="admin-gcash-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <path d="M21 15l-5-5L5 21" />
                </svg>
                <p>No QR code uploaded yet.</p>
                <p class="admin-gcash-empty__hint">Users will see a message to contact admin until a QR is uploaded.</p>
            </div>
        }
    </div>

    <div class="admin-gcash-card">
        <h2 class="admin-gcash-card__title">Upload New QR Code</h2>

        <form asp-action="UploadGCashQR" method="post" enctype="multipart/form-data" class="admin-gcash-form">
            @Html.AntiForgeryToken()

            <div class="admin-form-group">
                <label for="qrImage" class="admin-form-label">QR Code Image</label>
                <input type="file"
                       id="qrImage"
                       name="qrImage"
                       class="admin-form-file"
                       accept="image/png,image/jpeg,image/jpg"
                       required />
                <span class="admin-form-hint">PNG or JPEG, max 2MB</span>
            </div>

            <div class="admin-gcash-preview" id="previewContainer" style="display: none;">
                <p>Preview:</p>
                <img id="previewImage" alt="QR Preview" />
            </div>

            <button type="submit" class="btn btn--primary">Upload QR Code</button>
        </form>
    </div>

    <div class="admin-gcash-card">
        <h2 class="admin-gcash-card__title">GCash Account Number</h2>
        <p class="admin-gcash-card__desc">
            Enter the GCash number that receipts must match for validation.
            <strong class="admin-gcash-card__highlight">Leave blank to skip account number validation.</strong>
        </p>

        @if (!string.IsNullOrEmpty(Model?.GCashAccountNumber))
        {
            <div class="admin-gcash-current">
                <div class="admin-gcash-account-display">
                    <span class="admin-gcash-account-label">Current Account Number:</span>
                    <code class="admin-gcash-account-number">@Model.GCashAccountNumber</code>
                    <span class="admin-gcash-account-meta">
                        Updated: @(Model.AccountNumberUpdatedAt?.ToString("MMM dd, yyyy HH:mm") ?? "Unknown")
                    </span>
                </div>
            </div>
        }
        else
        {
            <div class="admin-gcash-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                    <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <p>No account number set.</p>
                <p class="admin-gcash-empty__hint">Add a GCash number to enable automatic validation.</p>
            </div>
        }

        <form asp-action="UpdateGCashAccountNumber" method="post" class="admin-gcash-form">
            @Html.AntiForgeryToken()

            <div class="admin-form-group">
                <label for="accountNumber" class="admin-form-label">GCash Account Number</label>
                <input type="tel"
                       id="accountNumber"
                       name="accountNumber"
                       class="admin-form-input"
                       placeholder="e.g., 09123456789"
                       pattern="^(09|\+639)\d{9}$"
                       title="Enter a valid 11-digit Philippine mobile number"
                       value="@Model?.GCashAccountNumber" />
                <span class="admin-form-hint">Enter the 11-digit GCash number (e.g., 09123456789)</span>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="btn btn--primary">Save Account Number</button>
                @if (!string.IsNullOrEmpty(Model?.GCashAccountNumber))
                {
                    <button type="button" class="btn btn--ghost" id="clearAccountNumberBtn" onclick="clearAccountNumber()">Clear</button>
                }
            </div>
        </form>
        
        @if (!string.IsNullOrEmpty(Model?.GCashAccountNumber))
        {
            <form id="clearAccountNumberForm" asp-action="UpdateGCashAccountNumber" method="post" style="display: none;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="accountNumber" value="" />
            </form>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Admin.css" asp-append-version="true" />
    <style>
        .admin-gcash-card__desc {
            font-size: 0.85rem;
            color: var(--admin-muted, #4b4b63);
            margin-bottom: 1.25rem;
            line-height: 1.5;
        }
        
        .admin-gcash-card__highlight {
            display: block;
            margin-top: 0.5rem;
            color: var(--admin-primary, #2d1b69);
            font-weight: 500;
        }
        
        .admin-gcash-account-display {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .admin-gcash-account-label {
            font-size: 0.8rem;
            color: #6b7280;
            font-weight: 500;
        }
        
        .admin-gcash-account-number {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--admin-primary, #2d1b69);
            background: #f3f4f6;
            padding: 0.75rem 1.25rem;
            border-radius: 10px;
            display: inline-block;
            letter-spacing: 1px;
            border: 1px solid #e5e7eb;
        }
        
        .admin-gcash-account-meta {
            font-size: 0.7rem;
            color: #9ca3af;
            margin-top: 0.25rem;
        }
        
        .admin-form-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1rem;
        }
        
        .admin-gcash-current {
            margin-bottom: 1.5rem;
        }
    </style>
}

@section Scripts {
    <script>
        (function() {
            const fileInput = document.getElementById('qrImage');
            const previewContainer = document.getElementById('previewContainer');
            const previewImage = document.getElementById('previewImage');

            if (fileInput) {
                fileInput.addEventListener('change', function() {
                    const file = this.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            previewImage.src = e.target.result;
                            previewContainer.style.display = 'block';
                        };
                        reader.readAsDataURL(file);
                    }
                });
            }
        })();
        
        function clearAccountNumber() {
            if (confirm('Clear the GCash account number? Transactions will no longer be validated against a specific account.')) {
                document.getElementById('clearAccountNumberForm').submit();
            }
        }
    </script>
}