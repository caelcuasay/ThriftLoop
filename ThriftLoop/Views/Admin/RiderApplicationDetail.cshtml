<!-- Views/Admin/RiderApplicationDetail.cshtml - Add rejection reason display -->
@model ThriftLoop.Models.Rider
@{
    ViewData["Title"] = "Rider Application Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="admin-approvals">
    <div class="admin-header">
        <div>
            <div class="admin-header__back">
                <a asp-action="RiderApprovals" class="back-link">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                        <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
                    </svg>
                    Back to Rider Approvals
                </a>
            </div>
            <h1>Rider Application Details</h1>
            <p>Review the applicant's information before making a decision.</p>
        </div>
    </div>

    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="alert alert--error">@errMsg</div>
    }

    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div class="alert alert--success">@successMsg</div>
    }

    <div class="application-detail-grid">
        <!-- Personal Information Card -->
        <div class="detail-card">
            <div class="detail-card__header">
                <h2>Personal Information</h2>
            </div>
            <div class="detail-card__body">
                <div class="detail-row">
                    <div class="detail-label">Full Name</div>
                    <div class="detail-value">@(Model.FullName ?? "—")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Email Address</div>
                    <div class="detail-value">@Model.Email</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Phone Number</div>
                    <div class="detail-value">@(Model.PhoneNumber ?? "—")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Home Address</div>
                    <div class="detail-value">@(Model.Address ?? "—")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Applied On</div>
                    <div class="detail-value">@Model.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</div>
                </div>

                @if (Model.RejectedAt.HasValue)
                {
                    <div class="detail-row">
                        <div class="detail-label">Rejected On</div>
                        <div class="detail-value">@Model.RejectedAt.Value.ToString("MMMM d, yyyy 'at' h:mm tt")</div>
                    </div>
                }

                @if (Model.ResubmittedAt.HasValue)
                {
                    <div class="detail-row">
                        <div class="detail-label">Resubmitted On</div>
                        <div class="detail-value">@Model.ResubmittedAt.Value.ToString("MMMM d, yyyy 'at' h:mm tt")</div>
                    </div>
                }
            </div>
        </div>

        <!-- Vehicle Information Card -->
        <div class="detail-card">
            <div class="detail-card__header">
                <h2>Vehicle Information</h2>
            </div>
            <div class="detail-card__body">
                <div class="detail-row">
                    <div class="detail-label">Vehicle Type</div>
                    <div class="detail-value">@(Model.VehicleType ?? "—")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Vehicle Color</div>
                    <div class="detail-value">@(Model.VehicleColor ?? "—")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">License Plate</div>
                    <div class="detail-value">@(Model.LicensePlate ?? "—")</div>
                </div>
            </div>
        </div>

        <!-- Driver's License Card -->
        <div class="detail-card detail-card--full">
            <div class="detail-card__header">
                <h2>Driver's License</h2>
            </div>
            <div class="detail-card__body">
                @if (!string.IsNullOrEmpty(Model.DriversLicense))
                {
                    <div class="license-preview">
                        <img src="@Model.DriversLicense" alt="Driver's License Photo" class="license-image" />
                        <p class="license-caption">Submitted license photo (click to enlarge)</p>
                    </div>
                }
                else
                {
                    <p class="text-muted">No license photo uploaded.</p>
                }
            </div>
        </div>

        <!-- NEW: Rejection Information Card (only shown if rejected) -->
        @if (!Model.IsApproved && !string.IsNullOrEmpty(Model.RejectionReason))
        {
            <div class="detail-card detail-card--full" style="border-color: #fecaca;">
                <div class="detail-card__header" style="background-color: #fef2f2;">
                    <h2 style="color: #991b1b;">Rejection Information</h2>
                </div>
                <div class="detail-card__body">
                    <div class="detail-row">
                        <div class="detail-label">Rejection Reason</div>
                        <div class="detail-value" style="color: #dc2626; font-weight: 500;">
                            @Model.RejectionReason
                        </div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label">Status</div>
                        <div class="detail-value">
                            <span class="status-badge status-rejected">Rejected - Needs Revision</span>
                        </div>
                    </div>
                    <div class="alert alert--info" style="margin-top: 1rem; background-color: #eff6ff; color: #1e40af; padding: 0.75rem; border-radius: 0.5rem;">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" style="display: inline-block; vertical-align: middle;">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                        </svg>
                        <span style="margin-left: 0.5rem;">This application was rejected. The rider can edit and resubmit.</span>
                    </div>
                </div>
            </div>
        }

        <!-- NEW: Resubmission Information Card -->
        @if (Model.UpdatedAt.HasValue && Model.UpdatedAt.Value > Model.CreatedAt && !Model.IsApproved)
        {
            <div class="detail-card detail-card--full" style="border-color: #fde68a;">
                <div class="detail-card__header" style="background-color: #fffbeb;">
                    <h2 style="color: #92400e;">Application Resubmitted</h2>
                </div>
                <div class="detail-card__body">
                    <div class="detail-row">
                        <div class="detail-label">Resubmitted On</div>
                        <div class="detail-value">@Model.UpdatedAt.Value.ToString("MMMM d, yyyy 'at' h:mm tt")</div>
                    </div>
                    <div class="alert alert--warning" style="margin-top: 1rem; background-color: #fef3c7; color: #92400e; padding: 0.75rem; border-radius: 0.5rem;">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" style="display: inline-block; vertical-align: middle;">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                        </svg>
                        <span style="margin-left: 0.5rem;">This application has been resubmitted after rejection. Please review the updated information.</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Application Status & Actions -->
    <div class="application-actions">
        <div class="status-section">
            <div class="detail-row">
                <div class="detail-label">Current Status</div>
                <div class="detail-value">
                    @if (Model.IsApproved)
                    {
                        <span class="status-badge status-approved">Approved</span>
                    }
                    else if (!string.IsNullOrEmpty(Model.RejectionReason))
                    {
                        <span class="status-badge status-rejected">Rejected - Needs Revision</span>
                    }
                    else
                    {
                        <span class="status-badge status-pending">Pending Review</span>
                    }
                </div>
            </div>
        </div>

        @if (!Model.IsApproved)
        {
            <div class="action-buttons">
                <form method="post" asp-action="ApproveRider" class="action-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="riderId" value="@Model.Id" />
                    <button type="submit" class="btn btn--approve" onclick="return confirm('Approve @Model.FullName as a rider? This will allow them to accept delivery jobs.')">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                        </svg>
                        Approve Rider
                    </button>
                </form>
                <a asp-action="RejectRiderWithReason" asp-route-id="@Model.Id" class="btn btn--reject">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                    Reject Application
                </a>
                <a asp-action="RiderApprovals" class="btn btn--secondary">Cancel</a>
            </div>
        }
        else
        {
            <div class="already-approved">
                <p>This rider has already been approved.</p>
                <a asp-action="RiderApprovals" class="btn btn--secondary">Back to Approvals</a>
            </div>
        }
    </div>
</div>

<style>
    .admin-header__back {
        margin-bottom: 1rem;
    }
    
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #6b7280;
        text-decoration: none;
        font-size: 0.875rem;
    }
    
    .back-link:hover {
        color: #374151;
    }
    
    .alert {
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
    }
    
    .alert--success {
        background-color: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }
    
    .alert--error {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }
    
    .alert--info {
        background-color: #eff6ff;
        color: #1e40af;
        border: 1px solid #bfdbfe;
    }
    
    .alert--warning {
        background-color: #fef3c7;
        color: #92400e;
        border: 1px solid #fde68a;
    }
    
    .application-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .detail-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        overflow: hidden;
    }
    
    .detail-card--full {
        grid-column: span 2;
    }
    
    .detail-card__header {
        padding: 1rem 1.5rem;
        background-color: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
    }
    
    .detail-card__header h2 {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 0;
        color: #111827;
    }
    
    .detail-card__body {
        padding: 1.5rem;
    }
    
    .detail-row {
        display: flex;
        padding: 0.75rem 0;
        border-bottom: 1px solid #f3f4f6;
    }
    
    .detail-row:last-child {
        border-bottom: none;
    }
    
    .detail-label {
        width: 140px;
        flex-shrink: 0;
        font-weight: 500;
        color: #6b7280;
        font-size: 0.875rem;
    }
    
    .detail-value {
        flex: 1;
        color: #111827;
        font-size: 0.875rem;
        word-break: break-word;
    }
    
    .license-preview {
        text-align: center;
    }
    
    .license-image {
        max-width: 100%;
        max-height: 400px;
        border-radius: 0.5rem;
        border: 1px solid #e5e7eb;
        cursor: pointer;
        transition: transform 0.2s;
    }
    
    .license-image:hover {
        transform: scale(1.02);
    }
    
    .license-caption {
        font-size: 0.75rem;
        color: #9ca3af;
        margin-top: 0.5rem;
    }
    
    .text-muted {
        color: #9ca3af;
        font-size: 0.875rem;
    }
    
    .application-actions {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1.5rem;
    }
    
    .status-section {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e5e7eb;
    }
    
    .action-buttons {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }
    
    .action-form {
        margin: 0;
        padding: 0;
    }
    
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 500;
        font-size: 0.875rem;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: all 0.2s;
    }
    
    .btn--approve {
        background-color: #059669;
        color: white;
    }
    
    .btn--approve:hover {
        background-color: #047857;
    }
    
    .btn--reject {
        background-color: #dc2626;
        color: white;
    }
    
    .btn--reject:hover {
        background-color: #b91c1c;
    }
    
    .btn--secondary {
        background-color: #f3f4f6;
        color: #374151;
        border: 1px solid #d1d5db;
    }
    
    .btn--secondary:hover {
        background-color: #e5e7eb;
    }
    
    .already-approved {
        text-align: center;
        padding: 1rem;
    }
    
    .already-approved p {
        color: #059669;
        margin-bottom: 1rem;
    }
    
    .status-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 500;
    }
    
    .status-approved {
        background-color: #d1fae5;
        color: #065f46;
    }
    
    .status-pending {
        background-color: #fef3c7;
        color: #92400e;
    }
    
    .status-rejected {
        background-color: #fee2e2;
        color: #991b1b;
    }
    
    @@media (max-width: 768px) {
        .application-detail-grid {
            grid-template-columns: 1fr;
        }
        
        .detail-card--full {
            grid-column: span 1;
        }
        
        .detail-row {
            flex-direction: column;
        }
        
        .detail-label {
            width: auto;
            margin-bottom: 0.25rem;
        }
        
        .action-buttons {
            flex-direction: column;
            align-items: stretch;
        }
        
        .btn {
            justify-content: center;
        }
    }
</style>

<script>
    // Click to enlarge license image
    document.querySelectorAll('.license-image').forEach(img => {
        img.addEventListener('click', function() {
            const modal = document.createElement('div');
            modal.style.position = 'fixed';
            modal.style.top = '0';
            modal.style.left = '0';
            modal.style.width = '100%';
            modal.style.height = '100%';
            modal.style.backgroundColor = 'rgba(0,0,0,0.9)';
            modal.style.zIndex = '9999';
            modal.style.display = 'flex';
            modal.style.alignItems = 'center';
            modal.style.justifyContent = 'center';
            modal.style.cursor = 'pointer';
            
            const enlargedImg = document.createElement('img');
            enlargedImg.src = this.src;
            enlargedImg.style.maxWidth = '90%';
            enlargedImg.style.maxHeight = '90%';
            enlargedImg.style.borderRadius = '0.5rem';
            
            modal.appendChild(enlargedImg);
            modal.addEventListener('click', () => modal.remove());
            document.body.appendChild(modal);
        });
    });
</script>