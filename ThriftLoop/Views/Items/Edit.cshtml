@using ThriftLoop.ViewModels
@model ItemEditViewModel
@{
    ViewData["Title"] = "Edit Listing";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThriftLoop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Items.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Navbar.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("_Navbar")

    <div class="container">
        <div class="create-page">
            <div class="create-header">
                <a asp-action="Index" class="create-header__back">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                        <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Back to listings
                </a>
                <div>
                    <h1 class="create-header__title">Edit Listing</h1>
                    <p class="create-header__subtitle">Update your item's details below.</p>
                </div>
            </div>

            <form asp-action="Edit" asp-controller="Items" method="post" enctype="multipart/form-data" id="editItemForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ExistingImageUrls" id="existingImageUrlsHidden" value='@Json.Serialize(Model.ExistingImageUrls)' />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="create-error-banner" role="alert">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                        </svg>
                        <span>Please correct the errors below.</span>
                    </div>
                }

                <div class="create-grid">
                    @* LEFT COLUMN - Photos *@
                    <div class="create-photo-col">
                        <div class="create-section-label">Current Photos</div>
                        
                        <div class="photo-thumbs" id="existingPhotoThumbs">
                            @foreach (var url in Model.ExistingImageUrls.Select((url, i) => new { url, index = i }))
                            {
                                <div class="photo-thumb" data-url="@url.url" data-index="@url.index">
                                    <img src="@url.url" alt="Existing photo @(url.index + 1)" />
                                    @if (url.index == 0)
                                    {
                                        <span class="photo-thumb__badge">Cover</span>
                                    }
                                    <button type="button" class="photo-thumb__remove" data-url="@url.url" aria-label="Remove photo">×</button>
                                </div>
                            }
                        </div>

                        <div id="removedImagesContainer"></div>

                        <div class="create-section-label" style="margin-top: 20px;">Add More Photos</div>
                        <p class="create-section-hint">You can have up to 5 photos total.</p>

                        <div class="photo-add-zone" id="photoDropzone" tabindex="0" role="button" aria-label="Upload more photos">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true">
                                <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <span class="photo-add-zone__cta">Click or drag more photos</span>
                            <span class="photo-add-zone__hint">JPEG, PNG, WebP · Max 5 MB each</span>
                        </div>

                        <input asp-for="NewImages" type="file" class="photo-input-hidden" id="photoInput" multiple accept="image/jpeg,image/png,image/webp" />

                        <div class="photo-thumbs" id="newPhotoThumbs"></div>
                    </div>

                    @* RIGHT COLUMN - Form fields *@
                    <div class="create-form-col">
                        @* Title *@
                        <div class="create-field">
                            <div class="create-field__top">
                                <label asp-for="Title" class="create-field__label">Title</label>
                                <span class="create-field__counter" id="titleCounter">@(Model.Title?.Length ?? 0)/100</span>
                            </div>
                            <input asp-for="Title" class="create-field__input" id="titleInput" placeholder="e.g., Vintage Levi's 501 Jeans" maxlength="100" />
                            <span asp-validation-for="Title" class="field__error"></span>
                        </div>

                        @* Description *@
                        <div class="create-field">
                            <div class="create-field__top">
                                <label asp-for="Description" class="create-field__label">Description</label>
                                <span class="create-field__counter" id="descCounter">@(Model.Description?.Length ?? 0)/1000</span>
                            </div>
                            <textarea asp-for="Description" class="create-field__input create-field__input--textarea" id="descInput" rows="4" placeholder="Describe your item's condition, brand, measurements, etc." maxlength="1000"></textarea>
                            <span asp-validation-for="Description" class="field__error"></span>
                        </div>

                        @* Price & Size row *@
                        <div class="create-row">
                            <div class="create-field create-field--half">
                                <label asp-for="Price" class="create-field__label">Price (₱)</label>
                                <div class="create-price-wrap">
                                    <span class="create-price-wrap__symbol">₱</span>
                                    <input asp-for="Price" class="create-price-wrap__input" id="priceInput" type="number" step="0.01" min="0.01" max="99999.99" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="field__error"></span>
                            </div>
                            <div class="create-field create-field--half">
                                <div class="create-field__top">
                                    <label asp-for="Size" class="create-field__label">Size</label>
                                    <span class="create-field__optional">Optional</span>
                                </div>
                                <select asp-for="Size" class="create-field__input" id="sizeSelect">
                                    <option value="">-- Select size --</option>
                                    @foreach (var size in ItemEditViewModel.Sizes)
                                    {
                                        <option value="@size" selected="@(Model.Size == size)">@size</option>
                                    }
                                </select>
                                <span asp-validation-for="Size" class="field__error"></span>
                            </div>
                        </div>

                        @* Category *@
                        <div class="create-field">
                            <label asp-for="Category" class="create-field__label">Category</label>
                            <input type="hidden" asp-for="Category" id="categoryHidden" value="@Model.Category" />
                            <div class="create-chips" id="categoryChips" role="radiogroup" aria-label="Select category">
                                @foreach (var category in ItemEditViewModel.Categories)
                                {
                                    <button type="button" class="create-chip @(Model.Category == category ? "create-chip--active" : "")" data-value="@category" role="radio">@category</button>
                                }
                            </div>
                            <span asp-validation-for="Category" class="field__error"></span>
                        </div>

                        @* Condition *@
                        <div class="create-field">
                            <label asp-for="Condition" class="create-field__label">Condition</label>
                            <input type="hidden" asp-for="Condition" id="conditionHidden" value="@Model.Condition" />
                            <div class="create-condition" id="conditionPills" role="radiogroup" aria-label="Select condition">
                                @foreach (var condition in ItemEditViewModel.Conditions)
                                {
                                    <button type="button" class="create-condition__pill @(Model.Condition == condition ? "create-condition__pill--active" : "")" data-value="@condition" role="radio">@condition</button>
                                }
                            </div>
                            <span asp-validation-for="Condition" class="field__error"></span>
                        </div>

                        @* Fulfillment Options *@
                        <div class="create-field">
                            <label class="create-field__label">Fulfillment Options</label>
                            <p class="create-field__hint">Choose how buyers can receive this item. At least one required.</p>
                            
                            <div class="fulfillment-options" id="fulfillmentOptions">
                                <label class="fulfillment-option">
                                    <input type="checkbox" asp-for="AllowDelivery" class="fulfillment-option__checkbox" />
                                    <div class="fulfillment-option__content">
                                        <span class="fulfillment-option__icon">🚚</span>
                                        <div>
                                            <span class="fulfillment-option__title">Rider Delivery</span>
                                            <span class="fulfillment-option__desc">ThriftLoop rider delivers. Buyer pays rider cash.</span>
                                        </div>
                                    </div>
                                </label>
                                <label class="fulfillment-option">
                                    <input type="checkbox" asp-for="AllowHalfway" class="fulfillment-option__checkbox" />
                                    <div class="fulfillment-option__content">
                                        <span class="fulfillment-option__icon">🤝</span>
                                        <div>
                                            <span class="fulfillment-option__title">Halfway Meetup</span>
                                            <span class="fulfillment-option__desc">Meet at agreed location. Chat opens after purchase.</span>
                                        </div>
                                    </div>
                                </label>
                                <label class="fulfillment-option">
                                    <input type="checkbox" asp-for="AllowPickup" class="fulfillment-option__checkbox" />
                                    <div class="fulfillment-option__content">
                                        <span class="fulfillment-option__icon">🏠</span>
                                        <div>
                                            <span class="fulfillment-option__title">Self Pickup</span>
                                            <span class="fulfillment-option__desc">Buyer picks up from you. Chat opens after purchase.</span>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <span class="field__error" id="fulfillmentError"></span>
                        </div>

                        @* Actions *@
                        <div class="create-actions">
                            <a asp-action="Index" class="btn btn--ghost">Cancel</a>
                            <button type="submit" class="btn btn--primary" id="submitBtn">Save Changes</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script>
            window.itemEditData = {
                existingImageUrls: @Json.Serialize(Model.ExistingImageUrls)
            };
    </script>
    <script src="~/js/items.js" asp-append-version="true"></script>
</body>
</html>