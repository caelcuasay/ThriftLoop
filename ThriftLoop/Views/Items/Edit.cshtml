@model ThriftLoop.ViewModels.ItemEditViewModel
@{
    ViewData["Title"] = "Edit Listing";
}

<div class="container">
    <div class="create-page">

        <div class="create-header">
            <a asp-action="Index" asp-controller="Items" class="create-header__back">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" width="16" height="16">
                    <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Back to Listings
            </a>
            <div>
                <h1 class="create-header__title">Edit Listing</h1>
                <p class="create-header__subtitle">Update your item details below</p>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="create-error-banner">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                </svg>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" id="editForm" novalidate>
            @Html.AntiForgeryToken()

            @* Hidden fields *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ExistingImageUrl" id="existingImageUrlInput" />
            <input type="hidden" asp-for="RemoveImage" id="removeImageInput" value="false" />

            <div class="create-grid">

                <!-- Photo Column -->
                <div class="create-photo-col">
                    <p class="create-section-label">Item Photo</p>

                    <div class="photo-dropzone" id="photoDropzone" tabindex="0" role="button">
                        <input asp-for="Image" type="file" id="photoInput" class="photo-dropzone__input" accept="image/jpeg,image/png,image/webp" />

                        <div class="photo-dropzone__empty" id="dropzoneEmpty" @(Model.ExistingImageUrl != null ? "hidden" : "")>
                            <div class="photo-dropzone__icon">
                                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="4" y="10" width="40" height="28" rx="4" stroke="currentColor" />
                                    <circle cx="34" cy="18" r="3" stroke="currentColor" />
                                    <path d="M4 32l10-10 8 8 6-6 8 8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <p class="photo-dropzone__main">
                                <span class="photo-dropzone__cta">Click to upload</span> or drag
                            </p>
                            <p class="photo-dropzone__hint">JPEG, PNG · max 5MB</p>
                        </div>

                        <div class="photo-dropzone__preview" id="dropzonePreview" @(Model.ExistingImageUrl == null ? "hidden" : "")>
                            <img id="previewImg" src="@(Model.ExistingImageUrl ?? string.Empty)" alt="Preview" />
                            <button type="button" class="photo-dropzone__remove" id="removePhoto">
                                <svg viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" />
                                </svg>
                            </button>
                        </div>

                        <div class="photo-dropzone__overlay" id="dropzoneOverlay" hidden>
                            <p>Drop to upload</p>
                        </div>
                    </div>

                    <span asp-validation-for="Image" class="field__error"></span>

                    <div class="create-tips">
                        <p class="create-tips__heading">Photo tips</p>
                        <ul class="create-tips__list">
                            <li>Clear, well-lit photos sell faster</li>
                            <li>Show any wear or flaws honestly</li>
                            <li>Square format works best</li>
                        </ul>
                    </div>
                </div>

                <!-- Form Column -->
                <div class="create-form-col">

                    <!-- Title -->
                    <div class="create-field">
                        <div class="create-field__top">
                            <label asp-for="Title" class="create-field__label">Title</label>
                            <span class="create-field__counter" id="titleCounter">0/100</span>
                        </div>
                        <input asp-for="Title" class="create-field__input" id="titleInput"
                               placeholder="e.g. Vintage Levi's Jacket" maxlength="100" />
                        <span asp-validation-for="Title" class="field__error"></span>
                    </div>

                    <!-- Description -->
                    <div class="create-field">
                        <div class="create-field__top">
                            <label asp-for="Description" class="create-field__label">Description</label>
                            <span class="create-field__counter" id="descCounter">0/1000</span>
                        </div>
                        <textarea asp-for="Description" class="create-field__input create-field__input--textarea"
                                  id="descInput" rows="3" maxlength="1000"
                                  placeholder="Describe the item — size, colour, condition, any flaws…"></textarea>
                        <span asp-validation-for="Description" class="field__error"></span>
                    </div>

                    <!-- Price -->
                    <div class="create-field">
                        <label asp-for="Price" class="create-field__label">Price (₱)</label>
                        <div class="create-price-wrap">
                            <span class="create-price-wrap__symbol">₱</span>
                            <input asp-for="Price" class="create-field__input create-price-wrap__input"
                                   type="number" step="0.01" min="0.01" max="99999.99" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="field__error"></span>
                    </div>

                    <!-- Category -->
                    <div class="create-field">
                        <label class="create-field__label">Category</label>
                        <select asp-for="Category" class="create-hidden-select" id="categorySelect">
                            <option value=""></option>
                            @foreach (var cat in ThriftLoop.ViewModels.ItemEditViewModel.Categories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>

                        <div class="create-chips" id="categoryChips">
                            @foreach (var cat in ThriftLoop.ViewModels.ItemEditViewModel.Categories)
                            {
                                var isActive = Model.Category == cat;
                                <button type="button"
                                        class="create-chip @(isActive ? "create-chip--active" : "")"
                                        data-value="@cat"
                                        data-target="categorySelect"
                                        aria-pressed="@(isActive ? "true" : "false")">
                                    @cat
                                </button>
                            }
                        </div>
                        <span asp-validation-for="Category" class="field__error"></span>
                    </div>

                    <!-- Condition -->
                    <div class="create-field">
                        <label class="create-field__label">Condition</label>
                        <select asp-for="Condition" class="create-hidden-select" id="conditionSelect">
                            <option value=""></option>
                            @foreach (var cond in ThriftLoop.ViewModels.ItemEditViewModel.Conditions)
                            {
                                <option value="@cond">@cond</option>
                            }
                        </select>

                        <div class="create-condition" id="conditionPills">
                            @foreach (var cond in ThriftLoop.ViewModels.ItemEditViewModel.Conditions)
                            {
                                var isActive = Model.Condition == cond;
                                <button type="button"
                                        class="create-condition__pill @(isActive ? "create-condition__pill--active" : "")"
                                        data-value="@cond"
                                        data-target="conditionSelect"
                                        aria-pressed="@(isActive ? "true" : "false")">
                                    @cond
                                </button>
                            }
                        </div>
                        <span asp-validation-for="Condition" class="field__error"></span>
                    </div>

                    <!-- Actions -->
                    <div class="create-actions">
                        <button type="submit" class="btn btn--primary" id="submitBtn">
                            <svg viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                            </svg>
                            Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn--ghost">Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function() {
            'use strict';

            // Character counters
            function initCounter(inputId, counterId, max) {
                const input = document.getElementById(inputId);
                const counter = document.getElementById(counterId);
                if (!input || !counter) return;

                const update = () => {
                    const len = input.value.length;
                    counter.textContent = len + '/' + max;
                    counter.classList.toggle('create-field__counter--warn', len > max * 0.9);
                };

                input.addEventListener('input', update);
                update(); // Initialize with current value
            }

            initCounter('titleInput', 'titleCounter', 100);
            initCounter('descInput', 'descCounter', 1000);

            // Category/Condition chips
            function initChips(containerId) {
                const container = document.getElementById(containerId);
                if (!container) return;

                container.addEventListener('click', (e) => {
                    const btn = e.target.closest('[data-value]');
                    if (!btn) return;

                    const select = document.getElementById(btn.dataset.target);
                    if (!select) return;

                    // Deactivate all siblings
                    container.querySelectorAll('[data-value]').forEach(b => {
                        b.classList.remove('create-chip--active', 'create-condition__pill--active');
                        b.setAttribute('aria-pressed', 'false');
                    });

                    // Activate clicked
                    btn.classList.add(containerId === 'categoryChips' ? 'create-chip--active' : 'create-condition__pill--active');
                    btn.setAttribute('aria-pressed', 'true');
                    select.value = btn.dataset.value;

                    // Trigger validation
                    if (window.$ && $.validator) {
                        $(select).valid();
                    }
                });

                // Keyboard support
                container.addEventListener('keydown', (e) => {
                    if (e.key === ' ' || e.key === 'Enter') {
                        const btn = e.target.closest('[data-value]');
                        if (btn) {
                            e.preventDefault();
                            btn.click();
                        }
                    }
                });
            }

            initChips('categoryChips');
            initChips('conditionPills');

            // Photo dropzone with existing image support
            const dropzone = document.getElementById('photoDropzone');
            const input = document.getElementById('photoInput');
            const emptyEl = document.getElementById('dropzoneEmpty');
            const previewEl = document.getElementById('dropzonePreview');
            const previewImg = document.getElementById('previewImg');
            const removeBtn = document.getElementById('removePhoto');
            const overlay = document.getElementById('dropzoneOverlay');
            const removeInput = document.getElementById('removeImageInput');

            if (dropzone && input) {
                dropzone.addEventListener('click', (e) => {
                    if (e.target === removeBtn || removeBtn?.contains(e.target)) return;
                    input.click();
                });

                input.addEventListener('change', () => {
                    if (input.files?.[0]) {
                        showPreview(input.files[0]);
                        removeInput.value = 'false'; // Replacing, not removing
                    }
                });

                removeBtn?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    clearPreview();
                    removeInput.value = 'true'; // Signal to remove existing image
                });

                // Drag & drop
                ['dragenter', 'dragover'].forEach(evt => {
                    dropzone.addEventListener(evt, (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        overlay.hidden = false;
                        dropzone.classList.add('photo-dropzone--drag');
                    });
                });

                ['dragleave', 'dragend'].forEach(evt => {
                    dropzone.addEventListener(evt, (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        overlay.hidden = true;
                        dropzone.classList.remove('photo-dropzone--drag');
                    });
                });

                dropzone.addEventListener('drop', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    overlay.hidden = true;
                    dropzone.classList.remove('photo-dropzone--drag');

                    const file = e.dataTransfer.files[0];
                    if (!file) return;

                    // Validate file type
                    const allowed = ['image/jpeg', 'image/png', 'image/webp'];
                    if (!allowed.includes(file.type)) {
                        showError('Only JPEG, PNG, or WebP images are accepted.');
                        return;
                    }

                    // Validate file size (5MB max)
                    if (file.size > 5 * 1024 * 1024) {
                        showError('Image must be smaller than 5 MB.');
                        return;
                    }

                    // Update the file input
                    const dt = new DataTransfer();
                    dt.items.add(file);
                    input.files = dt.files;

                    showPreview(file);
                    removeInput.value = 'false'; // Replacing, not removing
                });
            }

            function showPreview(file) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    previewImg.src = e.target.result;
                    emptyEl.hidden = true;
                    previewEl.hidden = false;
                };
                reader.readAsDataURL(file);
            }

            function clearPreview() {
                input.value = '';
                previewImg.src = '';
                previewEl.hidden = true;
                emptyEl.hidden = false;
            }

            function showError(msg) {
                const errorSpan = document.querySelector('.create-photo-col .field__error');
                if (errorSpan) {
                    errorSpan.textContent = msg;
                    setTimeout(() => errorSpan.textContent = '', 3000);
                }
            }

            // Submit button loading state
            const form = document.getElementById('editForm');
            const submitBtn = document.getElementById('submitBtn');

            if (form && submitBtn) {
                form.addEventListener('submit', () => {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<svg class="spin" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3zm-1 0v3M9 14v3M3 9H0M17 9h3"/></svg> Saving...';
                });
            }

            // Initialize condition pills with current values
            // This ensures the UI matches the model on page load
            (function initSelectedValues() {
                const categorySelect = document.getElementById('categorySelect');
                const conditionSelect = document.getElementById('conditionSelect');

                if (categorySelect) {
                    const activeCategory = Array.from(document.querySelectorAll('#categoryChips [data-value]')).find(
                        btn => btn.dataset.value === categorySelect.value
                    );
                    if (activeCategory) {
                        activeCategory.classList.add('create-chip--active');
                        activeCategory.setAttribute('aria-pressed', 'true');
                    }
                }

                if (conditionSelect) {
                    const activeCondition = Array.from(document.querySelectorAll('#conditionPills [data-value]')).find(
                        btn => btn.dataset.value === conditionSelect.value
                    );
                    if (activeCondition) {
                        activeCondition.classList.add('create-condition__pill--active');
                        activeCondition.setAttribute('aria-pressed', 'true');
                    }
                }
            })();
        })();
    </script>
}