@model ThriftLoop.ViewModels.ItemCreateViewModel
@{
    ViewData["Title"] = "List an Item";
}

<div class="container">
    <div class="create-page">

        <div class="create-header">
            <a asp-controller="Home" asp-action="Index" class="create-header__back">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" width="16" height="16">
                    <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Back
            </a>
            <div>
                <h1 class="create-header__title">List a new item</h1>
                <p class="create-header__subtitle">Fill in the details below</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="create-toast">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
                @successMsg
            </div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data" id="createForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="create-grid">

                @* Photo Column *@
                <div class="create-photo-col">
                    <p class="create-section-label">Photo</p>

                    <div class="photo-dropzone" id="photoDropzone" tabindex="0" role="button">
                        <input asp-for="Image" type="file" id="photoInput" class="photo-dropzone__input" accept="image/jpeg,image/png,image/webp" />

                        <div class="photo-dropzone__empty" id="dropzoneEmpty">
                            <div class="photo-dropzone__icon">
                                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="4" y="10" width="40" height="28" rx="4" stroke="currentColor" />
                                    <circle cx="34" cy="18" r="3" stroke="currentColor" />
                                    <path d="M4 32l10-10 8 8 6-6 8 8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <p class="photo-dropzone__main">
                                <span class="photo-dropzone__cta">Click to upload</span> or drag
                            </p>
                            <p class="photo-dropzone__hint">JPEG, PNG · max 5MB</p>
                        </div>

                        <div class="photo-dropzone__preview" id="dropzonePreview" hidden>
                            <img id="previewImg" src="" alt="Preview" />
                            <button type="button" class="photo-dropzone__remove" id="removePhoto">
                                <svg viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" />
                                </svg>
                            </button>
                        </div>

                        <div class="photo-dropzone__overlay" id="dropzoneOverlay" hidden>
                            <p>Drop to add photo</p>
                        </div>
                    </div>

                    <span asp-validation-for="Image" class="field__error"></span>

                    <div class="create-tips">
                        <p class="create-tips__heading">Quick tips</p>
                        <ul class="create-tips__list">
                            <li>Use natural light</li>
                            <li>Show any wear honestly</li>
                            <li>Square crops work best</li>
                        </ul>
                    </div>
                </div>

                @* Form Column *@
                <div class="create-form-col">

                    @* Title *@
                    <div class="create-field">
                        <div class="create-field__top">
                            <label asp-for="Title" class="create-field__label">Title</label>
                            <span class="create-field__counter" id="titleCounter">0/100</span>
                        </div>
                        <input asp-for="Title" class="create-field__input" id="titleInput" placeholder="e.g. Vintage Levi's 501" maxlength="100" />
                        <span asp-validation-for="Title" class="field__error"></span>
                    </div>

                    @* Description *@
                    <div class="create-field">
                        <div class="create-field__top">
                            <label asp-for="Description" class="create-field__label">Description</label>
                            <span class="create-field__counter" id="descCounter">0/1000</span>
                        </div>
                        <textarea asp-for="Description" class="create-field__input create-field__input--textarea" id="descInput" rows="3" maxlength="1000" placeholder="Describe the item..."></textarea>
                        <span asp-validation-for="Description" class="field__error"></span>
                    </div>

                    @* Price *@
                    <div class="create-field">
                        <label asp-for="Price" class="create-field__label">Price</label>
                        <div class="create-price-wrap">
                            <span class="create-price-wrap__symbol">₱</span>
                            <input asp-for="Price" class="create-field__input create-price-wrap__input" type="number" step="0.01" min="0.01" max="99999.99" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="field__error"></span>
                    </div>

                    @* Category *@
                    <div class="create-field">
                        <label class="create-field__label">Category</label>
                        <select asp-for="Category" class="create-hidden-select" id="categorySelect">
                            <option value=""></option>
                            @foreach (var cat in ThriftLoop.ViewModels.ItemCreateViewModel.Categories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                        <div class="create-chips" id="categoryChips">
                            @foreach (var cat in ThriftLoop.ViewModels.ItemCreateViewModel.Categories)
                            {
                                <button type="button" class="create-chip @(Model.Category == cat ? "create-chip--active" : "")" data-value="@cat" data-target="categorySelect">@cat</button>
                            }
                        </div>
                        <span asp-validation-for="Category" class="field__error"></span>
                    </div>

                    @* Condition *@
                    <div class="create-field">
                        <label class="create-field__label">Condition</label>
                        <select asp-for="Condition" class="create-hidden-select" id="conditionSelect">
                            <option value=""></option>
                            @foreach (var cond in ThriftLoop.ViewModels.ItemCreateViewModel.Conditions)
                            {
                                <option value="@cond">@cond</option>
                            }
                        </select>
                        <div class="create-condition" id="conditionPills">
                            @{
                                var icons = new[] { "✦", "★", "◆", "▲", "●" };
                                var idx = 0;
                            }
                            @foreach (var cond in ThriftLoop.ViewModels.ItemCreateViewModel.Conditions)
                            {
                                <button type="button" class="create-condition__pill @(Model.Condition == cond ? "create-condition__pill--active" : "")" data-value="@cond" data-target="conditionSelect">
                                    <span>@icons[idx]</span>
                                    <span>@cond</span>
                                </button>
                                idx++;
                            }
                        </div>
                        <span asp-validation-for="Condition" class="field__error"></span>
                    </div>

                    @* Size — optional, reuses the same chip pattern as Category *@
                    <div class="create-field">
                        <div class="create-field__top">
                            <label class="create-field__label">Size</label>
                            <span class="create-field__optional">optional</span>
                        </div>

                        @* Hidden select drives model binding — empty value = no size selected *@
                        <select asp-for="Size" class="create-hidden-select" id="sizeSelect">
                            <option value=""></option>
                            @foreach (var size in ThriftLoop.ViewModels.ItemCreateViewModel.Sizes)
                            {
                                <option value="@size">@size</option>
                            }
                        </select>

                        <div class="create-chips create-chips--size" id="sizeChips">
                            @foreach (var size in ThriftLoop.ViewModels.ItemCreateViewModel.Sizes)
                            {
                                <button type="button"
                                        class="create-chip @(Model.Size == size ? "create-chip--active" : "")"
                                        data-value="@size"
                                        data-target="sizeSelect">
                                    @size
                                </button>
                            }
                        </div>

                        @*
                            Unlike Category/Condition, a second click on an already-active size chip
                            deselects it (clears the size) — handled in the JS below.
                        *@
                        <span asp-validation-for="Size" class="field__error"></span>
                    </div>

                    @* Actions *@
                    <div class="create-actions">
                        <button type="submit" class="btn btn--primary" id="submitBtn">
                            <svg viewBox="0 0 20 20" fill="currentColor">
                                <path d="M10 1a9 9 0 100 18A9 9 0 0010 1zm4.53 6.03l-5 5a.75.75 0 01-1.06 0l-2-2a.75.75 0 111.06-1.06l1.47 1.47 4.47-4.47a.75.75 0 111.06 1.06z" />
                            </svg>
                            Post Listing
                        </button>
                        <a asp-action="Index" asp-controller="Home" class="btn btn--ghost">Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function() {
            'use strict';

            // ── Character counters ───────────────────────────────────────────────
            function initCounter(inputId, counterId, max) {
                const input = document.getElementById(inputId);
                const counter = document.getElementById(counterId);
                if (!input || !counter) return;

                const update = () => {
                    const len = input.value.length;
                    counter.textContent = len + '/' + max;
                    counter.classList.toggle('create-field__counter--warn', len > max * 0.9);
                };

                input.addEventListener('input', update);
                update();
            }

            initCounter('titleInput', 'titleCounter', 100);
            initCounter('descInput', 'descCounter', 1000);

            // ── Category / Condition chips (required — click activates, cannot deselect) ──
            function initChips(containerId) {
                const container = document.getElementById(containerId);
                if (!container) return;

                container.addEventListener('click', (e) => {
                    const btn = e.target.closest('[data-value]');
                    if (!btn) return;

                    const select = document.getElementById(btn.dataset.target);
                    if (!select) return;

                    // Deactivate all
                    container.querySelectorAll('[data-value]').forEach(b => {
                        b.classList.remove('create-chip--active', 'create-condition__pill--active');
                    });

                    // Activate clicked
                    btn.classList.add(containerId === 'categoryChips' ? 'create-chip--active' : 'create-condition__pill--active');
                    select.value = btn.dataset.value;

                    if (window.$ && $.validator) $(select).valid();
                });
            }

            initChips('categoryChips');
            initChips('conditionPills');

            // ── Size chips (optional — clicking an active chip deselects it) ────────
            (function initSizeChips() {
                const container = document.getElementById('sizeChips');
                const select    = document.getElementById('sizeSelect');
                if (!container || !select) return;

                container.addEventListener('click', (e) => {
                    const btn = e.target.closest('[data-value]');
                    if (!btn) return;

                    const alreadyActive = btn.classList.contains('create-chip--active');

                    // Deactivate all size chips first
                    container.querySelectorAll('[data-value]').forEach(b => {
                        b.classList.remove('create-chip--active');
                    });

                    if (alreadyActive) {
                        // Second click on same chip → clear selection
                        select.value = '';
                    } else {
                        btn.classList.add('create-chip--active');
                        select.value = btn.dataset.value;
                    }
                });
            })();

            // ── Photo dropzone ───────────────────────────────────────────────────
            const dropzone = document.getElementById('photoDropzone');
            const input = document.getElementById('photoInput');
            const empty = document.getElementById('dropzoneEmpty');
            const preview = document.getElementById('dropzonePreview');
            const previewImg = document.getElementById('previewImg');
            const removeBtn = document.getElementById('removePhoto');
            const overlay = document.getElementById('dropzoneOverlay');

            if (dropzone && input) {
                dropzone.addEventListener('click', (e) => {
                    if (e.target === removeBtn || removeBtn?.contains(e.target)) return;
                    input.click();
                });

                input.addEventListener('change', () => {
                    if (input.files?.[0]) showPreview(input.files[0]);
                });

                removeBtn?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    clearPreview();
                });

                ['dragenter', 'dragover'].forEach(evt => {
                    dropzone.addEventListener(evt, (e) => {
                        e.preventDefault();
                        overlay.hidden = false;
                    });
                });

                ['dragleave', 'dragend', 'drop'].forEach(evt => {
                    dropzone.addEventListener(evt, (e) => {
                        e.preventDefault();
                        overlay.hidden = true;
                    });
                });

                dropzone.addEventListener('drop', (e) => {
                    const file = e.dataTransfer.files[0];
                    if (!file) return;

                    if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
                        showError('Only JPEG, PNG, or WebP images are accepted.');
                        return;
                    }
                    if (file.size > 5 * 1024 * 1024) {
                        showError('Image must be smaller than 5 MB.');
                        return;
                    }

                    const dt = new DataTransfer();
                    dt.items.add(file);
                    input.files = dt.files;
                    showPreview(file);
                });
            }

            function showPreview(file) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    previewImg.src = e.target.result;
                    empty.hidden = true;
                    preview.hidden = false;
                };
                reader.readAsDataURL(file);
            }

            function clearPreview() {
                input.value = '';
                previewImg.src = '';
                preview.hidden = true;
                empty.hidden = false;
            }

            function showError(msg) {
                const errorSpan = document.querySelector('.create-photo-col .field__error');
                if (errorSpan) {
                    errorSpan.textContent = msg;
                    setTimeout(() => errorSpan.textContent = '', 3000);
                }
            }

            // ── Submit loading state ─────────────────────────────────────────────
            const form = document.getElementById('createForm');
            const submitBtn = document.getElementById('submitBtn');

            form?.addEventListener('submit', () => {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<svg class="spin" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3zm-1 0v3M9 14v3M3 9H0M17 9h3"/></svg> Posting...';
            });

            // ── Auto-dismiss toast ───────────────────────────────────────────────
            const toast = document.querySelector('.create-toast');
            if (toast) {
                setTimeout(() => {
                    toast.style.opacity = '0';
                    setTimeout(() => toast.remove(), 400);
                }, 4000);
            }
        })();
    </script>
}
