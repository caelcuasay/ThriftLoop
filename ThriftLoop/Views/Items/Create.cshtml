@model ThriftLoop.ViewModels.ItemCreateViewModel
@using ThriftLoop.Models
@{
    ViewData["Title"] = "List an Item";
}

<div class="container">
    <div class="create-page">

        <div class="create-header">
            <a asp-controller="Home" asp-action="Index" class="create-header__back">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" width="16" height="16">
                    <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Back
            </a>
            <div>
                <h1 class="create-header__title">List a new item</h1>
                <p class="create-header__subtitle">Fill in the details below</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="create-toast">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
                @successMsg
            </div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data" id="createForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="create-grid">

                @* ── Photo Column ──────────────────────────────────────────────── *@
                <div class="create-photo-col">
                    <p class="create-section-label">Photo</p>

                    <div class="photo-dropzone" id="photoDropzone" tabindex="0" role="button">
                        <input asp-for="Image" type="file" id="photoInput" class="photo-dropzone__input" accept="image/jpeg,image/png,image/webp" />

                        <div class="photo-dropzone__empty" id="dropzoneEmpty">
                            <div class="photo-dropzone__icon">
                                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="4" y="10" width="40" height="28" rx="4" stroke="currentColor" />
                                    <circle cx="34" cy="18" r="3" stroke="currentColor" />
                                    <path d="M4 32l10-10 8 8 6-6 8 8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <p class="photo-dropzone__main">
                                <span class="photo-dropzone__cta">Click to upload</span> or drag
                            </p>
                            <p class="photo-dropzone__hint">JPEG, PNG · max 5MB</p>
                        </div>

                        <div class="photo-dropzone__preview" id="dropzonePreview" hidden>
                            <img id="previewImg" src="" alt="Preview" />
                            <button type="button" class="photo-dropzone__remove" id="removePhoto">
                                <svg viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" />
                                </svg>
                            </button>
                        </div>

                        <div class="photo-dropzone__overlay" id="dropzoneOverlay" hidden>
                            <p>Drop to add photo</p>
                        </div>
                    </div>

                    <span asp-validation-for="Image" class="field__error"></span>

                    <div class="create-tips">
                        <p class="create-tips__heading">Quick tips</p>
                        <ul class="create-tips__list">
                            <li>Use natural light</li>
                            <li>Show any wear honestly</li>
                            <li>Square crops work best</li>
                        </ul>
                    </div>
                </div>

                @* ── Form Column ───────────────────────────────────────────────── *@
                <div class="create-form-col">

                    @* Title *@
                    <div class="create-field">
                        <div class="create-field__top">
                            <label asp-for="Title" class="create-field__label">Title</label>
                            <span class="create-field__counter" id="titleCounter">0/100</span>
                        </div>
                        <input asp-for="Title" class="create-field__input" id="titleInput" placeholder="e.g. Vintage Levi's 501" maxlength="100" />
                        <span asp-validation-for="Title" class="field__error"></span>
                    </div>

                    @* Description *@
                    <div class="create-field">
                        <div class="create-field__top">
                            <label asp-for="Description" class="create-field__label">Description</label>
                            <span class="create-field__counter" id="descCounter">0/1000</span>
                        </div>
                        <textarea asp-for="Description" class="create-field__input create-field__input--textarea" id="descInput" rows="3" maxlength="1000" placeholder="Describe the item..."></textarea>
                        <span asp-validation-for="Description" class="field__error"></span>
                    </div>

                    @* Price *@
                    <div class="create-field">
                        <label asp-for="Price" class="create-field__label">Price</label>
                        <div class="create-price-wrap">
                            <span class="create-price-wrap__symbol">₱</span>
                            <input asp-for="Price" class="create-field__input create-price-wrap__input" type="number" step="0.01" min="0.01" max="99999.99" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="field__error"></span>
                    </div>

                    @* Category *@
                    <div class="create-field">
                        <label class="create-field__label">Category</label>
                        <select asp-for="Category" class="create-hidden-select" id="categorySelect">
                            <option value=""></option>
                            @foreach (var cat in ThriftLoop.ViewModels.ItemCreateViewModel.Categories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                        <div class="create-chips" id="categoryChips">
                            @foreach (var cat in ThriftLoop.ViewModels.ItemCreateViewModel.Categories)
                            {
                                <button type="button" class="create-chip @(Model.Category == cat ? "create-chip--active" : "")" data-value="@cat" data-target="categorySelect">@cat</button>
                            }
                        </div>
                        <span asp-validation-for="Category" class="field__error"></span>
                    </div>

                    @* Condition *@
                    <div class="create-field">
                        <label class="create-field__label">Condition</label>
                        <select asp-for="Condition" class="create-hidden-select" id="conditionSelect">
                            <option value=""></option>
                            @foreach (var cond in ThriftLoop.ViewModels.ItemCreateViewModel.Conditions)
                            {
                                <option value="@cond">@cond</option>
                            }
                        </select>
                        <div class="create-condition" id="conditionPills">
                            @{
                                var icons = new[] { "✦", "★", "◆", "▲", "●" };
                                var idx = 0;
                            }
                            @foreach (var cond in ThriftLoop.ViewModels.ItemCreateViewModel.Conditions)
                            {
                                <button type="button" class="create-condition__pill @(Model.Condition == cond ? "create-condition__pill--active" : "")" data-value="@cond" data-target="conditionSelect">
                                    <span>@icons[idx]</span>
                                    <span>@cond</span>
                                </button>
                                idx++;
                            }
                        </div>
                        <span asp-validation-for="Condition" class="field__error"></span>
                    </div>

                    @* Size — optional *@
                    <div class="create-field">
                        <div class="create-field__top">
                            <label class="create-field__label">Size</label>
                            <span class="create-field__optional">optional</span>
                        </div>
                        <select asp-for="Size" class="create-hidden-select" id="sizeSelect">
                            <option value=""></option>
                            @foreach (var size in ThriftLoop.ViewModels.ItemCreateViewModel.Sizes)
                            {
                                <option value="@size">@size</option>
                            }
                        </select>
                        <div class="create-chips create-chips--size" id="sizeChips">
                            @foreach (var size in ThriftLoop.ViewModels.ItemCreateViewModel.Sizes)
                            {
                                <button type="button"
                                        class="create-chip @(Model.Size == size ? "create-chip--active" : "")"
                                        data-value="@size"
                                        data-target="sizeSelect">
                                    @size
                                </button>
                            }
                        </div>
                        <span asp-validation-for="Size" class="field__error"></span>
                    </div>

                    @* ── Stealable Listing Section ─────────────────────────────── *@
                    <div class="create-field create-field--stealable">

                        @* Section divider *@
                        <div class="create-stealable-header">
                            <div>
                                <p class="create-field__label">Listing Type</p>
                                <p class="create-stealable-header__sub">
                                    Stealable listings let buyers compete — one claims it, another can steal it.
                                </p>
                            </div>
                        </div>

                        @* Toggle row *@
                        <label class="stealable-toggle" for="IsStealable">
                            <span class="stealable-toggle__track">
                                <input asp-for="IsStealable"
                                       id="IsStealable"
                                       type="checkbox"
                                       class="stealable-toggle__input" />
                                <span class="stealable-toggle__thumb" aria-hidden="true"></span>
                            </span>
                            <span class="stealable-toggle__label-group">
                                <span class="stealable-toggle__name">Make this a Stealable listing</span>
                                <span class="stealable-toggle__badge" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11">
                                        <path d="M8.75 3.75a.75.75 0 00-1.5 0v3.5h-3.5a.75.75 0 000 1.5h3.5v3.5a.75.75 0 001.5 0v-3.5h3.5a.75.75 0 000-1.5h-3.5v-3.5z" />
                                    </svg>
                                    NEW
                                </span>
                            </span>
                        </label>

                        @* Duration panel — hidden until checkbox is ticked *@
                        <div class="stealable-duration-panel" id="stealDurationPanel"
                             @(Model.IsStealable ? "" : "hidden")
                             aria-live="polite">

                            <div class="stealable-duration-inner">
                                <svg class="stealable-duration-icon" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
                                </svg>

                                <div class="stealable-duration-body">
                                    <label asp-for="StealDurationHours" class="create-field__label">
                                        Steal Window Duration
                                    </label>
                                    <p class="stealable-duration-body__hint">
                                        How long a buyer has before another can steal the item.
                                        After the window closes, the original buyer gets a 2-hour grace period.
                                    </p>

                                    @* Chip-style duration selector driven by a hidden <select> *@
                                    <select asp-for="StealDurationHours"
                                            class="create-hidden-select"
                                            id="stealDurationSelect">
                                        <option value=""></option>
                                        @foreach (var hours in ThriftLoop.ViewModels.ItemCreateViewModel.StealDurations)
                                        {
                                            <option value="@hours">@hours hours</option>
                                        }
                                    </select>

                                    <div class="create-chips create-chips--duration" id="durationChips">
                                        @foreach (var hours in ThriftLoop.ViewModels.ItemCreateViewModel.StealDurations)
                                        {
                                            <button type="button"
                                                    class="create-chip @(Model.StealDurationHours == hours ? "create-chip--active" : "")"
                                                    data-value="@hours"
                                                    data-target="stealDurationSelect">
                                                @hours hr
                                            </button>
                                        }
                                    </div>

                                    <span asp-validation-for="StealDurationHours" class="field__error"></span>
                                </div>
                            </div>
                        </div>

                    </div>

                    @* Actions *@
                    <div class="create-actions">
                        <button type="submit" class="btn btn--primary" id="submitBtn">
                            <svg viewBox="0 0 20 20" fill="currentColor">
                                <path d="M10 1a9 9 0 100 18A9 9 0 0010 1zm4.53 6.03l-5 5a.75.75 0 01-1.06 0l-2-2a.75.75 0 111.06-1.06l1.47 1.47 4.47-4.47a.75.75 0 111.06 1.06z" />
                            </svg>
                            Post Listing
                        </button>
                        <a asp-action="Index" asp-controller="Home" class="btn btn--ghost">Cancel</a>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <style>
        /* ── Stealable toggle ──────────────────────────────────────────────── */
        .create-field--stealable {
            border-top: 1px solid var(--color-border, #e8e3da);
            padding-top: 1.25rem;
            margin-top: 0.25rem;
        }

        .create-stealable-header {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .create-stealable-header__sub {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.8125rem;
            color: var(--color-muted, #8a8278);
            margin: 0.2rem 0 0;
            line-height: 1.5;
        }

        /* Toggle switch */
        .stealable-toggle {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
            user-select: none;
            width: fit-content;
        }

        .stealable-toggle__track {
            position: relative;
            width: 44px;
            height: 24px;
            flex-shrink: 0;
        }

        .stealable-toggle__input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .stealable-toggle__thumb {
            position: absolute;
            inset: 0;
            background: var(--color-border, #d4cdc4);
            border-radius: 99px;
            transition: background 0.2s ease;
        }

            .stealable-toggle__thumb::after {
                content: '';
                position: absolute;
                top: 3px;
                left: 3px;
                width: 18px;
                height: 18px;
                background: #fff;
                border-radius: 50%;
                transition: transform 0.2s ease;
                box-shadow: 0 1px 3px rgba(0,0,0,.15);
            }

        .stealable-toggle__input:checked ~ .stealable-toggle__thumb {
            background: var(--color-primary, #2d5a27);
        }

            .stealable-toggle__input:checked ~ .stealable-toggle__thumb::after {
                transform: translateX(20px);
            }

        .stealable-toggle__input:focus-visible ~ .stealable-toggle__thumb {
            outline: 2px solid var(--color-primary, #2d5a27);
            outline-offset: 2px;
        }

        .stealable-toggle__label-group {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .stealable-toggle__name {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9375rem;
            font-weight: 500;
            color: var(--color-text, #1a1814);
        }

        .stealable-toggle__badge {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            background: var(--color-primary, #2d5a27);
            color: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            padding: 2px 6px;
            border-radius: 4px;
        }

        /* Duration panel */
        .stealable-duration-panel {
            margin-top: 1rem;
            overflow: hidden;
        }

            .stealable-duration-panel[hidden] {
                display: none;
            }

        .stealable-duration-inner {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            background: var(--color-surface-alt, #f5f1ea);
            border: 1px solid var(--color-border, #e2ddd6);
            border-radius: 10px;
            padding: 1rem 1.125rem;
        }

        .stealable-duration-icon {
            color: var(--color-primary, #2d5a27);
            flex-shrink: 0;
            margin-top: 2px;
        }

        .stealable-duration-body {
            flex: 1;
        }

        .stealable-duration-body__hint {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.8125rem;
            color: var(--color-muted, #8a8278);
            margin: 0.25rem 0 0.875rem;
            line-height: 1.55;
        }

        .create-chips--duration {
            margin-top: 0.5rem;
        }
    </style>

    <script>
        (function() {
            'use strict';

            // ── Character counters ─────────────────────────────────────────────
            function initCounter(inputId, counterId, max) {
                var input   = document.getElementById(inputId);
                var counter = document.getElementById(counterId);
                if (!input || !counter) return;

                var update = function() {
                    var len = input.value.length;
                    counter.textContent = len + '/' + max;
                    counter.classList.toggle('create-field__counter--warn', len > max * 0.9);
                };

                input.addEventListener('input', update);
                update();
            }

            initCounter('titleInput', 'titleCounter', 100);
            initCounter('descInput', 'descCounter', 1000);

            // ── Category / Condition chips (required — click activates, cannot deselect) ──
            function initChips(containerId) {
                var container = document.getElementById(containerId);
                if (!container) return;

                container.addEventListener('click', function(e) {
                    var btn = e.target.closest('[data-value]');
                    if (!btn) return;

                    var select = document.getElementById(btn.dataset.target);
                    if (!select) return;

                    container.querySelectorAll('[data-value]').forEach(function(b) {
                        b.classList.remove('create-chip--active', 'create-condition__pill--active');
                    });

                    btn.classList.add(containerId === 'categoryChips' ? 'create-chip--active' : 'create-condition__pill--active');
                    select.value = btn.dataset.value;

                    if (window.$ && $.validator) $(select).valid();
                });
            }

            initChips('categoryChips');
            initChips('conditionPills');

            // ── Duration chips (required when Stealable — same chip pattern) ───
            function initDurationChips() {
                var container = document.getElementById('durationChips');
                var select    = document.getElementById('stealDurationSelect');
                if (!container || !select) return;

                container.addEventListener('click', function(e) {
                    var btn = e.target.closest('[data-value]');
                    if (!btn) return;

                    container.querySelectorAll('[data-value]').forEach(function(b) {
                        b.classList.remove('create-chip--active');
                    });

                    btn.classList.add('create-chip--active');
                    select.value = btn.dataset.value;

                    // Re-run unobtrusive validation on the hidden select so the
                    // error span clears immediately when the user picks a value.
                    if (window.$ && $.validator) $(select).valid();
                });
            }

            initDurationChips();

            // ── Size chips (optional — second click deselects) ─────────────────
            (function initSizeChips() {
                var container = document.getElementById('sizeChips');
                var select    = document.getElementById('sizeSelect');
                if (!container || !select) return;

                container.addEventListener('click', function(e) {
                    var btn = e.target.closest('[data-value]');
                    if (!btn) return;

                    var alreadyActive = btn.classList.contains('create-chip--active');

                    container.querySelectorAll('[data-value]').forEach(function(b) {
                        b.classList.remove('create-chip--active');
                    });

                    if (alreadyActive) {
                        select.value = '';
                    } else {
                        btn.classList.add('create-chip--active');
                        select.value = btn.dataset.value;
                    }
                });
            })();

            // ── Stealable toggle — show / hide the duration panel ─────────────
            (function initStealableToggle() {
                var checkbox      = document.getElementById('IsStealable');
                var panel         = document.getElementById('stealDurationPanel');
                var durationSelect = document.getElementById('stealDurationSelect');
                if (!checkbox || !panel) return;

                function syncPanel() {
                    if (checkbox.checked) {
                        panel.removeAttribute('hidden');
                    } else {
                        panel.setAttribute('hidden', '');

                        // Clear the selection so the hidden field submits empty
                        // and server-side validation does not complain.
                        if (durationSelect) {
                            durationSelect.value = '';
                            document.querySelectorAll('#durationChips [data-value]').forEach(function(b) {
                                b.classList.remove('create-chip--active');
                            });
                        }
                    }
                }

                checkbox.addEventListener('change', syncPanel);
                // Run once on load to restore state after a failed server POST.
                syncPanel();
            })();

            // ── Photo dropzone ─────────────────────────────────────────────────
            var dropzone   = document.getElementById('photoDropzone');
            var input      = document.getElementById('photoInput');
            var empty      = document.getElementById('dropzoneEmpty');
            var preview    = document.getElementById('dropzonePreview');
            var previewImg = document.getElementById('previewImg');
            var removeBtn  = document.getElementById('removePhoto');
            var overlay    = document.getElementById('dropzoneOverlay');

            if (dropzone && input) {
                dropzone.addEventListener('click', function(e) {
                    if (e.target === removeBtn || (removeBtn && removeBtn.contains(e.target))) return;
                    input.click();
                });

                input.addEventListener('change', function() {
                    if (input.files && input.files[0]) showPreview(input.files[0]);
                });

                if (removeBtn) {
                    removeBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        clearPreview();
                    });
                }

                ['dragenter', 'dragover'].forEach(function(evt) {
                    dropzone.addEventListener(evt, function(e) {
                        e.preventDefault();
                        if (overlay) overlay.hidden = false;
                    });
                });

                ['dragleave', 'dragend', 'drop'].forEach(function(evt) {
                    dropzone.addEventListener(evt, function(e) {
                        e.preventDefault();
                        if (overlay) overlay.hidden = true;
                    });
                });

                dropzone.addEventListener('drop', function(e) {
                    var file = e.dataTransfer.files[0];
                    if (!file) return;

                    if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
                        showDropzoneError('Only JPEG, PNG, or WebP images are accepted.');
                        return;
                    }
                    if (file.size > 5 * 1024 * 1024) {
                        showDropzoneError('Image must be smaller than 5 MB.');
                        return;
                    }

                    var dt = new DataTransfer();
                    dt.items.add(file);
                    input.files = dt.files;
                    showPreview(file);
                });
            }

            function showPreview(file) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    if (empty)   empty.hidden   = true;
                    if (preview) preview.hidden = false;
                };
                reader.readAsDataURL(file);
            }

            function clearPreview() {
                input.value = '';
                previewImg.src = '';
                if (preview) preview.hidden = true;
                if (empty)   empty.hidden   = false;
            }

            function showDropzoneError(msg) {
                var errorSpan = document.querySelector('.create-photo-col .field__error');
                if (errorSpan) {
                    errorSpan.textContent = msg;
                    setTimeout(function() { errorSpan.textContent = ''; }, 3000);
                }
            }

            // ── Submit loading state ───────────────────────────────────────────
            var form      = document.getElementById('createForm');
            var submitBtn = document.getElementById('submitBtn');

            if (form && submitBtn) {
                form.addEventListener('submit', function() {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<svg class="spin" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3zm-1 0v3M9 14v3M3 9H0M17 9h3"/></svg> Posting...';
                });
            }

            // ── Auto-dismiss toast ─────────────────────────────────────────────
            var toast = document.querySelector('.create-toast');
            if (toast) {
                setTimeout(function() {
                    toast.style.opacity = '0';
                    setTimeout(function() { toast.remove(); }, 400);
                }, 4000);
            }

        })();
    </script>
}
