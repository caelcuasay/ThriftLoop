@model ThriftLoop.Models.Item
@using ThriftLoop.Models
@using ThriftLoop.Enums
@{
    ViewData["Title"] = Model.Title;
    Layout = null;

    bool isOwner = (bool)(ViewBag.IsOwner ?? false);
    bool isAnonymous = (bool)(ViewBag.IsAnonymous ?? true);
    bool isCurrentWinner = (bool)(ViewBag.IsCurrentWinner ?? false);
    bool isOriginalGetter = (bool)(ViewBag.IsOriginalGetter ?? false);

    bool isStealable = Model.ListingType == ListingType.Stealable;
    bool stealWindowOpen = isStealable
                           && Model.Status == ItemStatus.Reserved
                           && Model.StealEndsAt.HasValue
                           && DateTime.UtcNow <= Model.StealEndsAt.Value;

    string sellerDisplay = Model.User is not null
        ? Model.User.Email.Split('@')[0]
        : "Unknown seller";

    string condClass = Model.Condition switch
    {
        "New" => "detail-condition--new",
        "Like New" => "detail-condition--like-new",
        "Good" => "detail-condition--good",
        "Fair" => "detail-condition--fair",
        _ => "detail-condition--poor"
    };

    string priceLabel = isStealable ? "Starting price" : "Fixed price";
    if (isStealable && Model.Status == ItemStatus.Reserved)
        priceLabel = "Current price";
    if (isStealable && Model.Status == ItemStatus.StolenPendingCheckout)
        priceLabel = "Stolen price";

    bool hasImages = Model.ImageUrls.Count > 0;
    
    // Determine default fulfillment method (first allowed option)
    string defaultFulfillmentMethod = Model.AllowDelivery ? "Delivery"
        : Model.AllowHalfway ? "Halfway"
        : Model.AllowPickup ? "Pickup"
        : "Delivery";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThriftLoop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Items.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Navbar.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("_Navbar")

    <div class="detail-shell">

        <nav class="detail-breadcrumb" aria-label="Breadcrumb">
            <a asp-action="Index" asp-controller="Home" class="detail-breadcrumb__link">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Back to listings
            </a>
        </nav>

        <div class="detail-grid">

            <aside class="detail-img-col">
                <div class="detail-gallery">
                    <div class="detail-img-frame" id="galleryMain">
                        @if (hasImages)
                        {
                            <img src="@Model.ImageUrls[0]"
                                 id="mainGalleryImg"
                                 alt="Photo of @Model.Title"
                                 class="detail-img"
                                 loading="eager" />

                            @if (Model.ImageUrls.Count > 1)
                            {
                                <button type="button" class="gallery-arrow gallery-arrow--prev" id="galleryPrev" aria-label="Previous photo">
                                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                        <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </button>
                                <button type="button" class="gallery-arrow gallery-arrow--next" id="galleryNext" aria-label="Next photo">
                                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                        <path d="M7.5 5L12.5 10L7.5 15" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </button>
                                <span class="gallery-counter" id="galleryCounter">
                                    1 / @Model.ImageUrls.Count
                                </span>
                            }
                        }
                        else
                        {
                            <div class="detail-img detail-img--placeholder" aria-hidden="true">
                                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4">
                                    <rect x="6" y="10" width="52" height="44" rx="6" />
                                    <circle cx="22" cy="26" r="6" />
                                    <path d="M6 46l16-14 10 10 8-7 18 15" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <span>No photo</span>
                            </div>
                        }

                        @if (isStealable)
                        {
                            <span class="detail-stealable-badge" aria-label="Stealable listing">
                                <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                                    <path d="M8.75 3.75a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" />
                                </svg>
                                Stealable
                            </span>
                        }
                    </div>

                    @if (Model.ImageUrls.Count > 1)
                    {
                        <div class="gallery-thumbs" id="galleryThumbs" role="list">
                            @for (int t = 0; t < Model.ImageUrls.Count; t++)
                            {
                                <button type="button"
                                        class="gallery-thumb @(t == 0 ? "gallery-thumb--active" : "")"
                                        data-index="@t"
                                        data-src="@Model.ImageUrls[t]"
                                        role="listitem"
                                        aria-label="Photo @(t + 1)">
                                    <img src="@Model.ImageUrls[t]" alt="Thumbnail @(t + 1)" loading="lazy" />
                                    @if (t == 0)
                                    {
                                        <span class="gallery-thumb__cover">Cover</span>
                                    }
                                </button>
                            }
                        </div>
                    }
                </div>

                <div class="detail-seller detail-seller--below-img">
                    <div class="detail-seller__avatar" aria-hidden="true">
                        @sellerDisplay.Substring(0, 1).ToUpper()
                    </div>
                    <div class="detail-seller__info">
                        <p class="detail-seller__label">Listed by</p>
                        <p class="detail-seller__name">@sellerDisplay</p>
                        <p class="detail-seller__since">
                            Member since @(Model.User?.CreatedAt.ToString("MMMM yyyy") ?? "—")
                        </p>
                    </div>
                </div>
            </aside>

            <section class="detail-info-col">
                <div class="detail-meta-row">
                    <span class="detail-category">@Model.Category</span>
                    <span class="detail-condition @condClass">@Model.Condition</span>
                    @if (!string.IsNullOrEmpty(Model.Size))
                    {
                        <span class="detail-size">@Model.Size</span>
                    }
                    @if (isStealable)
                    {
                        <span class="detail-listing-type-badge">
                            <svg viewBox="0 0 14 14" fill="currentColor" width="10" height="10" aria-hidden="true">
                                <path d="M7 1a6 6 0 100 12A6 6 0 007 1zm.6 8.9H6.4V6.4h1.2v3.5zm0-4.6H6.4V4.1h1.2v1.2z" />
                            </svg>
                            Stealable
                        </span>
                    }
                </div>

                <h1 class="detail-title">@Model.Title</h1>

                <div class="detail-price-block">
                    <span class="detail-price">₱@Model.Price.ToString("N2")</span>
                    <span class="detail-price-label">@priceLabel</span>
                    @if (isStealable && Model.Status == ItemStatus.Available)
                    {
                        <span class="detail-steal-note">+₱50 if stolen</span>
                    }
                </div>

                @* Fulfillment Options Display (show what seller allows) *@
                <div class="detail-fulfillment-badges">
                    @if (Model.AllowDelivery)
                    {
                        <span class="fulfillment-badge fulfillment-badge--delivery">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                                <path d="M2.5 3A1.5 1.5 0 001 4.5v7A1.5 1.5 0 002.5 13h11a1.5 1.5 0 001.5-1.5v-7A1.5 1.5 0 0013.5 3h-11z" />
                                <circle cx="4.5" cy="9.5" r="1.5" />
                                <circle cx="11.5" cy="9.5" r="1.5" />
                            </svg>
                            Delivery
                        </span>
                    }
                    @if (Model.AllowHalfway)
                    {
                        <span class="fulfillment-badge fulfillment-badge--halfway">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                                <path d="M8 1a5 5 0 00-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 00-5-5z" />
                                <circle cx="8" cy="6" r="2" />
                            </svg>
                            Halfway Meetup
                        </span>
                    }
                    @if (Model.AllowPickup)
                    {
                        <span class="fulfillment-badge fulfillment-badge--pickup">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                                <path d="M2 6l6-4.5L14 6v7.5a.5.5 0 01-.5.5h-11a.5.5 0 01-.5-.5V6z" />
                                <path d="M6 14V9h4v5" />
                            </svg>
                            Pickup
                        </span>
                    }
                </div>

                @if (isStealable && Model.Status == ItemStatus.Reserved && Model.StealEndsAt.HasValue)
                {
                    if (stealWindowOpen)
                    {
                        <div class="steal-countdown-card" id="stealCountdownCard">
                            <div class="steal-countdown-card__icon" aria-hidden="true">
                                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="steal-countdown-card__body">
                                <p class="steal-countdown-card__label">Steal window closes in</p>
                                <p class="steal-countdown-card__timer"
                                       id="stealTimer"
                                       data-ends-at="@(DateTime.SpecifyKind(Model.StealEndsAt.Value, DateTimeKind.Utc).ToString("O"))">
                                    ——:——:——
                                </p>
                            </div>
                        </div>
                    }
                    else if (Model.IsInFinalizeWindow)
                    {
                        <div class="steal-countdown-card steal-countdown-card--finalize">
                            <div class="steal-countdown-card__icon" aria-hidden="true">
                                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="steal-countdown-card__body">
                                <p class="steal-countdown-card__label">Steal window closed — finalise window open</p>
                                <p class="steal-countdown-card__timer"
                                       id="finalizeTimer"
                                       data-ends-at="@(DateTime.SpecifyKind(Model.FinalizeDeadline!.Value, DateTimeKind.Utc).ToString("O"))">
                                    ——:——:——
                                </p>
                            </div>
                        </div>
                    }
                }

                @if (isStealable && Model.Status == ItemStatus.StolenPendingCheckout)
                {
                    <div class="steal-countdown-card steal-countdown-card--stolen">
                        <div class="steal-countdown-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="steal-countdown-card__body">
                            <p class="steal-countdown-card__label">Stolen — pending purchase</p>
                            <p class="steal-countdown-card__sub">
                                @if (isCurrentWinner)
                                {
                                    @:Complete your checkout below, or cancel to restore the item to the previous holder.
                                }
                                else if (isOriginalGetter)
                                {
                                    @:Someone is stealing your item. If they cancel checkout, your reservation will be fully restored.
                                }
                                else
                                {
                                    @:A buyer is completing a steal purchase. If they cancel, the item returns to its previous holder.
                                }
                            </p>
                        </div>
                    </div>
                }

                @if (Model.Status == ItemStatus.Sold)
                {
                    <div class="steal-sold-notice">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                        </svg>
                        This item has been sold.
                    </div>
                }

                <hr class="detail-divider" />

                <div class="detail-description-block">
                    <h2 class="detail-section-heading">Description</h2>
                    <p class="detail-description">@Model.Description</p>
                </div>

                <div class="detail-facts">
                    <div class="detail-fact">
                        <span class="detail-fact__label">Listed</span>
                        <span class="detail-fact__value">
                            <time datetime="@Model.CreatedAt.ToString("yyyy-MM-dd")">
                                @Model.CreatedAt.ToString("MMMM d, yyyy")
                            </time>
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Size))
                    {
                        <div class="detail-fact">
                            <span class="detail-fact__label">Size</span>
                            <span class="detail-fact__value">@Model.Size</span>
                        </div>
                    }
                    @if (isStealable)
                    {
                        <div class="detail-fact">
                            <span class="detail-fact__label">Steal window</span>
                            <span class="detail-fact__value">@Model.StealDurationHours hr</span>
                        </div>
                    }
                    <div class="detail-fact">
                        <span class="detail-fact__label">Photos</span>
                        <span class="detail-fact__value">@Model.ImageUrls.Count</span>
                    </div>
                    <div class="detail-fact">
                        <span class="detail-fact__label">Item ID</span>
                        <span class="detail-fact__value">#@Model.Id</span>
                    </div>
                </div>

                <div class="detail-seller detail-seller--inline">
                    <div class="detail-seller__avatar" aria-hidden="true">
                        @sellerDisplay.Substring(0, 1).ToUpper()
                    </div>
                    <div class="detail-seller__info">
                        <p class="detail-seller__label">Listed by</p>
                        <p class="detail-seller__name">@sellerDisplay</p>
                        <p class="detail-seller__since">
                            Member since @(Model.User?.CreatedAt.ToString("MMMM yyyy") ?? "—")
                        </p>
                    </div>
                </div>

                <hr class="detail-divider" />

                @if (isOwner)
                {
                    <div class="detail-actions">
                        <a asp-action="Edit" asp-controller="Items" asp-route-id="@Model.Id"
                               class="detail-btn detail-btn--edit">
                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z" />
                            </svg>
                            Edit Listing
                        </a>
                        <a asp-action="Delete" asp-controller="Items" asp-route-id="@Model.Id"
                               class="detail-btn detail-btn--delete">
                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" />
                            </svg>
                            Delete Listing
                        </a>
                    </div>
                    <p class="detail-owner-note">
                        This is your listing.
                        <a asp-action="Index" asp-controller="Items">View all your listings →</a>
                    </p>
                }
                else if (isAnonymous)
                {
                    <div class="detail-actions">
                        <a asp-action="Login" asp-controller="Auth"
                               asp-route-returnUrl="@Context.Request.Path"
                               class="detail-btn detail-btn--buy">
                            Sign in to Buy
                        </a>
                    </div>
                    <p class="detail-anon-note">
                        <a asp-action="Login" asp-controller="Auth">Sign in</a> or
                        <a asp-action="Register" asp-controller="Auth">create a free account</a>
                        to purchase this item.
                    </p>
                }
                else
                {
                    @if (!isStealable)
                    {
                        @if (Model.Status != ItemStatus.Sold)
                        {
                            @* Fulfillment Method Selection *@
                            <div class="detail-fulfillment-section">
                                <label class="detail-fulfillment-label">How would you like to receive this item?</label>
                                <div class="detail-fulfillment-options">
                                    @if (Model.AllowDelivery)
                                    {
                                        <label class="detail-fulfillment-option @(defaultFulfillmentMethod == "Delivery" ? "detail-fulfillment-option--selected" : "")" data-method="Delivery">
                                            <input type="radio" name="fulfillmentMethod" value="Delivery" class="detail-fulfillment-radio"
                                            @(defaultFulfillmentMethod == "Delivery" ? "checked" : "") />
                                            <div class="detail-fulfillment-option__content">
                                                <div class="detail-fulfillment-option__icon">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                                                        <path d="M4 7h16a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V9a2 2 0 012-2z" />
                                                        <circle cx="7" cy="14" r="2" />
                                                        <circle cx="17" cy="14" r="2" />
                                                    </svg>
                                                </div>
                                                <div class="detail-fulfillment-option__info">
                                                    <span class="detail-fulfillment-option__title">Rider Delivery</span>
                                                    <span class="detail-fulfillment-option__description">Delivery fee: ₱50.00</span>
                                                </div>
                                            </div>
                                        </label>
                                    }
                                    @if (Model.AllowHalfway)
                                    {
                                        <label class="detail-fulfillment-option @(defaultFulfillmentMethod == "Halfway" ? "detail-fulfillment-option--selected" : "")" data-method="Halfway">
                                            <input type="radio" name="fulfillmentMethod" value="Halfway" class="detail-fulfillment-radio"
                                            @(defaultFulfillmentMethod == "Halfway" ? "checked" : "") />
                                            <div class="detail-fulfillment-option__content">
                                                <div class="detail-fulfillment-option__icon">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                                                        <path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7z" />
                                                        <circle cx="12" cy="9" r="3" />
                                                    </svg>
                                                </div>
                                                <div class="detail-fulfillment-option__info">
                                                    <span class="detail-fulfillment-option__title">Halfway Meetup</span>
                                                    <span class="detail-fulfillment-option__description">No delivery fee — coordinate via chat</span>
                                                </div>
                                            </div>
                                        </label>
                                    }
                                    @if (Model.AllowPickup)
                                    {
                                        <label class="detail-fulfillment-option @(defaultFulfillmentMethod == "Pickup" ? "detail-fulfillment-option--selected" : "")" data-method="Pickup">
                                            <input type="radio" name="fulfillmentMethod" value="Pickup" class="detail-fulfillment-radio"
                                            @(defaultFulfillmentMethod == "Pickup" ? "checked" : "") />
                                            <div class="detail-fulfillment-option__content">
                                                <div class="detail-fulfillment-option__icon">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                                                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                                        <path d="M9 22V12h6v10" />
                                                    </svg>
                                                </div>
                                                <div class="detail-fulfillment-option__info">
                                                    <span class="detail-fulfillment-option__title">Self Pickup</span>
                                                    <span class="detail-fulfillment-option__description">No delivery fee — coordinate via chat</span>
                                                </div>
                                            </div>
                                        </label>
                                    }
                                </div>
                            </div>

                            @* Price breakdown *@
                            <div class="detail-price-breakdown" id="priceBreakdown">
                                <div class="detail-breakdown-row">
                                    <span>Item price</span>
                                    <span>₱@Model.Price.ToString("N2")</span>
                                </div>
                                <div class="detail-breakdown-row" id="deliveryFeeRow">
                                    <span>Delivery fee</span>
                                    <span id="deliveryFeeDisplay">₱50.00</span>
                                </div>
                                <div class="detail-breakdown-row detail-breakdown-row--total">
                                    <span>Total</span>
                                    <span id="totalPriceDisplay">₱@((Model.Price + 50).ToString("N2"))</span>
                                </div>
                            </div>

                            @* Dynamic Action Button - changes based on selected fulfillment method *@
                            <div class="detail-actions">
                                @* Buy Now form (for Delivery) *@
                                <form asp-action="BuyNow" asp-controller="Items" method="get" id="buyNowForm" style="display: none;">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="fulfillmentMethod" id="fulfillmentMethodInput" value="@defaultFulfillmentMethod" />
                                    <button type="submit" class="detail-btn detail-btn--buy">
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                                        </svg>
                                        Buy Now
                                    </button>
                                </form>

                                @* Contact Seller form (for Halfway/Pickup) *@
                                <form asp-action="ContactSeller" asp-controller="Items" method="get" id="contactSellerForm" style="display: none;">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="detail-btn detail-btn--contact">
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                            <path d="M2 5a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2h-2.5l-3.5 3-3.5-3H4a2 2 0 01-2-2V5z" />
                                        </svg>
                                        Contact Seller
                                    </button>
                                </form>
                            </div>

                            <p class="detail-fulfillment-hint" id="fulfillmentHint">
                                @if (defaultFulfillmentMethod == "Delivery")
                                {
                                    @:Proceed to checkout — rider will deliver this item.
                                }
                                else
                                {
                                    @:Chat with the seller to coordinate meetup or pickup details.
                                }
                            </p>
                        }
                    }
                    else if (Model.Status == ItemStatus.Available)
                    {
                        <div class="detail-actions">
                            <form asp-action="GetItem" asp-controller="Item" asp-route-id="@Model.Id" method="post" class="get-item-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="detail-btn detail-btn--get" data-get-item>
                                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                                    </svg>
                                    Get this Item
                                </button>
                            </form>
                        </div>
                        <p class="detail-steal-explainer">
                            Claiming this item reserves it at the base price. Another buyer can Steal it
                            — adding ₱50 — within the @Model.StealDurationHours-hour window.
                            If no one steals it, the item is yours to finalise.
                        </p>
                    }
                    else if (Model.Status == ItemStatus.Reserved)
                    {
                        @if (isCurrentWinner)
                        {
                            @if (Model.IsInFinalizeWindow)
                            {
                                <div class="detail-actions">
                                    <a asp-action="Checkout" asp-controller="Orders" asp-route-itemId="@Model.Id"
                                           class="detail-btn detail-btn--complete">
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                        </svg>
                                        Complete Purchase
                                    </a>
                                </div>
                                <p class="detail-steal-explainer detail-steal-explainer--winner">
                                    The steal window has closed — the item is yours! Finalise your
                                    purchase before your 2-hour grace period expires.
                                </p>
                            }
                            else
                            {
                                <div class="detail-actions detail-actions--waiting">
                                    <div class="detail-winner-notice">
                                        <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                                        </svg>
                                        <span>You hold this item at <strong>₱@Model.Price.ToString("N2")</strong>. Watch the countdown — if no one steals it, you can finalise once the timer hits zero.</span>
                                    </div>
                                </div>

                                <div class="detail-cancel-get-wrap">
                                    <p class="detail-cancel-get-hint">Changed your mind?</p>
                                    <form asp-action="CancelGet" asp-controller="Item" asp-route-id="@Model.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="detail-cancel-get-btn">
                                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
                                                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                                            </svg>
                                            Cancel reservation
                                        </button>
                                    </form>
                                    <p class="detail-cancel-get-note">
                                        Cancelling releases your reservation and returns the item to available so anyone can claim it.
                                    </p>
                                </div>
                            }
                        }
                        else
                        {
                            @if (stealWindowOpen)
                            {
                                <div class="detail-actions">
                                    <form asp-action="StealItem" asp-controller="Item" asp-route-id="@Model.Id" method="post" class="steal-item-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="detail-btn detail-btn--steal" data-steal-item>
                                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                                <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                            </svg>
                                            Steal this Item
                                            <span class="detail-btn__badge">+₱50</span>
                                        </button>
                                    </form>
                                </div>
                                <p class="detail-steal-explainer">
                                    Someone has already claimed this item. Steal it now — the price
                                    jumps by ₱50. You'll be sent to checkout to complete the purchase.
                                    You can cancel the steal at checkout if you change your mind.
                                </p>
                            }
                            else if (Model.IsInFinalizeWindow)
                            {
                                <div class="detail-actions detail-actions--waiting">
                                    <div class="detail-locked-notice">
                                        <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
                                        </svg>
                                        <span>The steal window has closed. The original buyer is finalising their purchase.</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="detail-actions">
                                    <button type="button" class="detail-btn detail-btn--buy" disabled>Unavailable</button>
                                </div>
                            }
                        }
                    }
                    else if (isStealable && Model.Status == ItemStatus.StolenPendingCheckout)
                    {
                        @if (isCurrentWinner)
                        {
                            <div class="detail-actions">
                                <a asp-action="Checkout" asp-controller="Orders" asp-route-itemId="@Model.Id"
                                       class="detail-btn detail-btn--complete">
                                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                    </svg>
                                    Complete Purchase
                                </a>
                            </div>
                            <p class="detail-steal-explainer detail-steal-explainer--winner">
                                You stole this item at ₱@Model.Price.ToString("N2"). Complete your
                                purchase to secure it — or cancel at checkout to return it to available.
                            </p>
                        }
                        else if (isOriginalGetter)
                        {
                            <div class="detail-actions detail-actions--waiting">
                                <div class="detail-winner-notice">
                                    <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
                                    </svg>
                                    <span>Someone is stealing your item at the higher price. If they don't complete checkout, your reservation will be fully restored automatically.</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="detail-actions detail-actions--waiting">
                                <div class="detail-locked-notice">
                                    <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
                                    </svg>
                                    <span>A buyer is completing a steal purchase. If they cancel, the item returns to its previous holder.</span>
                                </div>
                            </div>
                        }
                    }

                    @if (TempData["InfoMessage"] is string infoMsg)
                    {
                        <div class="create-toast create-toast--info" data-auto-hide>
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
                            </svg>
                            @infoMsg
                        </div>
                    }
                }
            </section>
        </div>
    </div>

    @* How-it-works modal for Get *@
    <div class="hiw-overlay" id="hiwGetOverlay">
        <div class="hiw-modal">
            <div class="hiw-modal__icon hiw-modal__icon--get">
                <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
            </div>
            <h3 class="hiw-modal__title">How "Get" Works</h3>
            <ul class="hiw-steps hiw-steps--get">
                <li class="hiw-step">
                    <span class="hiw-step__num">1</span>
                    <span class="hiw-step__text"><strong>Claim the item</strong> at the listed price</span>
                </li>
                <li class="hiw-step">
                    <span class="hiw-step__num">2</span>
                    <span class="hiw-step__text">Others can <strong>Steal</strong> it within the time window by paying +₱50</span>
                </li>
                <li class="hiw-step">
                    <span class="hiw-step__num">3</span>
                    <span class="hiw-step__text">If no one steals, you have <strong>2 hours to finalise</strong> your purchase</span>
                </li>
            </ul>
            <div class="hiw-modal__note">
                You can cancel your claim anytime during the steal window.
            </div>
            <div class="hiw-modal__actions">
                <button type="button" class="hiw-modal__proceed hiw-modal__proceed--get" id="hiwGetProceed">Got it — Claim Item</button>
                <label class="hiw-modal__dismiss">
                    <input type="checkbox" id="hiwGetDismiss" />
                    <span>Don't show this again today</span>
                </label>
            </div>
        </div>
    </div>

    @* How-it-works modal for Steal *@
    <div class="hiw-overlay" id="hiwStealOverlay">
        <div class="hiw-modal">
            <div class="hiw-modal__icon hiw-modal__icon--steal">
                <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                </svg>
            </div>
            <h3 class="hiw-modal__title">How "Steal" Works</h3>
            <ul class="hiw-steps hiw-steps--steal">
                <li class="hiw-step">
                    <span class="hiw-step__num">1</span>
                    <span class="hiw-step__text"><strong>Steal the item</strong> by paying the current price +₱50</span>
                </li>
                <li class="hiw-step">
                    <span class="hiw-step__num">2</span>
                    <span class="hiw-step__text">You'll be sent to <strong>checkout immediately</strong></span>
                </li>
                <li class="hiw-step">
                    <span class="hiw-step__num">3</span>
                    <span class="hiw-step__text">Complete your purchase to secure the item</span>
                </li>
            </ul>
            <div class="hiw-modal__note">
                If you cancel at checkout, the item returns to the previous holder at the original price.
            </div>
            <div class="hiw-modal__actions">
                <button type="button" class="hiw-modal__proceed hiw-modal__proceed--steal" id="hiwStealProceed">Got it — Steal Item</button>
                <label class="hiw-modal__dismiss">
                    <input type="checkbox" id="hiwStealDismiss" />
                    <span>Don't show this again today</span>
                </label>
            </div>
        </div>
    </div>

    <style>
            /* Fulfillment badges */
            .detail-fulfillment-badges {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                margin: 0.75rem 0 0.5rem;
            }

            .fulfillment-badge {
                display: inline-flex;
                align-items: center;
                gap: 0.25rem;
                padding: 0.25rem 0.75rem;
                border-radius: 999px;
                font-size: 0.75rem;
                font-weight: 500;
                background: #f3f4f6;
                color: #4b5563;
            }

            .fulfillment-badge--delivery {
                background: #e0f2fe;
                color: #0369a1;
            }

            .fulfillment-badge--halfway {
                background: #fef3c7;
                color: #b45309;
            }

            .fulfillment-badge--pickup {
                background: #dcfce7;
                color: #15803d;
            }

            /* Fulfillment Options Styles */
            .detail-fulfillment-section {
                margin: 1.25rem 0 1rem;
            }

            .detail-fulfillment-label {
                display: block;
                font-size: 0.9rem;
                font-weight: 600;
                margin-bottom: 0.75rem;
                color: #1a1814;
            }

            .detail-fulfillment-options {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }

            .detail-fulfillment-option {
                cursor: pointer;
                display: block;
            }

            .detail-fulfillment-radio {
                display: none;
            }

            .detail-fulfillment-option__content {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.75rem 1rem;
                border: 1.5px solid #e2ddd6;
                border-radius: 10px;
                transition: all 0.15s;
            }

            .detail-fulfillment-option--selected .detail-fulfillment-option__content,
            .detail-fulfillment-radio:checked + .detail-fulfillment-option__content {
                border-color: #2d5a27;
                background: rgba(45, 90, 39, 0.02);
            }

            .detail-fulfillment-option__icon {
                flex-shrink: 0;
                color: #6b7280;
            }

            .detail-fulfillment-option--selected .detail-fulfillment-option__icon,
            .detail-fulfillment-radio:checked + .detail-fulfillment-option__content .detail-fulfillment-option__icon {
                color: #2d5a27;
            }

            .detail-fulfillment-option__info {
                flex: 1;
            }

            .detail-fulfillment-option__title {
                display: block;
                font-weight: 600;
                font-size: 0.9rem;
                color: #1a1814;
            }

            .detail-fulfillment-option__description {
                display: block;
                font-size: 0.75rem;
                color: #6b7280;
                margin-top: 0.125rem;
            }

            /* Price Breakdown */
            .detail-price-breakdown {
                background: #f8f7f5;
                border-radius: 10px;
                padding: 1rem;
                margin-bottom: 1.25rem;
            }

            .detail-breakdown-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0.25rem 0;
                font-size: 0.9rem;
                color: #4b5563;
            }

            .detail-breakdown-row--total {
                margin-top: 0.5rem;
                padding-top: 0.5rem;
                border-top: 1px solid #e2ddd6;
                font-weight: 700;
                font-size: 1rem;
                color: #1a1814;
            }

            /* Contact Seller Button */
            .detail-btn--contact {
                width: 100%;
                justify-content: center;
                padding: 0.875rem 1.5rem;
                font-size: 1rem;
                background: #0095f6;
                color: white;
                border: none;
            }

                .detail-btn--contact:hover {
                    background: #0074cc;
                }

            /* Fulfillment Hint */
            .detail-fulfillment-hint {
                margin-top: 0.75rem;
                font-size: 0.8rem;
                color: #6b7280;
                text-align: center;
            }
    </style>

    <script>
            window.itemDetailsData = {
                itemId: @Model.Id,
                imageUrls: @Json.Serialize(Model.ImageUrls),
                stealEndsAt: '@(Model.StealEndsAt.HasValue ? DateTime.SpecifyKind(Model.StealEndsAt.Value, DateTimeKind.Utc).ToString("O") : "")',
                finalizeDeadline: '@(Model.FinalizeDeadline.HasValue ? DateTime.SpecifyKind(Model.FinalizeDeadline.Value, DateTimeKind.Utc).ToString("O") : "")'
            };

            // Fulfillment method selection - switches between Buy Now and Contact Seller
            (function() {
                'use strict';
            
                const fulfillmentRadios = document.querySelectorAll('.detail-fulfillment-radio');
                const fulfillmentInput = document.getElementById('fulfillmentMethodInput');
                const deliveryFeeRow = document.getElementById('deliveryFeeRow');
                const totalPriceDisplay = document.getElementById('totalPriceDisplay');
                const fulfillmentOptions = document.querySelectorAll('.detail-fulfillment-option');
                const buyNowForm = document.getElementById('buyNowForm');
                const contactSellerForm = document.getElementById('contactSellerForm');
                const fulfillmentHint = document.getElementById('fulfillmentHint');
            
                const itemPrice = @Model.Price;
                const deliveryFee = 50.00;
            
                function updateFulfillmentUI(method) {
                    // Update option selection styling
                    fulfillmentOptions.forEach(function(opt) {
                        opt.classList.remove('detail-fulfillment-option--selected');
                    });
                
                    const selectedOption = document.querySelector('.detail-fulfillment-option[data-method="' + method + '"]');
                    if (selectedOption) {
                        selectedOption.classList.add('detail-fulfillment-option--selected');
                    }
                
                    const isDelivery = method === 'Delivery';
                    const isHalfway = method === 'Halfway';
                    const isPickup = method === 'Pickup';
                
                    // Show/hide delivery fee row
                    if (deliveryFeeRow) {
                        deliveryFeeRow.style.display = isDelivery ? 'flex' : 'none';
                    }
                
                    // Calculate and update total price
                    const total = isDelivery ? itemPrice + deliveryFee : itemPrice;
                    if (totalPriceDisplay) {
                        totalPriceDisplay.textContent = '₱' + total.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                    }
                
                    // Update hidden input
                    if (fulfillmentInput) {
                        fulfillmentInput.value = method;
                    }
                
                    // Toggle between Buy Now and Contact Seller forms
                    if (buyNowForm && contactSellerForm) {
                        if (isDelivery) {
                            buyNowForm.style.display = 'block';
                            contactSellerForm.style.display = 'none';
                            if (fulfillmentHint) {
                                fulfillmentHint.textContent = 'Proceed to checkout — rider will deliver this item.';
                            }
                        } else {
                            buyNowForm.style.display = 'none';
                            contactSellerForm.style.display = 'block';
                            if (fulfillmentHint) {
                                fulfillmentHint.textContent = isHalfway
                                    ? 'Chat with the seller to coordinate a halfway meetup.'
                                    : 'Chat with the seller to arrange pickup details.';
                            }
                        }
                    }
                }
            
                if (fulfillmentRadios.length > 0) {
                    fulfillmentRadios.forEach(function(radio) {
                        radio.addEventListener('change', function() {
                            updateFulfillmentUI(radio.value);
                        });
                    });
                
                    fulfillmentOptions.forEach(function(opt) {
                        opt.addEventListener('click', function(e) {
                            const radio = this.querySelector('.detail-fulfillment-radio');
                            if (radio && !radio.disabled) {
                                radio.checked = true;
                                updateFulfillmentUI(radio.value);
                            }
                        });
                    });
                
                    // Initialize UI with default selection
                    const checkedFulfillment = document.querySelector('.detail-fulfillment-radio:checked');
                    if (checkedFulfillment) {
                        updateFulfillmentUI(checkedFulfillment.value);
                    } else {
                        // Default to first available option
                        const firstOption = document.querySelector('.detail-fulfillment-radio');
                        if (firstOption) {
                            firstOption.checked = true;
                            updateFulfillmentUI(firstOption.value);
                        }
                    }
                }
            })();
    </script>
    <script src="~/js/items-details.js" asp-append-version="true"></script>
</body>
</html>