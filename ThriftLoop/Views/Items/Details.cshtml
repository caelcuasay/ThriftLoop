@model ThriftLoop.Models.Item
@using ThriftLoop.Models
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool isOwner = (bool)(ViewBag.IsOwner ?? false);
    bool isAnonymous = (bool)(ViewBag.IsAnonymous ?? true);
    bool isCurrentWinner = (bool)(ViewBag.IsCurrentWinner ?? false);

    bool isStealable = Model.ListingType == ListingType.Stealable;
    bool stealWindowOpen = isStealable
                           && Model.Status == ItemStatus.Reserved
                           && Model.StealEndsAt.HasValue
                           && DateTime.UtcNow <= Model.StealEndsAt.Value;

    @* Derive a display name from the seller's email: take the part before '@' *@
    string sellerDisplay = Model.User is not null
        ? Model.User.Email.Split('@')[0]
        : "Unknown seller";

    @* Condition → colour class *@
    string condClass = Model.Condition switch
    {
        "New" => "detail-condition--new",
        "Like New" => "detail-condition--like-new",
        "Good" => "detail-condition--good",
        "Fair" => "detail-condition--fair",
        _ => "detail-condition--poor"
    };

    @* Price label changes for Stealable listings to reflect dynamic nature *@
    string priceLabel = isStealable ? "Starting price" : "Fixed price";
    if (isStealable && Model.Status == ItemStatus.Reserved)
        priceLabel = "Current price";
}

<div class="detail-shell">

    @* ── Back navigation ────────────────────────────────────────────────────── *@
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a asp-action="Index" asp-controller="Home" class="detail-breadcrumb__link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Back to listings
        </a>
    </nav>

    @* ── Two-column layout ──────────────────────────────────────────────────── *@
    <div class="detail-grid">

        @* ════════════════════════════════
           LEFT — Image
           ════════════════════════════════ *@
        <aside class="detail-img-col">

            <div class="detail-img-frame">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl"
                         alt="Photo of @Model.Title"
                         class="detail-img"
                         loading="eager" />
                }
                else
                {
                    <div class="detail-img detail-img--placeholder" aria-hidden="true">
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4">
                            <rect x="6" y="10" width="52" height="44" rx="6" />
                            <circle cx="22" cy="26" r="6" />
                            <path d="M6 46l16-14 10 10 8-7 18 15" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span>No photo</span>
                    </div>
                }

                @* Stealable badge overlaid on the image — visible on both columns *@
                @if (isStealable)
                {
                    <span class="detail-stealable-badge" aria-label="Stealable listing">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                            <path d="M8.75 3.75a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" />
                        </svg>
                        Stealable
                    </span>
                }
            </div>

            @* Seller card — desktop: in the image column *@
            <div class="detail-seller detail-seller--below-img">
                <div class="detail-seller__avatar" aria-hidden="true">
                    @sellerDisplay.Substring(0, 1).ToUpper()
                </div>
                <div class="detail-seller__info">
                    <p class="detail-seller__label">Listed by</p>
                    <p class="detail-seller__name">@sellerDisplay</p>
                    <p class="detail-seller__since">
                        Member since @(Model.User?.CreatedAt.ToString("MMMM yyyy") ?? "—")
                    </p>
                </div>
            </div>

        </aside>

        @* ════════════════════════════════
           RIGHT — Details
           ════════════════════════════════ *@
        <section class="detail-info-col">

            @* Category + condition + size badges *@
            <div class="detail-meta-row">
                <span class="detail-category">@Model.Category</span>
                <span class="detail-condition @condClass">@Model.Condition</span>
                @if (!string.IsNullOrEmpty(Model.Size))
                {
                    <span class="detail-size">@Model.Size</span>
                }
                @if (isStealable)
                {
                    <span class="detail-listing-type-badge">
                        <svg viewBox="0 0 14 14" fill="currentColor" width="10" height="10" aria-hidden="true">
                            <path d="M7 1a6 6 0 100 12A6 6 0 007 1zm.6 8.9H6.4V6.4h1.2v3.5zm0-4.6H6.4V4.1h1.2v1.2z" />
                        </svg>
                        Stealable
                    </span>
                }
            </div>

            @* Title *@
            <h1 class="detail-title">@Model.Title</h1>

            @* Price block *@
            <div class="detail-price-block">
                <span class="detail-price">₱@Model.Price.ToString("N2")</span>
                <span class="detail-price-label">@priceLabel</span>
                @if (isStealable && Model.Status == ItemStatus.Available)
                {
                    <span class="detail-steal-note">+₱50 if stolen</span>
                }
            </div>

            @* ── Stealable countdown / status banner ────────────────────────── *@
            @if (isStealable && Model.Status == ItemStatus.Reserved && Model.StealEndsAt.HasValue)
            {
                if (stealWindowOpen)
                {
                    <div class="steal-countdown-card" id="stealCountdownCard">
                        <div class="steal-countdown-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="steal-countdown-card__body">
                            <p class="steal-countdown-card__label">Steal window closes in</p>
                            <p class="steal-countdown-card__timer"
                               id="stealTimer"
                               data-ends-at="@(DateTime.SpecifyKind(Model.StealEndsAt.Value, DateTimeKind.Utc).ToString("O"))">
                                ——:——:——
                            </p>
                        </div>
                    </div>
                }
                else if (Model.IsInFinalizeWindow)
                {
                    <div class="steal-countdown-card steal-countdown-card--finalize">
                        <div class="steal-countdown-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="steal-countdown-card__body">
                            <p class="steal-countdown-card__label">Steal window closed — finalise window open</p>
                            <p class="steal-countdown-card__timer"
                               id="finalizeTimer"
                               data-ends-at="@(DateTime.SpecifyKind(Model.FinalizeDeadline!.Value, DateTimeKind.Utc).ToString("O"))">
                                ——:——:——
                            </p>
                        </div>
                    </div>
                }
            }

            @if (isStealable && Model.Status == ItemStatus.Sold)
            {
                <div class="steal-sold-notice">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                    This item has been sold.
                </div>
            }

            <hr class="detail-divider" />

            @* Description *@
            <div class="detail-description-block">
                <h2 class="detail-section-heading">Description</h2>
                <p class="detail-description">@Model.Description</p>
            </div>

            @* Facts grid *@
            <div class="detail-facts">
                <div class="detail-fact">
                    <span class="detail-fact__label">Listed</span>
                    <span class="detail-fact__value">
                        <time datetime="@Model.CreatedAt.ToString("yyyy-MM-dd")">
                            @Model.CreatedAt.ToString("MMMM d, yyyy")
                        </time>
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Size))
                {
                    <div class="detail-fact">
                        <span class="detail-fact__label">Size</span>
                        <span class="detail-fact__value">@Model.Size</span>
                    </div>
                }
                @if (isStealable)
                {
                    <div class="detail-fact">
                        <span class="detail-fact__label">Steal window</span>
                        <span class="detail-fact__value">@Model.StealDurationHours hr</span>
                    </div>
                }
                <div class="detail-fact">
                    <span class="detail-fact__label">Item ID</span>
                    <span class="detail-fact__value">#@Model.Id</span>
                </div>
            </div>

            @* Seller — mobile: inline in the info column *@
            <div class="detail-seller detail-seller--inline">
                <div class="detail-seller__avatar" aria-hidden="true">
                    @sellerDisplay.Substring(0, 1).ToUpper()
                </div>
                <div class="detail-seller__info">
                    <p class="detail-seller__label">Listed by</p>
                    <p class="detail-seller__name">@sellerDisplay</p>
                    <p class="detail-seller__since">
                        Member since @(Model.User?.CreatedAt.ToString("MMMM yyyy") ?? "—")
                    </p>
                </div>
            </div>

            <hr class="detail-divider" />

            @* ── Action buttons ──────────────────────────────────────────────── *@

            @* ── 1. Owner ──────────────────────────────────────────────── *@
            @if (isOwner)
            {
                <div class="detail-actions">
                    <a asp-action="Edit"
                       asp-controller="Items"
                       asp-route-id="@Model.Id"
                       class="detail-btn detail-btn--edit">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z" />
                        </svg>
                        Edit Listing
                    </a>
                    <a asp-action="Delete"
                       asp-controller="Items"
                       asp-route-id="@Model.Id"
                       class="detail-btn detail-btn--delete">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd"
                                  d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z"
                                  clip-rule="evenodd" />
                        </svg>
                        Delete Listing
                    </a>
                </div>
                <p class="detail-owner-note">
                    This is your listing.
                    <a asp-action="Index" asp-controller="Items">View all your listings →</a>
                </p>
            }

            @* ── 2. Anonymous visitor ──────────────────────────────────── *@
            else if (isAnonymous)
            {
                <div class="detail-actions">
                    <a asp-action="Login"
                       asp-controller="Auth"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="detail-btn detail-btn--buy">
                        Sign in to Buy
                    </a>
                    <a asp-action="Login"
                       asp-controller="Auth"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="detail-btn detail-btn--cart">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path d="M1 1.75A.75.75 0 011.75 1h1.628a1.75 1.75 0 011.734 1.51L5.61 7h9.945a.75.75 0 01.736.88l-1.5 7.5a.75.75 0 01-.736.62H6.75a.75.75 0 01-.736-.62L4.514 7.88l-.002-.009-.44-4.371A.25.25 0 003.826 3H1.75A.75.75 0 011 2.25v-.5zM6.75 8.5l1.25 6.25H13l1.25-6.25H6.75z" />
                            <path d="M7.5 16a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM13.5 16a1.5 1.5 0 110 3 1.5 1.5 0 010-3z" />
                        </svg>
                        Add to Cart
                    </a>
                </div>
                <p class="detail-anon-note">
                    <a asp-action="Login" asp-controller="Auth">Sign in</a> or
                    <a asp-action="Register" asp-controller="Auth">create a free account</a>
                    to purchase this item.
                </p>
            }

            @* ── 3. Authenticated buyer ────────────────────────────────── *@
            else
            {
                @* ══════════════════════════════════
                   3a. STANDARD listing
                   ══════════════════════════════════ *@
                @if (!isStealable)
                {
                    <div class="detail-actions">
                        @* Checkout for Standard listings is a future controller action.
                           These buttons are intentional stubs until Orders/Checkout exists. *@
                        <button type="button" class="detail-btn detail-btn--buy" disabled>
                            Buy Now
                        </button>
                        <button type="button" class="detail-btn detail-btn--cart" disabled>
                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path d="M1 1.75A.75.75 0 011.75 1h1.628a1.75 1.75 0 011.734 1.51L5.61 7h9.945a.75.75 0 01.736.88l-1.5 7.5a.75.75 0 01-.736.62H6.75a.75.75 0 01-.736-.62L4.514 7.88l-.002-.009-.44-4.371A.25.25 0 003.826 3H1.75A.75.75 0 011 2.25v-.5zM6.75 8.5l1.25 6.25H13l1.25-6.25H6.75z" />
                                <path d="M7.5 16a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM13.5 16a1.5 1.5 0 110 3 1.5 1.5 0 010-3z" />
                            </svg>
                            Add to Cart
                        </button>
                    </div>
                }

                @* ══════════════════════════════════
                   3b. STEALABLE — Available
                   First buyer to click "Get" claims the base price and starts the timer.
                   ══════════════════════════════════ *@
                else if (Model.Status == ItemStatus.Available)
                {
                    <div class="detail-actions">
                        <form asp-action="GetItem"
                              asp-controller="Items"
                              asp-route-id="@Model.Id"
                              method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="detail-btn detail-btn--get">
                                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                                </svg>
                                Get this Item
                            </button>
                        </form>
                    </div>
                    <p class="detail-steal-explainer">
                        Claiming this item reserves it at the base price. Another buyer can Steal it
                        — adding ₱50 — within the @Model.StealDurationHours-hour window.
                        If no one steals it, the item is yours to finalise.
                    </p>
                }

                @* ══════════════════════════════════
                   3c. STEALABLE — Reserved
                   Subdivide by who the current user is relative to the reservation.
                   ══════════════════════════════════ *@
                else if (Model.Status == ItemStatus.Reserved)
                {
                    @* Current user holds the reservation *@
                    @if (isCurrentWinner)
                    {
                        @if (Model.IsInFinalizeWindow)
                        {
                            @* Steal window has closed; winner can now finalise *@
                            <div class="detail-actions">
                                @* Replace "Orders" / "Checkout" with your actual route when ready. *@
                                <a asp-action="Checkout"
                                   asp-controller="Orders"
                                   asp-route-itemId="@Model.Id"
                                   class="detail-btn detail-btn--complete">
                                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                    </svg>
                                    Complete Purchase
                                </a>
                            </div>
                            <p class="detail-steal-explainer detail-steal-explainer--winner">
                                The steal window has closed — the item is yours! Finalise your
                                purchase before your 2-hour grace period expires.
                            </p>
                        }
                        else
                        {
                            @* Still inside the steal window — user can only wait *@
                            <div class="detail-actions detail-actions--waiting">
                                <div class="detail-winner-notice">
                                    <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                                    </svg>
                                    <span>You hold this item at <strong>₱@Model.Price.ToString("N2")</strong>. Watch the countdown — if no one steals it, you can finalise once the timer hits zero.</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        @* Another buyer holds the reservation *@
                        @if (stealWindowOpen)
                        {
                            @* Steal window still open — this buyer can steal *@
                            <div class="detail-actions">
                                <form asp-action="StealItem"
                                      asp-controller="Items"
                                      asp-route-id="@Model.Id"
                                      method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="detail-btn detail-btn--steal">
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="18" height="18">
                                            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                            <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                        </svg>
                                        Steal this Item
                                        <span class="detail-btn__badge">+₱50</span>
                                    </button>
                                </form>
                            </div>
                            <p class="detail-steal-explainer">
                                Someone has already claimed this item. Steal it now — the price
                                jumps by ₱50 and you'll be taken directly to checkout.
                                This can only happen once.
                            </p>
                        }
                        else if (Model.IsInFinalizeWindow)
                        {
                            @* Window expired and original winner is finalising — locked out *@
                            <div class="detail-actions detail-actions--waiting">
                                <div class="detail-locked-notice">
                                    <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
                                    </svg>
                                    <span>The steal window has closed. The original buyer is finalising their purchase.</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            @* Reserved but in an indeterminate state — show disabled placeholder *@
                            <div class="detail-actions">
                                <button type="button" class="detail-btn detail-btn--buy" disabled>
                                    Unavailable
                                </button>
                            </div>
                        }
                    }
                }

                @* ══════════════════════════════════
                   3d. STEALABLE — Sold
                   ══════════════════════════════════ *@
                else
                {
                    <div class="detail-actions">
                        <button type="button" class="detail-btn detail-btn--buy" disabled>
                            Sold
                        </button>
                    </div>
                }
            }

        </section>

    </div>

</div>

@section Scripts {
    <style>
        /* ── Stealable badge on image ──────────────────────────────────────── */
        .detail-img-frame {
            position: relative;
        }

        .detail-stealable-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: var(--color-primary, #2d5a27);
            color: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            padding: 4px 9px;
            border-radius: 6px;
            box-shadow: 0 2px 8px rgba(0,0,0,.18);
            z-index: 2;
        }

        /* ── Listing-type badge in meta row ───────────────────────────────── */
        .detail-listing-type-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: color-mix(in srgb, var(--color-primary, #2d5a27) 12%, transparent);
            color: var(--color-primary, #2d5a27);
            border: 1px solid color-mix(in srgb, var(--color-primary, #2d5a27) 25%, transparent);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            padding: 3px 8px;
            border-radius: 5px;
        }

        /* ── Steal note next to price ──────────────────────────────────────── */
        .detail-steal-note {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.8125rem;
            color: var(--color-primary, #2d5a27);
            font-weight: 500;
            margin-left: 0.25rem;
            align-self: flex-end;
            padding-bottom: 2px;
        }

        /* ── Countdown card ───────────────────────────────────────────────── */
        .steal-countdown-card {
            display: flex;
            align-items: center;
            gap: 0.875rem;
            background: color-mix(in srgb, var(--color-primary, #2d5a27) 7%, transparent);
            border: 1px solid color-mix(in srgb, var(--color-primary, #2d5a27) 20%, transparent);
            border-radius: 10px;
            padding: 0.875rem 1rem;
            margin: 1rem 0;
        }

        .steal-countdown-card--finalize {
            background: color-mix(in srgb, #b45309 7%, transparent);
            border-color: color-mix(in srgb, #b45309 20%, transparent);
        }

            .steal-countdown-card--finalize .steal-countdown-card__icon {
                color: #b45309;
            }

