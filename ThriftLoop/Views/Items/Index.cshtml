@model IReadOnlyList<ThriftLoop.Models.Item>
@using ThriftLoop.Enums
@using ThriftLoop.Models
@{
    ViewData["Title"] = "My Listings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .my-listings {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .my-listings__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .my-listings__title {
            font-family: 'DM Serif Display', serif;
            font-size: 2rem;
            color: var(--color-text, #1a1814);
            margin: 0;
        }

        .my-listings__count {
            color: var(--color-muted, #6b6560);
            font-size: 0.9rem;
            margin-left: 0.75rem;
            font-weight: 400;
        }

        .my-listings__grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .listing-card {
            background: #fff;
            border: 1px solid var(--color-border, #e2ddd6);
            border-radius: 16px;
            overflow: hidden;
            transition: box-shadow 0.2s, transform 0.2s;
            position: relative;
        }

            .listing-card:hover {
                box-shadow: 0 8px 24px rgba(0,0,0,0.08);
                transform: translateY(-2px);
            }

        .listing-card__img-wrap {
            position: relative;
            aspect-ratio: 1 / 1;
            background: #f5f3f0;
        }

        .listing-card__img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .listing-card__img-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-muted, #6b6560);
        }

        .listing-card__status {
            position: absolute;
            top: 10px;
            left: 10px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(4px);
            color: var(--color-text, #1a1814);
        }

        .listing-card__status--reserved {
            background: #fef3c7;
            color: #92400e;
        }

        .listing-card__status--sold {
            background: #e5e7eb;
            color: #374151;
        }

        .listing-card__status--disabled {
            background: #f3f4f6;
            color: #6b7280;
        }

        .listing-card__discount-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 4px 8px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            background: #dc2626;
            color: white;
            z-index: 2;
        }

        .listing-card__body {
            padding: 1rem;
        }

        .listing-card__title {
            font-size: 1rem;
            font-weight: 600;
            margin: 0 0 0.5rem;
            color: var(--color-text, #1a1814);
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

            .listing-card__title a {
                color: inherit;
                text-decoration: none;
            }

                .listing-card__title a:hover {
                    color: var(--color-primary, #2d5a27);
                }

        .listing-card__price-section {
            margin-bottom: 0.75rem;
        }

        .listing-card__price {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--color-primary, #2d5a27);
        }

        .listing-card__original-price {
            font-size: 0.85rem;
            color: var(--color-muted, #6b6560);
            text-decoration: line-through;
            margin-left: 0.5rem;
        }

        .listing-card__discount-expiry {
            font-size: 0.7rem;
            color: #dc2626;
            margin-top: 0.25rem;
        }

        .listing-card__meta {
            display: flex;
            gap: 0.5rem;
            font-size: 0.75rem;
            color: var(--color-muted, #6b6560);
            margin-bottom: 1rem;
        }

        .listing-card__type-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 2px 8px;
            background: #f0fdf4;
            color: #166534;
            border-radius: 20px;
            font-size: 0.65rem;
            font-weight: 600;
        }

        .listing-card__actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            border-top: 1px solid var(--color-border, #e2ddd6);
            padding-top: 0.75rem;
            margin-top: 0.5rem;
        }

        .listing-card__btn {
            flex: 1;
            padding: 0.5rem;
            font-size: 0.75rem;
            font-weight: 500;
            text-align: center;
            text-decoration: none;
            border-radius: 8px;
            border: 1px solid var(--color-border, #e2ddd6);
            background: #fff;
            color: var(--color-text, #1a1814);
            cursor: pointer;
            transition: all 0.15s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.25rem;
        }

            .listing-card__btn:hover {
                background: #f5f3f0;
            }

        .listing-card__btn--primary {
            background: var(--color-primary, #2d5a27);
            border-color: var(--color-primary, #2d5a27);
            color: white;
        }

            .listing-card__btn--primary:hover {
                background: #1e401a;
            }

        .listing-card__btn--danger {
            color: #dc2626;
            border-color: #fecaca;
        }

            .listing-card__btn--danger:hover {
                background: #fef2f2;
            }

        .listing-card__btn--discount {
            background: #fef3c7;
            border-color: #fde68a;
            color: #92400e;
        }

            .listing-card__btn--discount:hover {
                background: #fde68a;
            }

        .listing-card__btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--color-muted, #6b6560);
        }

        .empty-state__icon {
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        /* Discount Modal */
        .discount-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .discount-modal {
            background: #fff;
            border-radius: 20px;
            padding: 1.75rem;
            max-width: 420px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }

        .discount-modal__title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.5rem;
            margin: 0 0 0.5rem;
        }

        .discount-modal__subtitle {
            color: var(--color-muted, #6b6560);
            font-size: 0.875rem;
            margin-bottom: 1.5rem;
        }

        .discount-modal__item-preview {
            display: flex;
            gap: 1rem;
            padding: 1rem;
            background: #f8f7f5;
            border-radius: 12px;
            margin-bottom: 1.5rem;
        }

        .discount-modal__item-img {
            width: 60px;
            height: 60px;
            border-radius: 8px;
            object-fit: cover;
        }

        .discount-modal__item-info {
            flex: 1;
        }

        .discount-modal__item-title {
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .discount-modal__item-price {
            color: var(--color-muted, #6b6560);
            font-size: 0.875rem;
        }

        .discount-presets {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .discount-preset {
            flex: 1;
            padding: 0.625rem;
            border: 1.5px solid var(--color-border, #e2ddd6);
            border-radius: 10px;
            background: #fff;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
        }

            .discount-preset:hover {
                border-color: var(--color-primary, #2d5a27);
            }

        .discount-preset--active {
            border-color: var(--color-primary, #2d5a27);
            background: #f0fdf4;
            color: var(--color-primary, #2d5a27);
        }

        .discount-field {
            margin-bottom: 1.25rem;
        }

        .discount-field__label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 0.375rem;
            color: var(--color-text, #1a1814);
        }

        .discount-field__input-wrapper {
            display: flex;
            align-items: center;
            border: 1.5px solid var(--color-border, #e2ddd6);
            border-radius: 10px;
            padding: 0 0.75rem;
        }

            .discount-field__input-wrapper:focus-within {
                border-color: var(--color-primary, #2d5a27);
            }

        .discount-field__input {
            flex: 1;
            border: none;
            padding: 0.75rem 0;
            font-size: 1rem;
            outline: none;
        }

        .discount-field__suffix {
            color: var(--color-muted, #6b6560);
            font-weight: 500;
        }

        .discount-expiry-options {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .discount-expiry-option {
            flex: 1;
            padding: 0.5rem;
            border: 1.5px solid var(--color-border, #e2ddd6);
            border-radius: 8px;
            background: #fff;
            font-size: 0.8rem;
            cursor: pointer;
            text-align: center;
        }

        .discount-expiry-option--active {
            border-color: var(--color-primary, #2d5a27);
            background: #f0fdf4;
        }

        .discount-preview {
            padding: 1rem;
            background: #f0fdf4;
            border-radius: 10px;
            margin: 1rem 0;
        }

        .discount-preview__row {
            display: flex;
            justify-content: space-between;
            font-size: 0.875rem;
        }

        .discount-preview__new-price {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--color-primary, #2d5a27);
        }

        .discount-modal__actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }

        .discount-modal__error {
            color: #dc2626;
            font-size: 0.8rem;
            margin-top: 0.5rem;
        }

        .has-discount-badge {
            background: #dcfce7;
            color: #166534;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 0.65rem;
            font-weight: 600;
            margin-left: 0.5rem;
        }
    </style>
}

<div class="my-listings">
    <div class="my-listings__header">
        <h1 class="my-listings__title">
            My Listings
            <span class="my-listings__count">@Model.Count item@(Model.Count != 1 ? "s" : "")</span>
        </h1>
        <a asp-action="Create" class="tl-btn tl-btn--primary">
            <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                <path d="M7.75 2a.75.75 0 01.75.75V7h4.25a.75.75 0 010 1.5H8.5v4.25a.75.75 0 01-1.5 0V8.5H2.75a.75.75 0 010-1.5H7V2.75A.75.75 0 017.75 2z" />
            </svg>
            List New Item
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state__icon">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4" width="64" height="64">
                    <rect x="8" y="14" width="48" height="36" rx="6" />
                    <path d="M22 14v-4a6 6 0 0112 0v4" stroke-linecap="round" />
                    <path d="M24 33h16M32 25v16" stroke-linecap="round" />
                </svg>
            </div>
            <h3>No listings yet</h3>
            <p>Start selling by listing your first item!</p>
            <a asp-action="Create" class="tl-btn tl-btn--primary" style="margin-top:1rem">List New Item</a>
        </div>
    }
    else
    {
        <div class="my-listings__grid">
            @foreach (var item in Model)
            {
                var statusClass = item.Status switch
                {
                    ItemStatus.Reserved => "listing-card__status--reserved",
                    ItemStatus.Sold => "listing-card__status--sold",
                    ItemStatus.Disabled => "listing-card__status--disabled",
                    _ => ""
                };
                
                var canDiscount = item.CanBeDiscounted && item.Status == ItemStatus.Available;
                var hasDiscount = item.HasActiveDiscount;

                <div class="listing-card" data-item-id="@item.Id">
                    <div class="listing-card__img-wrap">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Title" class="listing-card__img" loading="lazy" />
                        }
                        else
                        {
                            <div class="listing-card__img-placeholder">No Image</div>
                        }
                        
                        <span class="listing-card__status @statusClass">@item.Status</span>
                        
                        @if (hasDiscount)
                        {
                            <span class="listing-card__discount-badge">-@(item.DiscountPercentage?.ToString("F0"))%</span>
                        }
                    </div>

                    <div class="listing-card__body">
                        <h3 class="listing-card__title">
                            <a asp-action="Details" asp-route-id="@item.Id">@item.Title</a>
                        </h3>

                        <div class="listing-card__price-section">
                            <span class="listing-card__price">₱@item.Price.ToString("N2")</span>
                            @if (hasDiscount)
                            {
                                <span class="listing-card__original-price">₱@item.OriginalPrice?.ToString("N2")</span>
                                @if (item.DiscountExpiresAt.HasValue)
                                {
                                    var timeLeft = item.DiscountExpiresAt.Value - DateTime.UtcNow;
                                    var expiryText = timeLeft.TotalDays >= 1
                                        ? $"{(int)timeLeft.TotalDays}d left"
                                        : timeLeft.TotalHours >= 1
                                            ? $"{(int)timeLeft.TotalHours}h left"
                                            : "Ending soon";
                                    <div class="listing-card__discount-expiry">⏰ @expiryText</div>
                                }
                            }
                        </div>

                        <div class="listing-card__meta">
                            <span>@item.Category</span>
                            <span>•</span>
                            <span>@item.Condition</span>
                            @if (item.ListingType == ListingType.Stealable)
                            {
                                <span class="listing-card__type-badge">
                                    <svg viewBox="0 0 16 16" fill="currentColor" width="10" height="10">
                                        <path d="M9.504.43a1.516 1.516 0 012.437 1.713L10.5 6h3.798a1.516 1.516 0 011.149 2.506l-6 7a1.516 1.516 0 01-2.631-1.275L7.5 10H4.701a1.516 1.516 0 01-1.149-2.506l6-7z" />
                                    </svg>
                                    Stealable
                                </span>
                            }
                            @if (hasDiscount)
                            {
                                <span class="has-discount-badge">Discounted</span>
                            }
                        </div>

                        <div class="listing-card__actions">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="listing-card__btn">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="listing-card__btn listing-card__btn--danger">Delete</a>
                            
                            @if (canDiscount && !hasDiscount)
                            {
                                <button type="button" class="listing-card__btn listing-card__btn--discount"
                                        onclick="openDiscountModal(@item.Id, '@item.Title', @item.Price, '@item.ImageUrl')">
                                    <svg viewBox="0 0 16 16" fill="currentColor" width="10" height="10">
                                        <path d="M14 4.5L9 1.5v6l5-3zM7 2.5L2 5.5v5l5 3 5-3v-5L7 2.5z" />
                                    </svg>
                                    Mark Down
                                </button>
                            }
                            else if (hasDiscount)
                            {
                                <button type="button" class="listing-card__btn" onclick="removeDiscount(@item.Id)">
                                    Remove Discount
                                </button>
                            }
                            else if (!canDiscount && item.Status == ItemStatus.Available && !hasDiscount)
                            {
                                var hoursUntil = 24 - (int)(DateTime.UtcNow - item.CreatedAt).TotalHours;
                                <button type="button" class="listing-card__btn" disabled title="Discount available in @hoursUntil hour@(hoursUntil != 1 ? "s" : "")">
                                    ⏳ @hoursUntil h
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Discount Modal *@
<div id="discountModal" class="discount-modal-backdrop" style="display:none;">
    <div class="discount-modal">
        <h2 class="discount-modal__title">Apply Discount</h2>
        <p class="discount-modal__subtitle">Set a discount for your listing</p>

        <div class="discount-modal__item-preview">
            <img id="modalItemImage" src="" alt="" class="discount-modal__item-img" />
            <div class="discount-modal__item-info">
                <div class="discount-modal__item-title" id="modalItemTitle"></div>
                <div class="discount-modal__item-price">Current: ₱<span id="modalCurrentPrice"></span></div>
            </div>
        </div>

        <input type="hidden" id="modalItemId" />

        <div class="discount-presets">
            <button type="button" class="discount-preset" data-percent="5">5%</button>
            <button type="button" class="discount-preset" data-percent="10">10%</button>
            <button type="button" class="discount-preset" data-percent="20">20%</button>
        </div>

        <div class="discount-field">
            <label class="discount-field__label">Custom Percentage</label>
            <div class="discount-field__input-wrapper">
                <input type="number" id="discountPercent" class="discount-field__input"
                       min="1" max="99" step="1" value="10" placeholder="10" />
                <span class="discount-field__suffix">%</span>
            </div>
        </div>

        <label class="discount-field__label">Discount Duration</label>
        <div class="discount-expiry-options">
            <button type="button" class="discount-expiry-option discount-expiry-option--active" data-duration="indefinite">Indefinite</button>
            <button type="button" class="discount-expiry-option" data-duration="24">24 hours</button>
            <button type="button" class="discount-expiry-option" data-duration="72">3 days</button>
            <button type="button" class="discount-expiry-option" data-duration="168">7 days</button>
        </div>

        <div class="discount-preview" id="discountPreview">
            <div class="discount-preview__row">
                <span>Original Price</span>
                <span id="previewOriginal">₱0.00</span>
            </div>
            <div class="discount-preview__row">
                <span>You Save</span>
                <span id="previewSavings">₱0.00</span>
            </div>
            <div class="discount-preview__row" style="margin-top:0.75rem;font-weight:600;">
                <span>New Price</span>
                <span class="discount-preview__new-price" id="previewNewPrice">₱0.00</span>
            </div>
        </div>

        <div id="modalError" class="discount-modal__error" style="display:none;"></div>

        <div class="discount-modal__actions">
            <button type="button" class="tl-btn tl-btn--ghost" onclick="closeDiscountModal()" style="flex:1">Cancel</button>
            <button type="button" class="tl-btn tl-btn--primary" onclick="applyDiscount()" style="flex:1">Apply Discount</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentItemId = 0;
        let currentOriginalPrice = 0;
        let selectedDuration = null; // null = indefinite
        const afToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        function openDiscountModal(itemId, title, price, imageUrl) {
            currentItemId = itemId;
            currentOriginalPrice = price;
            selectedDuration = null;
            
            document.getElementById('modalItemId').value = itemId;
            document.getElementById('modalItemTitle').textContent = title;
            document.getElementById('modalCurrentPrice').textContent = price.toLocaleString('en-PH', { minimumFractionDigits: 2 });
            document.getElementById('modalItemImage').src = imageUrl || '/images/placeholder.png';
            document.getElementById('discountPercent').value = 10;
            
            document.querySelectorAll('.discount-preset').forEach(p => p.classList.remove('discount-preset--active'));
            document.querySelector('.discount-preset[data-percent="10"]').classList.add('discount-preset--active');
            
            document.querySelectorAll('.discount-expiry-option').forEach(o => o.classList.remove('discount-expiry-option--active'));
            document.querySelector('.discount-expiry-option[data-duration="indefinite"]').classList.add('discount-expiry-option--active');
            
            document.getElementById('modalError').style.display = 'none';
            
            updatePreview();
            
            document.getElementById('discountModal').style.display = 'flex';
        }

        function closeDiscountModal() {
            document.getElementById('discountModal').style.display = 'none';
        }

        function updatePreview() {
            const percent = parseFloat(document.getElementById('discountPercent').value) || 10;
            const newPrice = currentOriginalPrice * (1 - percent / 100);
            const savings = currentOriginalPrice - newPrice;
            
            document.getElementById('previewOriginal').textContent = '₱' + currentOriginalPrice.toLocaleString('en-PH', { minimumFractionDigits: 2 });
            document.getElementById('previewSavings').textContent = '₱' + savings.toLocaleString('en-PH', { minimumFractionDigits: 2 });
            document.getElementById('previewNewPrice').textContent = '₱' + newPrice.toLocaleString('en-PH', { minimumFractionDigits: 2 });
        }

        // Preset click handlers
        document.querySelectorAll('.discount-preset').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.discount-preset').forEach(p => p.classList.remove('discount-preset--active'));
                this.classList.add('discount-preset--active');
                document.getElementById('discountPercent').value = this.dataset.percent;
                updatePreview();
            });
        });

        // Expiry option handlers
        document.querySelectorAll('.discount-expiry-option').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.discount-expiry-option').forEach(o => o.classList.remove('discount-expiry-option--active'));
                this.classList.add('discount-expiry-option--active');
                selectedDuration = this.dataset.duration === 'indefinite' ? null : parseInt(this.dataset.duration);
            });
        });

        // Manual percent input
        document.getElementById('discountPercent').addEventListener('input', function() {
            let val = parseInt(this.value) || 10;
            val = Math.max(1, Math.min(99, val));
            this.value = val;
            
            document.querySelectorAll('.discount-preset').forEach(p => p.classList.remove('discount-preset--active'));
            updatePreview();
        });

        async function applyDiscount() {
            const percent = parseFloat(document.getElementById('discountPercent').value);
            if (percent < 1 || percent > 99) {
                showModalError('Discount must be between 1% and 99%.');
                return;
            }

            let expiresAt = null;
            if (selectedDuration) {
                const date = new Date();
                date.setHours(date.getHours() + selectedDuration);
                expiresAt = date.toISOString();
            }

            const btn = document.querySelector('#discountModal .tl-btn--primary');
            btn.disabled = true;
            btn.textContent = 'Applying...';

            try {
                const response = await fetch('/Items/ApplyDiscount', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': afToken
                    },
                    body: JSON.stringify({
                        itemId: currentItemId,
                        discountPercentage: percent,
                        expiresAt: expiresAt
                    })
                });

                const data = await response.json();

                if (data.success) {
                    location.reload();
                } else {
                    showModalError(data.error || 'Failed to apply discount.');
                    btn.disabled = false;
                    btn.textContent = 'Apply Discount';
                }
            } catch (err) {
                showModalError('Network error. Please try again.');
                btn.disabled = false;
                btn.textContent = 'Apply Discount';
            }
        }

        async function removeDiscount(itemId) {
            if (!confirm('Remove the discount and restore the original price?')) return;

            try {
                const response = await fetch('/Items/RemoveDiscount?itemId=' + itemId, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': afToken
                    }
                });

                const data = await response.json();

                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Failed to remove discount.');
                }
            } catch (err) {
                alert('Network error. Please try again.');
            }
        }

        function showModalError(msg) {
            const errEl = document.getElementById('modalError');
            errEl.textContent = msg;
            errEl.style.display = 'block';
        }

        // Close modal on backdrop click
        document.getElementById('discountModal').addEventListener('click', function(e) {
            if (e.target === this) closeDiscountModal();
        });
    </script>
}