@using ThriftLoop.ViewModels
@using ThriftLoop.Enums
@model LikedItemsViewModel
@{
    ViewData["Title"] = "Liked Items";
}

<div class="likes-page">
    <h1 class="likes-page__title">Liked Items</h1>

    <div class="likes-page__filters">
        <a asp-action="Index" class="filter-btn @(Model.CurrentFilter == null ? "filter-btn--active" : "")">All</a>
        <a asp-action="Index" asp-route-filter="p2p" class="filter-btn @(Model.CurrentFilter == "p2p" ? "filter-btn--active" : "")">P2P Items</a>
        <a asp-action="Index" asp-route-filter="shop" class="filter-btn @(Model.CurrentFilter == "shop" ? "filter-btn--active" : "")">Shop Items</a>
        <a asp-action="Index" asp-route-filter="available" class="filter-btn @(Model.CurrentFilter == "available" ? "filter-btn--active" : "")">Available</a>
    </div>

    @if (Model.IsEmpty)
    {
        <div class="likes-page__empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="64" height="64">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
            </svg>
            <p>You haven't liked any items yet</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Browse Items</a>
        </div>
    }
    else
    {
        <div class="fy-grid likes-page__grid">
            @foreach (var item in Model.Items)
            {
                var isShopItem = item.ShopId.HasValue;
                var isSold = item.Status == ItemStatus.Sold;

                <article class="fy-card @(isSold ? "fy-card--sold" : "") @(isShopItem ? "fy-card--shop" : "")">
                    <div class="fy-card__img-wrap">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Title" class="fy-card__img" loading="lazy" />
                        }
                        else
                        {
                            <div class="fy-card__img fy-card__img--placeholder" aria-hidden="true">
                                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4">
                                    <rect x="4" y="8" width="40" height="32" rx="4" />
                                    <circle cx="17" cy="20" r="4" />
                                    <path d="M4 36l12-10 8 8 6-5 14 11" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                        }

                        <span class="fy-card__condition-badge" data-condition="@item.Condition.ToString().ToUpper()">@item.Condition</span>

                        @if (isShopItem)
                        {
                            <span class="fy-card__shop-badge" aria-label="Shop listing">Shop</span>
                        }

                        @if (!item.IsAvailable)
                        {
                            <span class="fy-card__status-badge">@item.Status</span>
                        }
                    </div>

                    <div class="fy-card__body">
                        <div class="fy-card__top">
                            <span class="fy-card__category">@item.Category</span>
                            <span class="fy-card__date">Liked @item.LikedAt.ToString("MMM d")</span>
                        </div>

                        <div class="fy-card__title-row">
                            <h2 class="fy-card__title">@item.Title</h2>
                            <button type="button" class="fy-like-btn fy-like-btn--liked" data-item-id="@item.ItemId" data-like-count="@item.LikeCount" aria-label="Unlike item">
                                <svg class="fy-like-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
                                </svg>
                                @if (item.LikeCount > 0)
                                {
                                    <span class="fy-like-btn__count">@item.LikeCount</span>
                                }
                            </button>
                        </div>

                        <div class="fy-card__price-section">
                            <div class="fy-card__current-price-row">
                                <span class="fy-card__current-price">₱@item.Price.ToString("N2")</span>
                            </div>
                        </div>
                    </div>

                    @if (item.IsP2P)
                    {
                        <a asp-controller="Items" asp-action="Details" asp-route-id="@item.ItemId" class="fy-card__link" aria-label="View details for @item.Title"></a>
                    }
                    else
                    {
                        <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.ItemId" class="fy-card__link" aria-label="View details for @item.Title"></a>
                    }
                </article>
            }
        </div>
    }
</div>

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/likes.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function() {
            // Like button click handler - unlike items since they're all liked on this page
            document.querySelectorAll('.fy-like-btn').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    var btn = this;
                    var itemId = btn.dataset.itemId;
                    var card = btn.closest('.fy-card');
                    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                    fetch('/Likes/Toggle', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ itemId: parseInt(itemId) })
                    })
                    .then(function(res) { return res.json(); })
                    .then(function(data) {
                        if (data.success) {
                            if (!data.isLiked) {
                                // Item was unliked - remove card with animation
                                card.style.transition = 'opacity 0.3s, transform 0.3s';
                                card.style.opacity = '0';
                                card.style.transform = 'scale(0.9)';
                                setTimeout(function() {
                                    card.remove();
                                    // Check if grid is empty
                                    var grid = document.querySelector('.fy-grid');
                                    if (grid && grid.children.length === 0) {
                                        location.reload(); // Reload to show empty state
                                    }
                                }, 300);
                            }
                        }
                    })
                    .catch(function(err) {
                        console.error('Unlike failed:', err);
                    });
                });
            });
        }());
    </script>
}
