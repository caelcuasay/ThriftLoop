﻿@{
ViewData["Title"] = "Check Your Email";
Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThriftLoop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Auth.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-shell">

        <aside class="auth-panel auth-panel--brand">
            <div class="brand-wordmark">ThriftLoop</div>
            <p class="brand-tagline">Check your<br>inbox.</p>
            <div class="brand-decoration" aria-hidden="true">
                <span class="deco-ring deco-ring--lg"></span>
                <span class="deco-ring deco-ring--md"></span>
                <span class="deco-ring deco-ring--sm"></span>
            </div>
        </aside>

        <main class="auth-panel auth-panel--form">
            <div class="form-card">

                <header class="form-card__header">
                    <h1 class="form-card__title">Email sent</h1>
                    <p class="form-card__subtitle">
                        If an account with that email exists, we've sent a password reset link.
                        Check your inbox — the link expires in <strong>1 hour</strong>.
                    </p>
                </header>

                <div class="confirm-icon" aria-hidden="true">
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="2" opacity=".15" />
                        <path d="M8 18l16 10 16-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        <rect x="8" y="14" width="32" height="22" rx="3" stroke="currentColor" stroke-width="2" />
                        <path d="M18 28l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>

                <p class="hint-text">
                    Didn't get it? Check your spam folder, or
                    <a asp-action="ForgotPassword" asp-controller="Auth" class="footer-link">try again</a>.
                </p>

                <footer class="form-card__footer">
                    <p>
                        <a asp-action="Login" asp-controller="Auth" class="footer-link">Back to sign in</a>
                    </p>
                </footer>

            </div>
        </main>

    </div>
</body>
</html>