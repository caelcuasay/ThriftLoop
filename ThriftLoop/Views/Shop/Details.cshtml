@model ThriftLoop.ViewModels.ShopItemDetailsViewModel
@using ThriftLoop.Constants
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool hasImages = Model.ImageUrls.Count > 0;

    string condClass = Model.Condition switch
    {
        "New"      => "detail-condition--new",
        "Like New" => "detail-condition--like-new",
        "Good"     => "detail-condition--good",
        "Fair"     => "detail-condition--fair",
        _          => "detail-condition--poor"
    };
}

<div class="detail-shell">

    @* ── Breadcrumb ───────────────────────────────────────────────────────── *@
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Shop" asp-action="Index" asp-route-id="@Model.ShopId"
           class="detail-breadcrumb__link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Back to @Model.ShopName
        </a>
    </nav>

    @* ── Two-column layout ────────────────────────────────────────────────── *@
    <div class="detail-grid">

        @* ════════════════════════ LEFT — Images ═════════════════════════════ *@
        <aside class="detail-img-col">
            <div class="detail-gallery">

                <div class="detail-img-frame" id="galleryMain">
                    @if (hasImages)
                    {
                        <img src="@Model.ImageUrls[0]" id="mainGalleryImg"
                             alt="Photo of @Model.Title" class="detail-img" loading="eager" />
                        @if (Model.ImageUrls.Count > 1)
                        {
                            <button type="button" class="gallery-arrow gallery-arrow--prev"
                                    id="galleryPrev" aria-label="Previous photo">
                                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                                     stroke-width="2" width="18" height="18">
                                    <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </button>
                            <button type="button" class="gallery-arrow gallery-arrow--next"
                                    id="galleryNext" aria-label="Next photo">
                                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                                     stroke-width="2" width="18" height="18">
                                    <path d="M7.5 5L12.5 10L7.5 15" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </button>
                            <span class="gallery-counter" id="galleryCounter">
                                1 / @Model.ImageUrls.Count
                            </span>
                        }
                    }
                    else
                    {
                        <div class="detail-img detail-img--placeholder" aria-hidden="true">
                            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4">
                                <rect x="6" y="10" width="52" height="44" rx="6" />
                                <circle cx="22" cy="26" r="6" />
                                <path d="M6 46l16-14 10 10 8-7 18 15"
                                      stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <span>No photo</span>
                        </div>
                    }
                </div>

                @if (Model.ImageUrls.Count > 1)
                {
                    <div class="gallery-thumbs" id="galleryThumbs" role="list">
                        @for (int t = 0; t < Model.ImageUrls.Count; t++)
                        {
                            <button type="button"
                                    class="gallery-thumb @(t == 0 ? "gallery-thumb--active" : "")"
                                    data-index="@t" data-src="@Model.ImageUrls[t]"
                                    role="listitem" aria-label="Photo @(t + 1)">
                                <img src="@Model.ImageUrls[t]" alt="Thumbnail @(t + 1)" loading="lazy" />
                                @if (t == 0) { <span class="gallery-thumb__cover">Cover</span> }
                            </button>
                        }
                    </div>
                }

            </div>

            @* Shop pill *@
            <a asp-controller="Shop" asp-action="Index" asp-route-id="@Model.ShopId"
               class="detail-shop-pill">
                @if (!string.IsNullOrWhiteSpace(Model.ShopLogoUrl))
                {
                    <img src="@Model.ShopLogoUrl" alt="@Model.ShopName logo"
                         class="detail-shop-pill__logo" />
                }
                else
                {
                    <div class="detail-shop-pill__logo detail-shop-pill__logo--placeholder">
                        @char.ToUpper(Model.ShopName.FirstOrDefault())
                    </div>
                }
                <div class="detail-shop-pill__info">
                    <span class="detail-shop-pill__label">Sold by</span>
                    <span class="detail-shop-pill__name">@Model.ShopName</span>
                </div>
                <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"
                     class="detail-shop-pill__chevron" aria-hidden="true">
                    <path d="M6.22 3.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 010-1.06z" />
                </svg>
            </a>

        </aside>

        @* ════════════════════════ RIGHT — Details ════════════════════════════ *@
        <section class="detail-info-col">

            <div class="detail-meta-row">
                <span class="detail-category">@Model.Category</span>
                <span class="detail-condition @condClass">@Model.Condition</span>
                <span class="detail-listing-type-badge">Shop</span>
            </div>

            <h1 class="detail-title">@Model.Title</h1>

            <div class="detail-price-block">
                <span class="detail-price" id="selectedPrice">
                    ₱@Model.StartingPrice.ToString("N2")
                </span>
                <span class="detail-price-label" id="priceLabel">Starting price</span>
            </div>

            <p class="detail-description">@Model.Description</p>

            @* ── Variant picker ───────────────────────────────────────────── *@
            @if (Model.Variants.Count > 0)
            {
                <div class="vp-shell">

                    @* Step 1: pick a variant *@
                    <div class="vp-section">
                        <p class="vp-section__label">
                            Variant
                            <span class="vp-section__required" id="variantRequired" hidden>
                                — please select one
                            </span>
                        </p>
                        <div class="vp-variant-chips" id="variantChips">
                            @foreach (var v in Model.Variants)
                            {
                                <button type="button"
                                        class="vp-chip"
                                        data-variant-id="@v.VariantId">
                                    @v.Name
                                </button>
                            }
                        </div>
                    </div>

                    @* Step 2: pick a SKU *@
                    <div class="vp-section" id="skuSection" hidden>
                        <p class="vp-section__label">
                            Size
                            <span class="vp-section__required" id="skuRequired" hidden>
                                — please select one
                            </span>
                        </p>
                        <div class="vp-sku-chips" id="skuChips"></div>
                    </div>

                </div>

                @* Variant data embedded as JSON for the JS picker *@
                <script id="variantData" type="application/json">
                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model.Variants.Select(v => new {
                            variantId = v.VariantId,
                            name      = v.Name,
                            skus      = v.Skus.Select(s => new {
                                skuId       = s.SkuId,
                                size        = s.Size,
                                price       = s.Price,
                                quantity    = s.Quantity,
                                isAvailable = s.IsAvailable
                            })
                        })
                    ))
                </script>
            }

            @* ── Action buttons ───────────────────────────────────────────── *@
            <div class="detail-actions" id="detailActions">
                @if (Model.IsOwner)
                {
                    <a asp-controller="Shop" asp-action="Edit"
                       asp-route-id="@Model.ItemId"
                       class="tl-btn tl-btn--ghost detail-actions__btn">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                            <path d="M11.013 1.427a1.75 1.75 0 012.474 0l1.086 1.086a1.75 1.75 0 010 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 01-.927-.928l.929-3.25c.081-.286.235-.547.445-.758l8.61-8.61zm1.414 1.06a.25.25 0 00-.354 0L10.811 3.75l1.439 1.44 1.263-1.263a.25.25 0 000-.354l-1.086-1.086zM11.189 6.25L9.75 4.81 3.23 11.33a.25.25 0 00-.064.108l-.558 1.953 1.953-.558a.25.25 0 00.108-.064l6.52-6.52z" />
                        </svg>
                        Edit Listing
                    </a>
                    <a asp-controller="Shop" asp-action="Delete"
                       asp-route-id="@Model.ItemId"
                       class="tl-btn tl-btn--danger detail-actions__btn">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                            <path d="M11 1.75V3h2.25a.75.75 0 010 1.5H2.75a.75.75 0 010-1.5H5V1.75C5 .784 5.784 0 6.75 0h2.5C10.216 0 11 .784 11 1.75zM4.496 6.675a.75.75 0 10-1.492.15l.66 6.6A1.75 1.75 0 005.405 15h5.19a1.75 1.75 0 001.741-1.575l.66-6.6a.75.75 0 10-1.492-.15l-.66 6.6a.25.25 0 01-.249.225H5.405a.25.25 0 01-.249-.225l-.66-6.6z" />
                        </svg>
                        Delete
                    </a>
                }
                else
                {
                    <button type="button" class="tl-btn tl-btn--primary detail-actions__btn"
                            id="addToCartBtn" style="width:100%">
                        Add to Cart
                    </button>
                }
            </div>

            @if (TempData["ErrorMessage"] is string errMsg)
            {
                <p class="detail-flash detail-flash--error">@errMsg</p>
            }
            @if (TempData["SuccessMessage"] is string okMsg)
            {
                <p class="detail-flash detail-flash--success">@okMsg</p>
            }

        </section>
    </div>
</div>

@section Scripts {
    <script>
    (function () {
        const rawData = document.getElementById('variantData');
        if (!rawData) return;

        const variants      = JSON.parse(rawData.textContent);
        const variantChips  = document.getElementById('variantChips');
        const skuSection    = document.getElementById('skuSection');
        const skuChips      = document.getElementById('skuChips');
        const priceEl       = document.getElementById('selectedPrice');
        const priceLabelEl  = document.getElementById('priceLabel');
        const variantReqEl  = document.getElementById('variantRequired');
        const skuReqEl      = document.getElementById('skuRequired');

        let selectedVariantId = null;
        let selectedSkuId     = null;

        // ── Variant chip click ────────────────────────────────────────────
        variantChips?.addEventListener('click', e => {
            const chip = e.target.closest('.vp-chip');
            if (!chip) return;

            variantChips.querySelectorAll('.vp-chip').forEach(c => c.classList.remove('vp-chip--active'));
            chip.classList.add('vp-chip--active');

            selectedVariantId = parseInt(chip.dataset.variantId);
            selectedSkuId     = null;
            variantReqEl.hidden = true;

            const variant = variants.find(v => v.variantId === selectedVariantId);
            if (!variant) return;

            // Render SKU chips
            skuChips.innerHTML = '';
            variant.skus.forEach(sku => {
                const btn = document.createElement('button');
                btn.type             = 'button';
                btn.className        = 'vp-chip' + (sku.isAvailable ? '' : ' vp-chip--disabled');
                btn.dataset.skuId    = sku.skuId;
                btn.dataset.price    = sku.price;
                btn.dataset.qty      = sku.quantity;
                btn.disabled         = !sku.isAvailable;
                btn.textContent      = sku.size || 'One size';
                if (!sku.isAvailable) btn.title = 'Out of stock';
                skuChips.appendChild(btn);
            });

            skuSection.removeAttribute('hidden');

            // Reset price display
            const lowestAvailable = variant.skus
                .filter(s => s.isAvailable)
                .reduce((min, s) => s.price < min ? s.price : min, Infinity);

            if (lowestAvailable < Infinity) {
                priceEl.textContent = '₱' + lowestAvailable.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                priceLabelEl.textContent = 'Starting price';
            }
        });

        // ── SKU chip click ────────────────────────────────────────────────
        skuChips?.addEventListener('click', e => {
            const chip = e.target.closest('.vp-chip:not(.vp-chip--disabled)');
            if (!chip) return;

            skuChips.querySelectorAll('.vp-chip').forEach(c => c.classList.remove('vp-chip--active'));
            chip.classList.add('vp-chip--active');

            selectedSkuId = parseInt(chip.dataset.skuId);
            skuReqEl.hidden = true;

            priceEl.textContent = '₱' + parseFloat(chip.dataset.price)
                .toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            priceLabelEl.textContent = `${chip.dataset.qty} available`;
        });

        // ── Gallery ───────────────────────────────────────────────────────
        const mainImg  = document.getElementById('mainGalleryImg');
        const thumbs   = document.querySelectorAll('.gallery-thumb');
        const counter  = document.getElementById('galleryCounter');
        const prevBtn  = document.getElementById('galleryPrev');
        const nextBtn  = document.getElementById('galleryNext');

        const urls = Array.from(thumbs).map(t => t.dataset.src);
        let current = 0;

        function goTo(idx) {
            if (!mainImg || urls.length === 0) return;
            current = (idx + urls.length) % urls.length;
            mainImg.src = urls[current];
            thumbs.forEach((t, i) => t.classList.toggle('gallery-thumb--active', i === current));
            if (counter) counter.textContent = `${current + 1} / ${urls.length}`;
        }

        thumbs.forEach((t, i) => t.addEventListener('click', () => goTo(i)));
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));

    }());
    </script>
}

<style>
    /* ── Variant picker ─────────────────────────────────────────────────── */
    .vp-shell { margin: 1.25rem 0; display: flex; flex-direction: column; gap: 1.25rem; }
    .vp-section__label {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--color-muted, #8a8278);
        margin: 0 0 0.625rem;
    }
    .vp-section__required {
        font-weight: 400;
        text-transform: none;
        letter-spacing: 0;
        color: #dc2626;
    }
    .vp-variant-chips,
    .vp-sku-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }

    .vp-chip {
        padding: 0.4rem 0.875rem;
        border: 1.5px solid var(--color-border, #e2ddd6);
        border-radius: 999px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        background: #fff;
        color: var(--color-text, #1a1814);
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
    }
    .vp-chip:hover:not(.vp-chip--disabled) {
        border-color: var(--color-primary, #2d5a27);
    }
    .vp-chip--active {
        border-color: var(--color-primary, #2d5a27);
        background: color-mix(in srgb, var(--color-primary, #2d5a27) 8%, transparent);
        color: var(--color-primary, #2d5a27);
        font-weight: 700;
    }
    .vp-chip--disabled {
        opacity: .45;
        cursor: not-allowed;
        text-decoration: line-through;
    }

    /* ── Shop pill ──────────────────────────────────────────────────────── */
    .detail-shop-pill {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        border: 1px solid var(--color-border, #e2ddd6);
        border-radius: 12px;
        margin-top: 1.25rem;
        text-decoration: none;
        transition: border-color 0.15s, background 0.15s;
    }
    .detail-shop-pill:hover {
        border-color: var(--color-primary, #2d5a27);
        background: color-mix(in srgb, var(--color-primary, #2d5a27) 3%, transparent);
    }
    .detail-shop-pill__logo {
        width: 40px; height: 40px;
        border-radius: 8px;
        object-fit: cover;
        flex-shrink: 0;
    }
    .detail-shop-pill__logo--placeholder {
        width: 40px; height: 40px;
        border-radius: 8px;
        background: var(--color-primary, #2d5a27);
        color: #fff;
        font-family: 'DM Serif Display', serif;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .detail-shop-pill__info { flex: 1; line-height: 1.3; }
    .detail-shop-pill__label {
        display: block;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.72rem;
        color: var(--color-muted, #8a8278);
    }
    .detail-shop-pill__name {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text, #1a1814);
    }
    .detail-shop-pill__chevron { color: var(--color-muted, #8a8278); flex-shrink: 0; }

    /* ── Description ────────────────────────────────────────────────────── */
    .detail-description {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        color: var(--color-muted, #8a8278);
        line-height: 1.65;
        margin: 0.75rem 0 1rem;
        white-space: pre-line;
    }

    /* ── Actions ────────────────────────────────────────────────────────── */
    .detail-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem; }
    .detail-actions__btn { flex: 1; justify-content: center; min-width: 120px; }

    .detail-flash {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem;
        padding: 0.625rem 0.875rem;
        border-radius: 8px;
        margin-top: 0.75rem;
    }
    .detail-flash--error {
        background: color-mix(in srgb, #dc2626 8%, transparent);
        color: #b91c1c;
        border: 1px solid color-mix(in srgb, #dc2626 20%, transparent);
    }
    .detail-flash--success {
        background: color-mix(in srgb, #16a34a 8%, transparent);
        color: #15803d;
        border: 1px solid color-mix(in srgb, #16a34a 20%, transparent);
    }

    /* ── Shop badge ─────────────────────────────────────────────────────── */
    .detail-listing-type-badge {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        padding: 2px 8px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-primary, #2d5a27) 12%, transparent);
        color: var(--color-primary, #2d5a27);
    }
</style>