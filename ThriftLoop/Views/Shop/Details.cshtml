@model ThriftLoop.ViewModels.ShopItemDetailsViewModel
@using ThriftLoop.Constants
@{
    ViewData["Title"] = Model.Title;
    Layout = null;

    bool hasImages = Model.ImageUrls.Count > 0;
    bool hasDiscount = Model.HasActiveDiscount;

    string condClass = Model.Condition switch
    {
        "New" => "detail-condition--new",
        "Like New" => "detail-condition--like-new",
        "Good" => "detail-condition--good",
        "Fair" => "detail-condition--fair",
        _ => "detail-condition--poor"
    };

    // Calculate expiry text for discount
    string? discountExpiryText = null;
    if (hasDiscount && Model.DiscountExpiresAt.HasValue)
    {
        var timeLeft = Model.DiscountExpiresAt.Value - DateTime.UtcNow;
        if (timeLeft.TotalDays >= 1)
        {
            var days = (int)timeLeft.TotalDays;
            discountExpiryText = $"{days} day{(days != 1 ? "s" : "")} left";
        }
        else if (timeLeft.TotalHours >= 1)
        {
            var hours = (int)timeLeft.TotalHours;
            discountExpiryText = $"{hours} hour{(hours != 1 ? "s" : "")} left";
        }
        else if (timeLeft.TotalMinutes > 0)
        {
            var mins = (int)timeLeft.TotalMinutes;
            discountExpiryText = $"{mins} min{(mins != 1 ? "s" : "")} left";
        }
        else
        {
            discountExpiryText = "Ending soon";
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThriftLoop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Shop.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Navbar.css" asp-append-version="true" />
    <style>
            /* Discount display styles for details page */
            .detail-price-block {
                display: flex;
                flex-direction: column;
                gap: 4px;
            }

            .detail-price-row {
                display: flex;
                align-items: baseline;
                gap: 12px;
                flex-wrap: wrap;
            }

            .detail-price-original {
                font-size: 1.1rem;
                color: #9ca3af;
                text-decoration: line-through;
                font-weight: 400;
            }

            .detail-price-current {
                font-size: 2rem;
                font-weight: 700;
                color: #1a1814;
            }

            .detail-discount-badge {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: #fee2e2;
                color: #b91c1c;
                font-size: 0.85rem;
                font-weight: 600;
                padding: 4px 12px;
                border-radius: 24px;
                line-height: 1;
                white-space: nowrap;
            }

            .detail-discount-badge--inline {
                margin-left: 0;
            }

            .detail-discount-expiry {
                display: flex;
                align-items: center;
                gap: 6px;
                margin-top: 8px;
                font-size: 0.8rem;
                color: #b91c1c;
                font-weight: 500;
            }

                .detail-discount-expiry svg {
                    flex-shrink: 0;
                }

            .detail-price-label {
                font-size: 0.875rem;
                color: #6b7280;
            }

            /* Original price wrapper - hidden when no discount or when SKU selected without discount tracking */
            .detail-price-original-wrapper {
                display: flex;
                align-items: center;
                gap: 12px;
            }
    </style>
</head>
<body>
    @await Html.PartialAsync("_Navbar")

    <div class="detail-shell">

        @* ── Breadcrumb ────────────────────────────────────────────────────── *@
        <nav class="detail-breadcrumb" aria-label="Breadcrumb">
            <a asp-controller="Shop" asp-action="Index" asp-route-id="@Model.ShopId"
                   class="detail-breadcrumb__link">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Back to @Model.ShopName
            </a>
        </nav>

        @* ── Two-column layout ──────────────────────────────────────────────── *@
        <div class="detail-grid">

            @* ═══════════════════ LEFT — Images ═══════════════════════════════ *@
            <aside class="detail-img-col">
                <div class="detail-gallery">

                    <div class="detail-img-frame" id="galleryMain">
                        @if (hasImages)
                        {
                            <img src="@Model.ImageUrls[0]" id="mainGalleryImg"
                                 alt="Photo of @Model.Title" class="detail-img" loading="eager" />
                            @if (Model.ImageUrls.Count > 1)
                            {
                                <button type="button" class="gallery-arrow gallery-arrow--prev"
                                        id="galleryPrev" aria-label="Previous photo">
                                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                                         stroke-width="2" width="16" height="16">
                                        <path d="M12.5 5L7.5 10L12.5 15" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </button>
                                <button type="button" class="gallery-arrow gallery-arrow--next"
                                        id="galleryNext" aria-label="Next photo">
                                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                                         stroke-width="2" width="16" height="16">
                                        <path d="M7.5 5L12.5 10L7.5 15" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </button>
                                <span class="gallery-counter" id="galleryCounter">
                                    1 / @Model.ImageUrls.Count
                                </span>
                            }
                        }
                        else
                        {
                            <div class="detail-img detail-img--placeholder" aria-hidden="true">
                                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4"
                                     width="52" height="52">
                                    <rect x="6" y="10" width="52" height="44" rx="6" />
                                    <circle cx="22" cy="26" r="6" />
                                    <path d="M6 46l16-14 10 10 8-7 18 15" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <span>No photo</span>
                            </div>
                        }
                    </div>

                    @if (Model.ImageUrls.Count > 1)
                    {
                        <div class="gallery-thumbs" id="galleryThumbs" role="list">
                            @for (int t = 0; t < Model.ImageUrls.Count; t++)
                            {
                                <button type="button"
                                        class="gallery-thumb @(t == 0 ? "gallery-thumb--active" : "")"
                                        data-index="@t" data-src="@Model.ImageUrls[t]"
                                        role="listitem" aria-label="Photo @(t + 1)">
                                    <img src="@Model.ImageUrls[t]" alt="Thumbnail @(t + 1)" loading="lazy" />
                                    @if (t == 0)
                                    {
                                        <span class="gallery-thumb__cover">Cover</span>
                                    }
                                </button>
                            }
                        </div>
                    }

                </div>

                @* Shop pill *@
                <a asp-controller="Shop" asp-action="Index" asp-route-id="@Model.ShopId"
                       class="detail-shop-pill">
                    @if (!string.IsNullOrWhiteSpace(Model.ShopLogoUrl))
                    {
                        <img src="@Model.ShopLogoUrl" alt="@Model.ShopName logo"
                             class="detail-shop-pill__logo" />
                    }
                    else
                    {
                        <div class="detail-shop-pill__logo detail-shop-pill__logo--placeholder">
                            @char.ToUpper(Model.ShopName.FirstOrDefault())
                        </div>
                    }
                    <div class="detail-shop-pill__info">
                        <span class="detail-shop-pill__label">Sold by</span>
                        <span class="detail-shop-pill__name">@Model.ShopName</span>
                    </div>
                    <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"
                         class="detail-shop-pill__chevron" aria-hidden="true">
                        <path d="M6.22 3.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 010-1.06z" />
                    </svg>
                </a>

            </aside>

            @* ═══════════════════ RIGHT — Details ═════════════════════════════ *@
            <section class="detail-info-col">

                <div class="detail-meta-row">
                    <span class="detail-category">@Model.Category</span>
                    <span class="detail-condition @condClass">@Model.Condition</span>
                    <span class="detail-listing-type-badge">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="10" height="10" aria-hidden="true">
                            <path d="M9.504.43a1.516 1.516 0 012.437 1.713L10.5 6h3.798a1.516 1.516 0 011.149 2.506l-6 7a1.516 1.516 0 01-2.631-1.275L7.5 10H4.701a1.516 1.516 0 01-1.149-2.506l6-7z" />
                        </svg>
                        Shop
                    </span>
                    @if (hasDiscount)
                    {
                        <span class="detail-discount-badge" style="margin-left: auto;">
                            -@(Model.DiscountPercentage?.ToString("F0"))% OFF
                        </span>
                    }
                </div>

                <h1 class="detail-title">@Model.Title</h1>

                @* ── Price Display with Discount Support ────────────────────────── *@
                <div class="detail-price-block" id="priceBlock">
                    @if (hasDiscount)
                    {
                        <div class="detail-price-original-wrapper">
                            <span class="detail-price-original" id="originalPriceDisplay">
                                ₱@(Model.OriginalPrice?.ToString("N2") ?? Model.StartingPrice.ToString("N2"))
                            </span>
                            <span class="detail-discount-badge detail-discount-badge--inline" id="inlineDiscountBadge">
                                -@(Model.DiscountPercentage?.ToString("F0"))%
                            </span>
                        </div>
                    }
                    <div class="detail-price-row">
                        <span class="detail-price-current" id="selectedPrice">
                            ₱@Model.StartingPrice.ToString("N2")
                        </span>
                    </div>
                    @if (hasDiscount && !string.IsNullOrEmpty(discountExpiryText))
                    {
                        <div class="detail-discount-expiry" id="discountExpiry">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                                <path d="M8 15A7 7 0 108 1a7 7 0 000 14zm.75-10.25a.75.75 0 00-1.5 0v4a.75.75 0 001.5 0v-4zM8 13a1 1 0 100-2 1 1 0 000 2z" />
                            </svg>
                            @discountExpiryText
                        </div>
                    }
                    <span class="detail-price-label" id="priceLabel">Starting price</span>
                </div>

                <p class="detail-description">@Model.Description</p>

                @* ── Variant picker ────────────────────────────────────────── *@
                @if (Model.Variants.Count > 0)
                {
                    <div class="vp-shell">

                        @* Step 1 — Variant *@
                        <div class="vp-section">
                            <p class="vp-section__label">
                                Variant
                                <span class="vp-section__required" id="variantRequired" hidden>
                                    — please select one
                                </span>
                            </p>
                            <div class="vp-variant-chips" id="variantChips">
                                @foreach (var v in Model.Variants)
                                {
                                    <button type="button" class="vp-chip"
                                            data-variant-id="@v.VariantId">
                                        @v.Name
                                    </button>
                                }
                            </div>
                        </div>

                        @* Step 2 — Size *@
                        <div class="vp-section" id="skuSection" hidden>
                            <p class="vp-section__label">
                                Size
                                <span class="vp-section__required" id="skuRequired" hidden>
                                    — please select one
                                </span>
                            </p>
                            <div class="vp-sku-chips" id="skuChips"></div>
                        </div>

                        @* Step 3 — Quantity *@
                        <div class="vp-section" id="qtySection" hidden>
                            <p class="vp-section__label">Quantity</p>
                            <div class="vp-qty-row">
                                <button type="button" class="vp-qty-btn" id="qtyDec" aria-label="Decrease quantity">
                                    <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11" aria-hidden="true">
                                        <path d="M2 8a.75.75 0 01.75-.75h10.5a.75.75 0 010 1.5H2.75A.75.75 0 012 8z" />
                                    </svg>
                                </button>
                                <input type="number" id="qtyInput" class="vp-qty-input"
                                       value="1" min="1" max="1" aria-label="Quantity" />
                                <button type="button" class="vp-qty-btn" id="qtyInc" aria-label="Increase quantity">
                                    <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11" aria-hidden="true">
                                        <path d="M7.75 2a.75.75 0 01.75.75V7h4.25a.75.75 0 010 1.5H8.5v4.25a.75.75 0 01-1.5 0V8.5H2.75a.75.75 0 010-1.5H7V2.75A.75.75 0 017.75 2z" />
                                    </svg>
                                </button>
                                <span class="vp-qty-stock" id="qtyStock" aria-live="polite"></span>
                            </div>
                        </div>

                    </div>

                    @* Variant data as JSON with discount info *@
                    <script id="variantData" type="application/json">
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
                                        {
                                                hasDiscount = hasDiscount,
                                                discountPercentage = Model.DiscountPercentage,
                                                originalStartingPrice = Model.OriginalPrice ?? Model.StartingPrice,
                                                variants = Model.Variants.Select(v => new
                                                {
                                                        variantId = v.VariantId,
                                                        name = v.Name,
                                                        skus = v.Skus.Select(s => new
                                                        {
                                                                skuId = s.SkuId,
                                                                size = s.Size,
                                                                price = s.Price,
                                                                originalPrice = s.OriginalPrice,
                                                                quantity = s.Quantity,
                                                                isAvailable = s.IsAvailable
                                                        })
                                                })
                                        }))
                    </script>
                }

                @* ── Action buttons ────────────────────────────────────────── *@
                @if (Model.IsOwner)
                {
                    <div class="detail-actions">
                        <a asp-controller="Shop" asp-action="Edit"
                               asp-route-id="@Model.ItemId"
                               class="tl-btn tl-btn--ghost detail-actions__btn">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13" aria-hidden="true">
                                <path d="M11.013 1.427a1.75 1.75 0 012.474 0l1.086 1.086a1.75 1.75 0 010 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 01-.927-.928l.929-3.25c.081-.286.235-.547.445-.758l8.61-8.61zm1.414 1.06a.25.25 0 00-.354 0L10.811 3.75l1.439 1.44 1.263-1.263a.25.25 0 000-.354l-1.086-1.086zM11.189 6.25L9.75 4.81 3.23 11.33a.25.25 0 00-.064.108l-.558 1.953 1.953-.558a.25.25 0 00.108-.064l6.52-6.52z" />
                            </svg>
                            Edit Listing
                        </a>
                        <a asp-controller="Shop" asp-action="Delete"
                               asp-route-id="@Model.ItemId"
                               class="tl-btn tl-btn--danger detail-actions__btn">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13" aria-hidden="true">
                                <path d="M11 1.75V3h2.25a.75.75 0 010 1.5H2.75a.75.75 0 010-1.5H5V1.75C5 .784 5.784 0 6.75 0h2.5C10.216 0 11 .784 11 1.75zM4.496 6.675a.75.75 0 10-1.492.15l.66 6.6A1.75 1.75 0 005.405 15h5.19a1.75 1.75 0 001.741-1.575l.66-6.6a.75.75 0 10-1.492-.15l-.66 6.6a.25.25 0 01-.249.225H5.405a.25.25 0 01-.249-.225l-.66-6.6z" />
                            </svg>
                            Delete
                        </a>
                    </div>
                }
                else
                {
                    <div class="detail-actions" id="buyerActions">
                        <button type="button"
                                class="tl-btn tl-btn--primary detail-actions__btn"
                                id="buyNowBtn"
                                disabled
                                style="width:100%; padding:13px 20px; font-size:.9rem">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14" aria-hidden="true">
                                <path d="M0 1.75A.75.75 0 01.75 1h1.628a1.75 1.75 0 011.734 1.51L4.358 4h9.109a.75.75 0 01.72.96l-1.5 5.25a.75.75 0 01-.72.54H5.744l.239 1.185A.25.25 0 006.22 12h7.28a.75.75 0 010 1.5H6.22a1.75 1.75 0 01-1.717-1.424L2.637 2.773A.25.25 0 002.395 2.5H.75A.75.75 0 010 1.75zM6 14.5a1 1 0 112 0 1 1 0 01-2 0zm6.5-1a1 1 0 100 2 1 1 0 000-2z" />
                            </svg>
                            Buy Now
                        </button>
                        <button type="button"
                                class="tl-btn tl-btn--ghost detail-actions__btn"
                                id="addToCartBtn"
                                disabled
                                style="width:100%; padding:13px 20px; font-size:.9rem; margin-top:8px;">
                            <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14" aria-hidden="true">
                                <path d="M.75 1a.75.75 0 000 1.5h1.256c.374.001.714.226.88.576l4.677 9.709a.75.75 0 001.346 0l3.15-6.532H9.25a.75.75 0 000-1.5h3a.75.75 0 01.75.75v3a.75.75 0 01-1.5 0V4.81l-3.286 6.822a2.25 2.25 0 01-4.028 0L1.318 3.346A2.25 2.25 0 01.006 2.249V1.75A.75.75 0 01.75 1zM5.5 13a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM12 13a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                            </svg>
                            Add to Cart
                        </button>
                        <div id="cartFeedback" class="cart-feedback" hidden></div>
                    </div>
                }

                @if (TempData["ErrorMessage"] is string errMsg)
                {
                    <p class="detail-flash detail-flash--error">@errMsg</p>
                }
                @if (TempData["SuccessMessage"] is string okMsg)
                {
                    <p class="detail-flash detail-flash--success">@okMsg</p>
                }

            </section>
        </div>
    </div>

    <script>
            (function () {
                'use strict';

                // ── Variant / SKU data ──────────────────────────────────────────────
                const rawData = document.getElementById('variantData');
                if (!rawData) return;

                const parsedData = JSON.parse(rawData.textContent);
                const variants = parsedData.variants;
                const hasDiscount = parsedData.hasDiscount;
                const discountPercentage = parsedData.discountPercentage;
                const originalStartingPrice = parsedData.originalStartingPrice;

                const variantChipsEl = document.getElementById('variantChips');
                const skuSection = document.getElementById('skuSection');
                const skuChipsEl = document.getElementById('skuChips');
                const priceEl = document.getElementById('selectedPrice');
                const priceLabelEl = document.getElementById('priceLabel');
                const originalPriceDisplay = document.getElementById('originalPriceDisplay');
                const inlineDiscountBadge = document.getElementById('inlineDiscountBadge');
                const discountExpiry = document.getElementById('discountExpiry');
                const variantReqEl = document.getElementById('variantRequired');
                const skuReqEl = document.getElementById('skuRequired');
                const qtySection = document.getElementById('qtySection');
                const qtyInput = document.getElementById('qtyInput');
                const qtyDecBtn = document.getElementById('qtyDec');
                const qtyIncBtn = document.getElementById('qtyInc');
                const qtyStock = document.getElementById('qtyStock');
                const buyNowBtn = document.getElementById('buyNowBtn');

                let selectedVariantId = null;
                let selectedSkuId = null;
                let currentUnitPrice = 0;
                let currentOriginalPrice = 0;

                // Format price helper
                function formatPrice(price) {
                    return '₱' + price.toLocaleString('en-PH', { minimumFractionDigits: 2 });
                }

                // Update price display for selected SKU
                function updatePriceDisplay(unitPrice, originalPrice, qty) {
                    const totalPrice = unitPrice * qty;
                    priceEl.textContent = formatPrice(totalPrice);

                    if (hasDiscount && originalPriceDisplay) {
                        const totalOriginal = originalPrice * qty;
                        originalPriceDisplay.textContent = formatPrice(totalOriginal);
                        originalPriceDisplay.style.display = 'inline';
                        if (inlineDiscountBadge) {
                            inlineDiscountBadge.style.display = 'inline-flex';
                            inlineDiscountBadge.textContent = '-' + discountPercentage + '%';
                        }
                        if (discountExpiry) {
                            discountExpiry.style.display = 'flex';
                        }
                    } else if (!hasDiscount && originalPriceDisplay) {
                        originalPriceDisplay.style.display = 'none';
                        if (inlineDiscountBadge) {
                            inlineDiscountBadge.style.display = 'none';
                        }
                        if (discountExpiry) {
                            discountExpiry.style.display = 'none';
                        }
                    }

                    if (qty > 1) {
                        priceLabelEl.textContent = qty + ' × ' + formatPrice(unitPrice);
                    } else {
                        priceLabelEl.textContent = (parseInt(qtyInput?.max || 1)) + ' available';
                    }
                }

                // Reset to starting price display
                function resetToStartingPrice() {
                    if (hasDiscount) {
                        const discountedStarting = originalStartingPrice * (1 - discountPercentage / 100);
                        priceEl.textContent = formatPrice(discountedStarting);
                        if (originalPriceDisplay) {
                            originalPriceDisplay.textContent = formatPrice(originalStartingPrice);
                            originalPriceDisplay.style.display = 'inline';
                        }
                        if (inlineDiscountBadge) {
                            inlineDiscountBadge.style.display = 'inline-flex';
                            inlineDiscountBadge.textContent = '-' + discountPercentage + '%';
                        }
                        if (discountExpiry) {
                            discountExpiry.style.display = 'flex';
                        }
                    } else {
                        priceEl.textContent = formatPrice(originalStartingPrice);
                        if (originalPriceDisplay) {
                            originalPriceDisplay.style.display = 'none';
                        }
                        if (inlineDiscountBadge) {
                            inlineDiscountBadge.style.display = 'none';
                        }
                        if (discountExpiry) {
                            discountExpiry.style.display = 'none';
                        }
                    }
                    priceLabelEl.textContent = 'Starting price';
                }

                // ── Variant chip click ──────────────────────────────────────────────
                variantChipsEl?.addEventListener('click', function (e) {
                    const chip = e.target.closest('.vp-chip');
                    if (!chip) return;

                    variantChipsEl.querySelectorAll('.vp-chip').forEach(c => c.classList.remove('vp-chip--active'));
                    chip.classList.add('vp-chip--active');

                    selectedVariantId = parseInt(chip.dataset.variantId);
                    selectedSkuId = null;
                    if (variantReqEl) variantReqEl.hidden = true;
                    hideQtyPicker();
                    if (buyNowBtn) buyNowBtn.disabled = true;
                    if (addToCartBtn) addToCartBtn.disabled = true;

                    const variant = variants.find(v => v.variantId === selectedVariantId);
                    if (!variant) return;

                    skuChipsEl.innerHTML = '';
                    variant.skus.forEach(sku => {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'vp-chip' + (sku.isAvailable ? '' : ' vp-chip--disabled');
                        btn.dataset.skuId = sku.skuId;
                        btn.dataset.price = sku.price;
                        btn.dataset.originalPrice = sku.originalPrice || sku.price;
                        btn.dataset.quantity = sku.quantity;
                        btn.disabled = !sku.isAvailable;
                        btn.textContent = sku.size || 'One size';
                        if (!sku.isAvailable) btn.title = 'Out of stock';
                        skuChipsEl.appendChild(btn);
                    });

                    skuSection.removeAttribute('hidden');

                    const lowestAvailable = variant.skus
                        .filter(s => s.isAvailable)
                        .reduce((min, s) => s.price < min ? s.price : min, Infinity);

                    if (lowestAvailable < Infinity) {
                        const lowestSku = variant.skus.find(s => s.price === lowestAvailable);
                        const lowestOriginal = lowestSku?.originalPrice || lowestAvailable;

                        if (hasDiscount) {
                            priceEl.textContent = formatPrice(lowestAvailable);
                            if (originalPriceDisplay) {
                                originalPriceDisplay.textContent = formatPrice(lowestOriginal);
                                originalPriceDisplay.style.display = 'inline';
                            }
                            if (inlineDiscountBadge) {
                                inlineDiscountBadge.style.display = 'inline-flex';
                            }
                            if (discountExpiry) {
                                discountExpiry.style.display = 'flex';
                            }
                        } else {
                            priceEl.textContent = formatPrice(lowestAvailable);
                            if (originalPriceDisplay) {
                                originalPriceDisplay.style.display = 'none';
                            }
                            if (inlineDiscountBadge) {
                                inlineDiscountBadge.style.display = 'none';
                            }
                            if (discountExpiry) {
                                discountExpiry.style.display = 'none';
                            }
                        }
                        priceLabelEl.textContent = 'Starting price';
                    }

                    resetToStartingPrice();
                });

                // ── SKU chip click ──────────────────────────────────────────────────
                skuChipsEl?.addEventListener('click', function (e) {
                    const chip = e.target.closest('.vp-chip:not(.vp-chip--disabled)');
                    if (!chip) return;

                    skuChipsEl.querySelectorAll('.vp-chip').forEach(c => c.classList.remove('vp-chip--active'));
                    chip.classList.add('vp-chip--active');

                    selectedSkuId = parseInt(chip.dataset.skuId);
                    if (skuReqEl) skuReqEl.hidden = true;

                    currentUnitPrice = parseFloat(chip.dataset.price);
                    currentOriginalPrice = parseFloat(chip.dataset.originalPrice || chip.dataset.price);
                    const maxQty = parseInt(chip.dataset.quantity) || 1;

                    showQtyPicker(maxQty, currentUnitPrice, currentOriginalPrice);
                    if (buyNowBtn) buyNowBtn.disabled = false;
                    if (addToCartBtn) addToCartBtn.disabled = false;
                });

                // ── Quantity picker ────────────────────────────────────────────────
                function showQtyPicker(maxQty, unitPrice, originalPrice) {
                    if (!qtySection) return;
                    qtyInput.max = maxQty;
                    qtyInput.value = 1;
                    qtyStock.textContent = maxQty + ' in stock';
                    qtySection.removeAttribute('hidden');
                    updateQtyButtons();
                    updatePriceDisplay(unitPrice, originalPrice, 1);
                }

                function hideQtyPicker() {
                    if (qtySection) qtySection.setAttribute('hidden', '');
                }

                function updateQtyButtons() {
                    if (!qtyInput) return;
                    const v = parseInt(qtyInput.value) || 1;
                    const max = parseInt(qtyInput.max) || 1;
                    if (qtyDecBtn) qtyDecBtn.disabled = v <= 1;
                    if (qtyIncBtn) qtyIncBtn.disabled = v >= max;
                }

                qtyDecBtn?.addEventListener('click', () => {
                    const v = parseInt(qtyInput.value) || 1;
                    if (v > 1) {
                        qtyInput.value = v - 1;
                        updateQtyButtons();
                        updatePriceDisplay(currentUnitPrice, currentOriginalPrice, v - 1);
                    }
                });

                qtyIncBtn?.addEventListener('click', () => {
                    const v = parseInt(qtyInput.value) || 1, max = parseInt(qtyInput.max) || 1;
                    if (v < max) {
                        qtyInput.value = v + 1;
                        updateQtyButtons();
                        updatePriceDisplay(currentUnitPrice, currentOriginalPrice, v + 1);
                    }
                });

                qtyInput?.addEventListener('input', () => {
                    let v = Math.max(1, Math.min(parseInt(qtyInput.value) || 1, parseInt(qtyInput.max) || 1));
                    qtyInput.value = v;
                    updateQtyButtons();
                    updatePriceDisplay(currentUnitPrice, currentOriginalPrice, v);
                });

                // ── Buy Now ────────────────────────────────────────────────────────
                buyNowBtn?.addEventListener('click', () => {
                    let valid = true;
                    if (!selectedVariantId) { if (variantReqEl) variantReqEl.hidden = false; valid = false; }
                    if (!selectedSkuId) { if (skuReqEl) skuReqEl.hidden = false; valid = false; }
                    if (!valid) return;
                    const qty = parseInt(qtyInput?.value) || 1;
                    window.location.href = '/Orders/ShopCheckout?skuId=' + selectedSkuId + '&quantity=' + qty;
                });

                // ── Add to Cart ─────────────────────────────────────────────────────
                const addToCartBtn = document.getElementById('addToCartBtn');
                const cartFeedback = document.getElementById('cartFeedback');

                addToCartBtn?.addEventListener('click', async () => {
                    let valid = true;
                    if (!selectedVariantId) { if (variantReqEl) variantReqEl.hidden = false; valid = false; }
                    if (!selectedSkuId) { if (skuReqEl) skuReqEl.hidden = false; valid = false; }
                    if (!valid) return;

                    const qty = parseInt(qtyInput?.value) || 1;
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                    try {
                        const response = await fetch('/Cart/Add', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({ itemId: @Model.ItemId, skuId: selectedSkuId, quantity: qty })
                        });

                        const result = await response.json();

                        if (result.success) {
                            showCartFeedback('Added to cart!', 'success');
                        } else {
                            showCartFeedback(result.error || 'Failed to add to cart', 'error');
                        }
                    } catch (err) {
                        showCartFeedback('Network error. Please try again.', 'error');
                    }
                });

                function showCartFeedback(message, type) {
                    if (!cartFeedback) return;
                    cartFeedback.textContent = message;
                    cartFeedback.className = 'cart-feedback cart-feedback--' + type;
                    cartFeedback.hidden = false;
                    setTimeout(() => { cartFeedback.hidden = true; }, 3000);
                }

                // ── Image gallery ──────────────────────────────────────────────────
                const mainImg = document.getElementById('mainGalleryImg');
                const thumbs = document.querySelectorAll('.gallery-thumb');
                const counter = document.getElementById('galleryCounter');
                const prevBtn = document.getElementById('galleryPrev');
                const nextBtn = document.getElementById('galleryNext');

                const urls = Array.from(thumbs).map(t => t.dataset.src);
                let current = 0;

                function goTo(idx) {
                    if (!mainImg || urls.length === 0) return;
                    const next = (idx + urls.length) % urls.length;
                    if (next === current) return;

                    mainImg.classList.add('fading');
                    setTimeout(() => {
                        current = next;
                        mainImg.src = urls[current];
                        mainImg.classList.remove('fading');
                        thumbs.forEach((t, i) => t.classList.toggle('gallery-thumb--active', i === current));
                        if (counter) counter.textContent = (current + 1) + ' / ' + urls.length;
                    }, 130);
                }

                thumbs.forEach((t, i) => t.addEventListener('click', () => goTo(i)));
                prevBtn?.addEventListener('click', () => goTo(current - 1));
                nextBtn?.addEventListener('click', () => goTo(current + 1));

                document.addEventListener('keydown', e => {
                    if (e.key === 'ArrowLeft') goTo(current - 1);
                    if (e.key === 'ArrowRight') goTo(current + 1);
                });

                let touchStartX = 0;
                const galleryEl = document.getElementById('galleryMain');
                galleryEl?.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
                galleryEl?.addEventListener('touchend', e => {
                    const dx = e.changedTouches[0].clientX - touchStartX;
                    if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
                });

            }());
    </script>
</body>
</html>